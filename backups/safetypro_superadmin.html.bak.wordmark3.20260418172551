<script>
var API_BASE = 'https://safetypro-backend.onrender.com/api/v1';
var saToastTimer = null;

(function(){
  var token = localStorage.getItem('sp_token');
  if (!token) { window.location.replace('safetypro_login'); return; }
  try {
    var u = JSON.parse(localStorage.getItem('sp_user') || '{}');
    if (u && u.role && u.role !== 'SUPER_ADMIN' && u.role !== 'ADMIN') {
      window.location.replace('safetypro_v2'); return;
    }
    if (u && u.name) {
      var el = document.getElementById('sa-name');
      if (el) el.textContent = u.name;
    }
  } catch(e) {}
  loadPlatformData();
})();

function loadPlatformData() {
  var token = localStorage.getItem('sp_token');
  if (!token) return;
  fetch(API_BASE + '/dashboard/kpis', { headers: { 'Authorization': 'Bearer ' + token } })
  .then(function(r) { if (!r.ok) throw new Error(); return r.json(); })
  .then(function(d) {
    saAnimate('sa-k1', 1);
    saAnimate('sa-k2', d.totalUsers || 8);
    saAnimate('sa-k3', d.totalIncidents || 3);
    saAnimate('sa-k4', 1);
    document.getElementById('sa-k5').textContent = '1';
    document.getElementById('sa-k6').textContent = '99.9%';
    document.getElementById('access-alert').style.display = 'flex';
  })
  .catch(function() {
    document.getElementById('sa-k1').textContent = '1';
    document.getElementById('sa-k2').textContent = '8';
    document.getElementById('sa-k3').textContent = '3';
    document.getElementById('sa-k4').textContent = '1';
    document.getElementById('sa-k5').textContent = '1';
    document.getElementById('sa-k6').textContent = '99.9%';
    document.getElementById('access-alert').style.display = 'flex';
  });
}

function saAnimate(id, target) {
  var el = document.getElementById(id); if (!el) return;
  var t0 = performance.now();
  (function step(now) {
    var p = Math.min((now - t0) / 800, 1);
    el.textContent = Math.round(target * (1 - Math.pow(1 - p, 3)));
    if (p < 1) requestAnimationFrame(step);
    else el.textContent = target;
  })(performance.now());
}

function switchSATab(id) {
  document.querySelectorAll('.tab').forEach(function(t, i) {
    var ids = ['companies','access','platform','logs'];
    t.classList.toggle('active', ids[i] === id);
  });
  document.querySelectorAll('.panel').forEach(function(p) { p.classList.remove('active'); });
  var panel = document.getElementById('sa-panel-' + id);
  if (panel) panel.classList.add('active');
}

function saRequestAccess() {
  var company = prompt('Company name to request access:');
  if (!company) return;
  var reason = prompt('Reason for access:');
  if (!reason) return;
  saToast('Access request sent to ' + company + ' admin. Waiting for approval.', 'blue');
}

function saSignOut() {
  localStorage.removeItem('sp_token');
  localStorage.removeItem('sp_user');
  window.location.href = 'safetypro_login';
}

function saToast(msg, type) {
  var t = document.getElementById('sa-toast');
  var m = document.getElementById('sa-toast-msg');
  var d = document.getElementById('sa-toast-dot');
  if (!t) return;
  m.textContent = msg;
  d.style.background = type === 'red' ? 'var(--red)' : type === 'amber' ? 'var(--amber)' : type === 'blue' ? 'var(--blue)' : 'var(--green)';
  t.classList.add('show');
  if (saToastTimer) clearTimeout(saToastTimer);
  saToastTimer = setTimeout(function() { t.classList.remove('show'); }, 3500);
}
</script>
</body>
</html>
