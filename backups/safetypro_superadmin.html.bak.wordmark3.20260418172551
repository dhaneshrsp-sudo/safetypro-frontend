<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Super Admin — SafetyPro . AI</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Roboto:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0B0F14;--card:#131C26;--raised:#16212B;--border:#1E293B;
  --green:#22C55E;--g-s:rgba(34,197,94,0.12);--g-b:rgba(34,197,94,0.3);
  --amber:#F59E0B;--a-s:rgba(245,158,11,0.12);--a-b:rgba(245,158,11,0.3);
  --red:#EF4444;--r-s:rgba(239,68,68,0.12);--r-b:rgba(239,68,68,0.35);
  --blue:#3B82F6;--b-s:rgba(59,130,246,0.12);--b-b:rgba(59,130,246,0.3);
  --purple:#8B5CF6;--p-s:rgba(139,92,246,0.12);
  --t1:#E6EDF3;--t2:#94A3B8;--t3:#64748B;
  --fh:'Montserrat',sans-serif;--fb:'Roboto',sans-serif;
}
body{background:var(--bg);color:var(--t1);font-family:var(--fb);min-height:100vh;}
.topbar{background:#0F1720;border-bottom:1px solid var(--border);padding:0 24px;height:52px;display:flex;align-items:center;justify-content:space-between;}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.logo-shield{width:28px;height:28px;background:linear-gradient(135deg,#22C55E,#16A34A);border-radius:7px;display:flex;align-items:center;justify-content:center;}
.logo-shield svg{width:16px;height:16px;fill:#fff;}
.logo-text{font-family:var(--fh);font-size:14px;font-weight:800;color:var(--t1);}
.logo-text span{color:var(--green);}
.sa-badge{font-size:9px;font-weight:700;padding:2px 8px;border-radius:4px;background:rgba(139,92,246,.15);color:var(--purple);border:1px solid rgba(139,92,246,.3);font-family:var(--fh);}
.topbar-right{display:flex;align-items:center;gap:12px;}
.sa-user{font-size:11px;color:var(--t3);font-family:var(--fh);}
.sa-user strong{color:var(--t1);}
.btn-signout{font-size:10px;padding:5px 14px;border-radius:6px;background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.3);cursor:pointer;font-family:var(--fh);font-weight:600;}
.content{padding:20px 24px;max-width:1400px;margin:0 auto;}
.page-header{margin-bottom:20px;}
.page-title{font-family:var(--fh);font-size:18px;font-weight:800;color:var(--t1);}
.page-sub{font-size:11px;color:var(--t3);margin-top:4px;}
.kpi-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:20px;}
.kpi-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center;}
.kpi-num{font-size:28px;font-weight:800;font-family:var(--fh);}
.kpi-label{font-size:10px;color:var(--t3);margin-top:4px;}
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:16px;}
.card-head{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid var(--border);}
.card-title{font-family:var(--fh);font-size:12px;font-weight:700;color:var(--t1);}
.card-body{padding:14px 16px;}
.company-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:12px;}
.company-card{background:var(--raised);border:1px solid var(--border);border-radius:10px;padding:14px;}
.company-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.company-name{font-family:var(--fh);font-size:12px;font-weight:700;color:var(--t1);}
.status-dot{width:8px;height:8px;border-radius:50%;}
.company-meta{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:10px;}
.meta-item{font-size:10px;color:var(--t3);}
.meta-item strong{color:var(--t2);}
.company-actions{display:flex;gap:6px;}
.btn-sm{font-size:9px;padding:4px 10px;border-radius:5px;cursor:pointer;font-family:var(--fh);font-weight:600;border:1px solid;}
.btn-request{background:rgba(59,130,246,.1);color:var(--blue);border-color:rgba(59,130,246,.3);}
.btn-view{background:rgba(34,197,94,.1);color:var(--green);border-color:rgba(34,197,94,.3);}
.btn-warn{background:rgba(245,158,11,.1);color:var(--amber);border-color:rgba(245,158,11,.3);}
.access-banner{background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.2);border-radius:8px;padding:10px 14px;margin-bottom:16px;display:flex;align-items:center;gap:10px;font-size:11px;color:var(--t2);}
.tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:16px;}
.tab{padding:10px 16px;font-size:11px;font-weight:600;font-family:var(--fh);color:var(--t3);cursor:pointer;border-bottom:2px solid transparent;}
.tab.active{color:var(--green);border-bottom-color:var(--green);}
.panel{display:none;}
.panel.active{display:block;}
table{width:100%;border-collapse:collapse;font-size:11px;}
th{padding:8px 10px;text-align:left;color:var(--t3);font-family:var(--fh);font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border);}
td{padding:9px 10px;border-bottom:1px solid rgba(30,41,59,.5);color:var(--t2);}
td:first-child{color:var(--t1);font-weight:600;}
.badge{font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;font-family:var(--fh);}
.b-active{background:rgba(34,197,94,.1);color:var(--green);border:1px solid rgba(34,197,94,.3);}
.b-trial{background:rgba(59,130,246,.1);color:var(--blue);border:1px solid rgba(59,130,246,.3);}
.b-inactive{background:var(--raised);color:var(--t3);border:1px solid var(--border);}
.b-pro{background:rgba(139,92,246,.1);color:var(--purple);border:1px solid rgba(139,92,246,.3);}
.toast{position:fixed;bottom:24px;right:24px;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:12px 18px;font-size:12px;color:var(--t1);font-family:var(--fh);display:none;z-index:9999;align-items:center;gap:8px;}
.toast.show{display:flex;}

/* SafetyPro scrollbar v2 */
.body { overflow: hidden !important; }
.content { overflow-y: auto !important; scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
.content::-webkit-scrollbar { width: 4px; }
.content::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
</style>
<style>/* sp-height-fix */
html,body{height:100%!important;overflow:hidden!important;}
.body{height:calc(100vh - 52px)!important;overflow:hidden!important;}
</style>
</head>
