var _currentDrilldownProject = null;

function spDrillDownProject(projId, projName) {
  /* If same card clicked again — close */
  if (_currentDrilldownProject === projId) {
    spCloseDrilldown();
    return;
  }
  _currentDrilldownProject = projId;

  /* Highlight the selected card */
  document.querySelectorAll('#portfolio-grid > div').forEach(function(c){
    c.style.outline = 'none';
    c.style.boxShadow = 'none';
  });
  /* Find and highlight the clicked card by projId */
  var clickedCard = document.querySelector('#portfolio-grid > div[data-proj-id="'+projId+'"]');
  if (clickedCard) {
    clickedCard.style.outline = '2px solid var(--green)';
    clickedCard.style.boxShadow = '0 0 12px rgba(34,197,94,.25)';
  }

  /* Try API first, fallback to demo */
  var token = localStorage.getItem('sp_token');
  if (token) {
    spFetch(API_BASE + '/projects/' + projId + '/summary', {
      headers:{ 'Authorization':'Bearer ' + token }
    }).then(function(r){ return r.ok ? r.json() : null; })
    .then(function(data){
      spRenderDrilldownPanel(data && data.id ? data : _ddProjectsMap[projId] || _ddProjectsMap['proj-a']);
    }).catch(function(){
      spRenderDrilldownPanel(_ddProjectsMap[projId] || _ddProjectsMap['proj-a']);
    });
  } else {
    spRenderDrilldownPanel(_ddProjectsMap[projId] || _ddProjectsMap['proj-a']);
  }
}

