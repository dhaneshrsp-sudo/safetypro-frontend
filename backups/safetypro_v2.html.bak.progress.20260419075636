function renderSafeManHours(data, projectId) {
  /* Format large numbers */
  function fmtHours(n) {
    if (!n) return '0';
    if (n >= 1000000) return (n/1000000).toFixed(2) + 'M';
    if (n >= 1000)    return Math.round(n/1000) + 'K';
    return n.toString();
  }

  /* LTIFR = LTI × 1,000,000 ÷ Cumulative Man-Hours */
  var ltifr = data.cumulativeHours > 0
    ? ((data.ltiCount || 0) * 1000000 / data.cumulativeHours).toFixed(2)
    : '0.00';
  /* TRIFR = Recordable × 1,000,000 ÷ Cumulative Man-Hours */
  var trifr = data.cumulativeHours > 0
    ? ((data.recordableCount || 0) * 1000000 / data.cumulativeHours).toFixed(2)
    : '0.00';

  /* Period hours display */
  var valEl  = document.getElementById('safe-manhours-val');
  var unitEl = document.getElementById('safe-manhours-unit');
  if (valEl) {
    var ph = data.periodHours || 0;
    if (ph >= 1000000) { valEl.textContent = (ph/1000000).toFixed(2); if(unitEl) unitEl.textContent = 'Million Hrs'; }
    else if (ph >= 1000) { valEl.textContent = Math.round(ph/1000); if(unitEl) unitEl.textContent = 'K Hrs'; }
    else { valEl.textContent = ph; if(unitEl) unitEl.textContent = 'Hrs'; }
  }

  /* Cumulative */
  var totalEl = document.getElementById('safe-manhours-total');
  if (totalEl) totalEl.textContent = fmtHours(data.cumulativeHours || 0);

  /* LTIFR — colour coded */
  var ltifrEl = document.getElementById('safe-manhours-ltifr');
  if (ltifrEl) {
    ltifrEl.textContent = ltifr;
    ltifrEl.style.color = parseFloat(ltifr) === 0 ? '#10B981' :
                          parseFloat(ltifr) < 1   ? '#F59E0B' : '#EF4444';
  }
  /* TRIFR — colour coded */
  var trifrEl = document.getElementById('safe-manhours-trifr');
  if (trifrEl) {
    trifrEl.textContent = trifr;
    trifrEl.style.color = parseFloat(trifr) === 0 ? '#10B981' :
                          parseFloat(trifr) < 2   ? '#F59E0B' : '#EF4444';
  }

  /* Activity items */
  var tb = document.getElementById('ap-toolbox');
  if (tb) tb.textContent = data.toolboxTalks || '—';
  var ins = document.getElementById('ap-inspections');
  if (ins) ins.textContent = data.inspections || '—';
  var ac = document.getElementById('ac-score');
  if (ac) ac.textContent = data.trainingPct ? data.trainingPct + '%' : '—';

  /* ── Consolidated breakdown panel ── */
  spRenderManHoursBreakdown(data, projectId);

  /* Feed lagging KPI mode */
  if (window._kpiMode === 'lagging') {
    var kn1 = document.getElementById('kn1'); if(kn1) kn1.textContent = ltifr;
    var kn2 = document.getElementById('kn2'); if(kn2) kn2.textContent = trifr;
  }
  animateBars();
}

