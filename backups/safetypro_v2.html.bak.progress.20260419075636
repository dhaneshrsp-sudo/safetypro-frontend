  /* Show panel with smooth animation */
  panel.style.display = 'block';
  panel.style.opacity = '0';
  panel.style.transform = 'translateY(-8px)';
  requestAnimationFrame(function(){
    panel.style.transition = 'opacity .25s, transform .25s';
    panel.style.opacity = '1';
    panel.style.transform = 'translateY(0)';
  });

  /* Scroll to panel */
  setTimeout(function(){
    panel.scrollIntoView({ behavior:'smooth', block:'nearest' });
  }, 100);
}

function spFmtHrs(n) {
  if (!n) return '0';
  if (n >= 1000000) return (n/1000000).toFixed(2) + 'M';
  if (n >= 1000) return Math.round(n/1000) + 'K';
  return n.toString();
}

function spCloseDrilldown() {
  var panel = document.getElementById('portfolio-drilldown');
  if (!panel) return;
  panel.style.opacity = '0';
  panel.style.transform = 'translateY(-8px)';
  setTimeout(function(){ panel.style.display = 'none'; }, 250);
  _currentDrilldownProject = null;
  /* Remove card highlights */
  document.querySelectorAll('#portfolio-grid > div').forEach(function(c){
    c.style.outline = 'none';
  });
}

