    var k4 = document.getElementById('kn4');
    if (k4) {
      var score = kpis.auditScore || 87;
      var t = performance.now();
      (function step(now) {
        var p = Math.min((now - t) / 1200, 1);
        var v = Math.round(score * (1 - Math.pow(1 - p, 3)));
        k4.innerHTML = v + '<span style="font-size:12px;color:var(--t3);font-weight:400">%</span>';
        if (p < 1) requestAnimationFrame(step);
      })(performance.now());
    }
    /* NEW: Feed command center + ISO 45001 HSE Score + performance cards */
    loadCommandCenter(kpis);
    loadHSEScore(kpis);
    loadPerformanceCards(kpis);
    /* Reload man-hours for selected project context */
    if (typeof loadSafeManHours === 'function') loadSafeManHours();
    if (typeof loadSafetyRecord === 'function') loadSafetyRecord();
    /* Sidebar badges */
    var sbOps = document.getElementById('sb-badge-ops');
    if (sbOps && kpis.pending > 0) { sbOps.textContent = kpis.pending; sbOps.style.display = 'inline-flex'; }
    var sbCtrl = document.getElementById('sb-badge-ctrl');
    if (sbCtrl && kpis.escalated > 0) { sbCtrl.textContent = kpis.escalated; sbCtrl.style.display = 'inline-flex'; }
    if (document.getElementById('rc-critical')) animateNum(document.getElementById('rc-critical'), kpis.escalated || 5);
    var dot = document.getElementById('alert-dot');
    if (dot && kpis.escalated > 0) dot.style.display = 'block';
    var total = document.getElementById('stat-total');
    if (total && kpis.totalIncidents) animateNum(total, kpis.totalIncidents);
    var month = document.getElementById('stat-month');
    if (month && kpis.monthIncidents) animateNum(month, kpis.monthIncidents);
  })
  .catch(function() { setFallbackKPIs(); });
}

