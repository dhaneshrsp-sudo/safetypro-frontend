      '</div>' +
      /* ACTION PERFORMANCE 50% */
      '<div style="font-size:9px;font-weight:700;color:#F59E0B;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Action Performance — 50%</div>' +
      spAccBar('Closure Rate',    closureRate, 30, '#10B981') +
