/* ═══════════════════════════════════════════════════════════════
   ISO 45001:2018 COMPOSITE HSE SCORE ENGINE
   Clause 9.1 — Performance Evaluation
   Score: 0-100 | 85-100=Excellent | 70-84=Acceptable | 50-69=High Risk | 0-49=Critical
   ═══════════════════════════════════════════════════════════════ */

var _hseScoreData = {};

var HSE_GRADES = [
  { min:85, label:'Excellent',  color:'var(--green)',  bg:'rgba(34,197,94,.12)'  },
  { min:70, label:'Acceptable', color:'#22D3EE',       bg:'rgba(34,211,238,.12)' },
  { min:50, label:'High Risk',  color:'var(--amber)',  bg:'rgba(245,158,11,.12)' },
  { min:0,  label:'Critical',   color:'var(--red)',    bg:'rgba(239,68,68,.12)'  }
];
function spGetGrade(score) {
  for (var i=0;i<HSE_GRADES.length;i++) { if (score>=HSE_GRADES[i].min) return HSE_GRADES[i]; }
  return HSE_GRADES[HSE_GRADES.length-1];
}

function spCalcHSEScore(data) {
  var ltifr    = Math.max(0,100-((data.ltifr||0)*20));
  var trifr    = Math.max(0,100-((data.trifr||0)*10));
  var severity = Math.max(0,100-(data.severityRate||0));
  var audit    = data.auditCompliance||data.auditScore||87;
  var closure  = data.actionClosureRate||data.closureRate||78;
  var training = data.trainingCompletion||data.trainingScore||82;
  var nearmiss = data.nearMissRate||70;
  var overdueInv = data.overdueInverse||Math.max(0,100-((data.overdue||data.pending||0)*5));
  var ptw      = data.ptwCompliance||data.permitCompliance||85;
  var score = Math.round(
    (ltifr*0.15)+(trifr*0.15)+(severity*0.10)+
    (audit*0.10)+(closure*0.10)+(training*0.10)+(nearmiss*0.10)+
    (overdueInv*0.10)+(ptw*0.10)
  );
  return {
    score:Math.min(100,Math.max(0,score)),
    ltifr:Math.round(ltifr),trifr:Math.round(trifr),severity:Math.round(severity),
    audit:Math.round(audit),closure:Math.round(closure),training:Math.round(training),
    nearmiss:Math.round(nearmiss),overdue:Math.round(overdueInv),ptw:Math.round(ptw),
    previousScore:data.previousScore
  };
}

function spRenderHSEScore(components) {
  _hseScoreData = components;
  var score = components.score;
  var grade = spGetGrade(score);
  var el = document.getElementById('global-score');
  if (el) { el.style.color = grade.color; animateNum(el, score); }
  var badge = document.getElementById('hse-grade-badge');
  if (badge) { badge.textContent=grade.label; badge.style.background=grade.bg; badge.style.color=grade.color; badge.style.border='1px solid '+grade.color+'33'; badge.style.display='inline-block'; }
  var bar = document.getElementById('hse-score-bar');
  if (bar) { bar.style.background=grade.color; setTimeout(function(){ bar.style.width=score+'%'; },300); }
  var trend = document.getElementById('score-trend');
  if (trend) { var diff=score-(components.previousScore||(score-2)); trend.textContent=(diff>=0?'⬆ ':'⬇ ')+(diff>=0?'+':'')+diff+' pts · '+grade.label; trend.style.color=diff>=0?'var(--green)':'var(--red)'; }
  var avg = document.getElementById('hse-industry-avg');
  if (avg) avg.textContent = '79';
  var lc = document.getElementById('hse-last-calc');
  if (lc) lc.textContent = 'Calculated: '+new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  var fields = [
    ['sb-ltifr','sb-ltifr-v',components.ltifr],['sb-trifr','sb-trifr-v',components.trifr],
    ['sb-severity','sb-severity-v',components.severity],['sb-audit','sb-audit-v',components.audit],
    ['sb-closure','sb-closure-v',components.closure],['sb-training','sb-training-v',components.training],
    ['sb-nearmiss','sb-nearmiss-v',components.nearmiss],['sb-overdue','sb-overdue-v',components.overdue],
    ['sb-ptw','sb-ptw-v',components.ptw]
  ];
  fields.forEach(function(f){
    var b=document.getElementById(f[0]); var v=document.getElementById(f[1]);
    if(b) setTimeout(function(){ b.style.width=f[2]+'%'; },500);
    if(v) v.textContent=f[2]+'%';
  });
}

var _scoreBreakdownOpen = false;
function spToggleScoreBreakdown() {
  var el = document.getElementById('hse-score-breakdown'); if (!el) return;
