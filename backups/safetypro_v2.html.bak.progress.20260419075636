var PV_ICONS = {dam:'🏗️',metro:'🚇',plant:'⚡',highway:'🛣️',road:'🛣️',power:'⚡',water:'💧',building:'🏢',default:'📋'};
function pvGetIcon(name){var n=(name||'').toLowerCase();for(var k in PV_ICONS){if(n.indexOf(k)>-1)return PV_ICONS[k];}return PV_ICONS.default;}

function pvLoadProjectBar(){
  var sel=document.getElementById('pv-proj-select');
  if(!sel){pvRenderProjectBar(pvFallbackProjects());return;}
  var token=localStorage.getItem('sp_token');
  if(!token){pvRenderProjectBar(pvFallbackProjects());return;}
  fetch(API_BASE+'/projects',{headers:{'Authorization':'Bearer '+token}})
  .then(function(r){return r.ok?r.json():null;})
  .then(function(p){pvRenderProjectBar(p&&p.length?p:pvFallbackProjects());if(p&&p.length)pvSyncSubnavDropdown(p);})
  .catch(function(){pvRenderProjectBar(pvFallbackProjects());});
}

function pvFallbackProjects(){
  return [{id:'proj-a',name:'Project A',location:'Region A',sector:'Construction'},
    {id:'proj-b',name:'Project B',location:'Region B',sector:'Infrastructure'},
    {id:'proj-c',name:'Project C',location:'Region C',sector:'Industrial'},
    {id:'proj-d',name:'Project D',location:'Region D',sector:'Highway'}];
}

// Live project map: id → project data (works with both real cuid & fallback keys)
var _pvProjectsMap = {};

function pvRenderProjectBar(projects){
  // Build live map so pvRenderHero can look up by real ID
  _pvProjectsMap = {};
  projects.forEach(function(p){ _pvProjectsMap[p.id] = p; });
  // Populate dropdown
  var sel = document.getElementById('pv-proj-select');
  if (!sel) return;
  sel.innerHTML = '<option value="">— Choose project —</option>' +
    projects.map(function(p){
      var icon = pvGetIcon(p.name+' '+(p.sector||''));
      return '<option value="'+p.id+'">'+icon+' '+p.name+(p.location?' — '+p.location:'')+'</option>';
    }).join('');
  // Style the select
  sel.style.borderColor = 'var(--border)';
  // If no project loaded yet, auto-select first
  if (!_pvCurrent && sel.options.length > 1) {
    sel.selectedIndex = 1;
    pvSelectProjectByDropdown(sel);
  }
}

function pvSelectProjectByDropdown(sel) {
  var proj = sel.value;
  if (!proj) return;
  // Update info bar
  var info = document.getElementById('pv-proj-info');
  var loc = document.getElementById('pv-proj-location');
  var p = _pvProjectsMap[proj];
  if (info && p) {
    info.style.display = 'block';
    if (loc) loc.textContent = '📍 ' + (p.location || p.state || '');
  }
  // Highlight select
  sel.style.borderColor = 'rgba(34,197,94,.4)';
  sel.style.color = 'var(--green)';
  // Sync subnav dropdown too
  var navSel = document.getElementById('filter-project');
  if (navSel) navSel.value = proj;
  loadProjectView(proj);
}

function pvSyncSubnavDropdown(projects){
  var sel=document.getElementById('filter-project');if(!sel)return;
  var cur=sel.value;
  sel.innerHTML='<option value="">All Projects</option>'+
    projects.map(function(p){return '<option value="'+p.id+'"'+(p.id===cur?' selected':'')+'>'+p.name+'</option>';}).join('');
}

function pvSelectProject(el, proj) {
  // Highlight active button
  document.querySelectorAll('.pv-proj-btn').forEach(function(b) {
    b.style.background = 'var(--elevated)';
    b.style.color = 'var(--t3)';
    b.style.borderColor = 'var(--border)';
  });
  el.style.background = 'var(--green-dim)';
  el.style.color = 'var(--green)';
  el.style.borderColor = 'rgba(34,197,94,.3)';
  // Sync subnav dropdown
  var sel = document.getElementById('filter-project');
  if (sel) sel.value = proj;
  // Load project
  loadProjectView(proj);
}

function loadProjectView(projectId) {
  if (!projectId) return;
  _pvCurrent = projectId;
  // Sync project switcher buttons
  document.querySelectorAll('.pv-proj-btn').forEach(function(b) {
    var isActive = b.getAttribute('data-proj') === projectId;
    b.style.background = isActive ? 'var(--green-dim)' : 'var(--elevated)';
    b.style.color = isActive ? 'var(--green)' : 'var(--t3)';
    b.style.borderColor = isActive ? 'rgba(34,197,94,.3)' : 'var(--border)';
  });
  var token = localStorage.getItem('sp_token');
  if (!token) return;
  var API = API_BASE;

  // Reset to loading state
  ['pv-k1','pv-k2','pv-k3'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.textContent = '—';
  });

  // Render static metadata immediately (no API needed)
  pvRenderHero(projectId, null);
  pvRenderKPIs(projectId, null);
  pvRenderCompliance(projectId);

  // Fetch KPIs
  fetch(API + '/dashboard/kpis?projectId=' + projectId, {
    headers: { 'Authorization': 'Bearer ' + token }
  })
  .then(function(r) { return r.ok ? r.json() : null; })
  .then(function(kpis) {
    if (kpis) {
      pvRenderHero(projectId, kpis);
      pvRenderKPIs(projectId, kpis);
    }
  })
  .catch(function() {});

  // Fetch Incidents
  fetch(API + '/incidents?projectId=' + projectId + '&limit=20', {
    headers: { 'Authorization': 'Bearer ' + token }
  })
  .then(function(r) { return r.ok ? r.json() : null; })
  .then(function(data) {
    var items = null;
    if (Array.isArray(data)) { items = data; }
    else if (data && Array.isArray(data.data)) { items = data.data; }
    else if (data && Array.isArray(data.items)) { items = data.items; }
    else if (data && Array.isArray(data.incidents)) { items = data.incidents; }
    else if (data && Array.isArray(data.results)) { items = data.results; }
    else if (data) { for (var k in data) { if (Array.isArray(data[k]) && data[k].length > 0) { items = data[k]; break; } } }
    if (items && items.length) {
      pvRenderIncidents(items);
    } else {
      pvRenderIncidents(pvDemoIncidents(projectId));
    }
  })
  .catch(function() { pvRenderIncidents(pvDemoIncidents(projectId)); });

  // Fetch Actions
  fetch(API + '/actions?projectId=' + projectId + '&limit=10', {
    headers: { 'Authorization': 'Bearer ' + token }
  })
  .then(function(r) { return r.ok ? r.json() : null; })
  .then(function(data) {
    // Store raw response for debugging
    window._pvLastActionsRaw = data;
    // Handle ALL backend response shapes
    var items = null;
    if (Array.isArray(data)) { items = data; }
    else if (data && Array.isArray(data.data)) { items = data.data; }
    else if (data && Array.isArray(data.items)) { items = data.items; }
    else if (data && Array.isArray(data.actions)) { items = data.actions; }
    else if (data && Array.isArray(data.results)) { items = data.results; }
    else if (data && data.total !== undefined) {
      for (var k in data) { if (Array.isArray(data[k]) && data[k].length > 0) { items = data[k]; break; } }
    }
    if (items && items.length) {
      // Store first item keys for debugging
      window._pvActionsFirstKeys = Object.keys(items[0] || {}).join(', ');
      pvRenderActions(items);
    } else {
      // API returned nothing - use demo data
      pvRenderActions(pvDemoActions(projectId));
    }
  })
  .catch(function(e) {
    window._pvActionsError = e.message;
    pvRenderActions(pvDemoActions(projectId));
  });
}

