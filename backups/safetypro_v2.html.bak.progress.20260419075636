function spFilterCompareList(q) {
  var items = document.querySelectorAll('#cmp-list label');
  var count = 0;
  items.forEach(function(item){
    var match = item.textContent.toLowerCase().includes(q.toLowerCase());
    item.style.display = match ? '' : 'none';
    if (match) count++;
  });
  var countEl = document.getElementById('cmp-count');
  if (countEl) countEl.textContent = count + ' shown';
}

function spSelectAllCompare(checked) {
  document.querySelectorAll('.cmp-cb, [id^="cmp-cb-"]').forEach(function(cb){ cb.checked = checked; });
}

function spSelectCriticalCompare() {
  /* Uncheck all, then check only critical */
  document.querySelectorAll('.cmp-cb, [id^="cmp-cb-"]').forEach(function(cb){ cb.checked = false; });
  document.querySelectorAll('#cmp-list label[data-risk="critical"] input').forEach(function(cb){ cb.checked = true; });
  renderCompareChart();
}

function spUpdateCompareBadge(cb) {
  var label = cb.closest('label');
  if (label) label.style.borderColor = cb.checked ? 'rgba(34,197,94,.3)' : 'var(--border)';
}

function renderCompareChart() {
  var el = document.getElementById('portfolio-compare-chart'); if (!el) return;

  /* Merge live data with _ddProjectsMap for full fields */
  var allProjects = (_portfolioAllProjects && _portfolioAllProjects.length)
    ? _portfolioAllProjects.map(function(p){
        var extra = (window._ddProjectsMap && window._ddProjectsMap[p.id]) || {};
        return Object.assign({}, extra, p);
      })
    : Object.values(window._ddProjectsMap || {});

  /* Get checked project IDs */
  var checkedIds = Array.from(document.querySelectorAll('#compare-checkboxes input[type="checkbox"]:checked'))
    .map(function(cb){ return cb.value; });
  var projects = checkedIds.length
    ? allProjects.filter(function(p){ return checkedIds.indexOf(p.id) >= 0; })
    : allProjects;

  if (!projects.length) {
    el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--t3);">Select at least one project to compare</div>';
    return;
  }

  /* Metric definitions */
  var metrics = [
    { key:'hseScore',   label:'HSE Score',      unit:'%',  icon:'🛡',
      val:function(p){ return p.hseScore||0; },
      fmt:function(v){ return v+'%'; },
      color:function(v){ return v>=80?'#10B981':v>=60?'#F59E0B':'#EF4444'; },
      higherBetter:true,
      iso:85, global:74 },
    { key:'incidents',  label:'Open Incidents', unit:'',   icon:'🔴',
      val:function(p){ return p.incidents||0; },
      fmt:function(v){ return v; },
      color:function(v){ return v===0?'#10B981':v<5?'#F59E0B':'#EF4444'; },
      higherBetter:false,
      iso:0, global:null },
    { key:'overdue',    label:'Overdue Actions',unit:'',   icon:'⏱',
      val:function(p){ return p.overdue||0; },
      fmt:function(v){ return v; },
      color:function(v){ return v===0?'#10B981':v<3?'#F59E0B':'#EF4444'; },
      higherBetter:false,
      iso:0, global:null },
    { key:'compliance', label:'Compliance',     unit:'%',  icon:'✅',
      val:function(p){ return p.compliance||0; },
      fmt:function(v){ return v+'%'; },
      color:function(v){ return v>=85?'#10B981':v>=70?'#F59E0B':'#EF4444'; },
      higherBetter:true,
      iso:90, global:72 },
    { key:'manhours',   label:'Man-Hours',      unit:'',   icon:'⏰',
      val:function(p){ var h=p.periodHours||0; return h; },
      fmt:function(v){ return v>=1000000?(v/1000000).toFixed(1)+'M':v>=1000?Math.round(v/1000)+'K':'—'; },
      color:function(){ return '#10B981'; },
      higherBetter:true,
      iso:null, global:null },
    { key:'ltifr',      label:'LTIFR',          unit:'',   icon:'📊',
      val:function(p){ var h=p.periodHours||1; return Math.round((p.ltiCount||0)*1000000/h*100)/100; },
      fmt:function(v){ return v.toFixed(2); },
      color:function(v){ return v===0?'#10B981':v<1?'#F59E0B':'#EF4444'; },
      higherBetter:false,
      iso:1.0, global:1.8 },
    { key:'trifr',      label:'TRIFR',          unit:'',   icon:'📉',
      val:function(p){ var h=p.periodHours||1; return Math.round((p.recordableCount||0)*1000000/h*100)/100; },
      fmt:function(v){ return v.toFixed(2); },
      color:function(v){ return v===0?'#10B981':v<3?'#F59E0B':'#EF4444'; },
      higherBetter:false,
      iso:3.0, global:4.2 },
  ];

  /* Find best/worst per metric */
  var metricStats = {};
  metrics.forEach(function(m) {
    var vals = projects.map(function(p){ return m.val(p); });
    metricStats[m.key] = {
      best:  m.higherBetter ? Math.max.apply(null,vals) : Math.min.apply(null,vals),
      worst: m.higherBetter ? Math.min.apply(null,vals) : Math.max.apply(null,vals),
      max:   Math.max.apply(null,vals) || 1
    };
  });

  /* Ensure _benchmarks is available */
  if (typeof _benchmarks === 'undefined') {
    window._benchmarks = {
      global: { hseScore:{value:74}, compliance:{value:72}, ltifr:{value:1.8}, trifr:{value:4.2} },
      iso:    { hseScore:{value:85}, compliance:{value:90}, ltifr:{value:1.0}, trifr:{value:3.0} },
      company: null
    };
  }

  /* ── SCORECARD DESIGN ──
     Each project = a vertical card with:
     - Header: project name + risk badge + overall score ring
     - Metric rows with status pill + value + mini radial fill
     - Bottom: benchmark comparison pills
  */
  var riskConfig = {
    critical: { color:'#EF4444', bg:'rgba(239,68,68,.08)', border:'rgba(239,68,68,.25)', label:'Critical' },
    medium:   { color:'#F59E0B', bg:'rgba(245,158,11,.08)', border:'rgba(245,158,11,.25)', label:'Medium'   },
    safe:     { color:'#10B981', bg:'rgba(34,197,94,.06)',  border:'rgba(34,197,94,.2)',   label:'Safe'     }
  };

  var cards = projects.map(function(p) {
    var risk = p.riskLevel || (p.hseScore<50?'critical':p.hseScore<75?'medium':'safe');
    var rc   = riskConfig[risk] || riskConfig.safe;
    var score = p.hseScore || 0;

    /* Circular score ring SVG */
    var circumference = 2 * Math.PI * 20;
    var dashoffset    = circumference * (1 - score/100);
    var ring = '<svg width="54" height="54" viewBox="0 0 54 54" style="flex-shrink:0;">' +
      '<circle cx="27" cy="27" r="20" fill="none" stroke="var(--border)" stroke-width="4"/>' +
      '<circle cx="27" cy="27" r="20" fill="none" stroke="'+rc.color+'" stroke-width="4" stroke-linecap="round" ' +
        'stroke-dasharray="'+circumference+'" stroke-dashoffset="'+dashoffset+'" ' +
        'transform="rotate(-90 27 27)" style="transition:stroke-dashoffset 1.2s;"/>' +
      '<text x="27" y="31" text-anchor="middle" font-size="11" font-weight="800" font-family="Inter,sans-serif" fill="'+rc.color+'">'+score+'</text>' +
    '</svg>';

    /* Metric rows */
    var metricRows = metrics.map(function(m) {
      var val    = m.val(p);
      var fmtVal = m.fmt(val);
      var color  = m.color(val);
      var stats  = metricStats[m.key];
      var isBest  = val === stats.best  && projects.length > 1;
      var isWorst = val === stats.worst && projects.length > 1 && stats.best !== stats.worst;

      /* Status indicator */
      var statusDot = isWorst ? '🔴' : color === '#10B981' ? '🟢' : color === '#F59E0B' ? '🟡' : '🟠';

      /* Gauge fill width relative to best in group */
      var gaugeMax = stats.max || 1;
      var gaugePct = m.higherBetter
        ? Math.round(val/gaugeMax*100)
        : Math.round((1 - (val - Math.min.apply(null,projects.map(function(x){ return m.val(x); }))) / (gaugeMax - Math.min.apply(null,projects.map(function(x){ return m.val(x); })) || 1))*100);

      return '<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--border2);">' +
        '<div style="font-size:11px;flex-shrink:0;width:18px;text-align:center;">'+m.icon+'</div>' +
        '<div style="flex:1;">' +
          '<div style="font-size:9px;color:var(--t3);font-family:var(--fh);font-weight:600;text-transform:uppercase;letter-spacing:.3px;">'+m.label+'</div>' +
          '<div style="display:flex;align-items:center;gap:5px;margin-top:2px;">' +
            '<span style="font-family:var(--fh);font-size:14px;font-weight:800;color:'+color+';">'+fmtVal+'</span>' +
            (isBest  ? '<span style="font-size:9px;background:#10B98122;color:#10B981;padding:1px 5px;border-radius:10px;font-family:var(--fh);font-weight:700;border:1px solid #10B98144;">BEST</span>' : '') +
            (isWorst ? '<span style="font-size:9px;background:#EF444422;color:#EF4444;padding:1px 5px;border-radius:10px;font-family:var(--fh);font-weight:700;border:1px solid #EF444444;">WORST</span>' : '') +
          '</div>' +
          /* Gauge bar */
          '<div style="height:3px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:3px;">' +
            '<div style="height:100%;width:'+gaugePct+'%;background:'+color+';border-radius:2px;transition:width 1s;"></div>' +
          '</div>' +
        '</div>' +
        /* Benchmark comparison pill */
        (m.iso !== null ?
          '<div style="text-align:right;flex-shrink:0;">' +
            '<div style="font-size:8px;color:'+(m.higherBetter ? (val>=m.iso?'#10B981':'#EF4444') : (val<=m.iso?'#10B981':'#EF4444'))+';">'+
              (m.higherBetter ? (val>=m.iso?'▲ ISO':'▼ ISO') : (val<=m.iso?'✓ ISO':'▲ ISO'))+
            '</div>' +
            (m.global !== null ? '<div style="font-size:8px;color:'+(m.higherBetter?(val>=m.global?'#10B981':'#94A3B8'):(val<=m.global?'#10B981':'#94A3B8'))+';">'+
              (m.higherBetter?(val>=m.global?'▲ Avg':'▼ Avg'):(val<=m.global?'✓ Avg':'▲ Avg'))+
            '</div>' : '') +
          '</div>'
        : '') +
      '</div>';
    }).join('');

    /* VS Benchmark summary pills at bottom */
    var ltifr = metrics.find(function(m){ return m.key==='ltifr'; });
    var trifr = metrics.find(function(m){ return m.key==='trifr'; });
    var lv = ltifr ? ltifr.val(p) : 0;
    var tv = trifr ? trifr.val(p) : 0;
    var vsISO    = lv <= 1.0 && tv <= 3.0;
    var vsGlobal = lv <= 1.8 && tv <= 4.2;

    return '<div style="background:'+rc.bg+';border:1.5px solid '+rc.border+';border-radius:12px;padding:14px;min-width:0;display:flex;flex-direction:column;gap:0;">' +
      /* Card header */
      '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid var(--border);">' +
        ring +
        '<div style="flex:1;min-width:0;">' +
          '<div style="font-family:var(--fh);font-size:13px;font-weight:800;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + (p.name||p.id) + '</div>' +
          '<div style="font-size:9px;color:var(--t3);margin-top:1px;">' + (p.location||'') + (p.sector?' · '+p.sector:'') + '</div>' +
          '<div style="font-size:9px;font-weight:700;color:'+rc.color+';background:'+rc.color+'18;border:1px solid '+rc.color+'33;border-radius:4px;padding:1px 7px;display:inline-block;margin-top:3px;">'+rc.label+'</div>' +
        '</div>' +
      '</div>' +
      /* Metrics */
      metricRows +
      /* Footer: vs benchmark */
      '<div style="display:flex;gap:4px;margin-top:8px;padding-top:8px;border-top:1px solid var(--border);flex-wrap:wrap;">' +
        '<div style="font-size:8px;font-weight:700;padding:2px 7px;border-radius:10px;background:'+(vsISO?'#10B98122':'#EF444422')+';color:'+(vsISO?'#10B981':'#EF4444')+';border:1px solid '+(vsISO?'#10B98144':'#EF444444')+'">' + (vsISO?'✓ Below ISO':'↑ Above ISO') + ' Target</div>' +
        '<div style="font-size:8px;font-weight:700;padding:2px 7px;border-radius:10px;background:'+(vsGlobal?'#10B98122':'#F59E0B22')+';color:'+(vsGlobal?'#10B981':'#F59E0B')+';border:1px solid '+(vsGlobal?'#10B98144':'#F59E0B44')+'">' + (vsGlobal?'✓ Below Global Avg':'↑ Above Global Avg') + '</div>' +
      '</div>' +
    '</div>';
  });

  /* Grid of cards */
  var gridCols = projects.length <= 2 ? 'repeat('+projects.length+',1fr)' :
                 projects.length <= 4 ? 'repeat('+projects.length+',1fr)' :
                 'repeat(auto-fit,minmax(220px,1fr))';

  el.innerHTML =
    '<div style="display:grid;grid-template-columns:'+gridCols+';gap:12px;">' +
      cards.join('') +
    '</div>' +
    /* Legend footer */
    '<div style="margin-top:10px;padding:8px 12px;background:var(--elevated);border-radius:8px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">' +
      '<div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;">' +
        '<span style="font-size:9px;color:var(--t3);font-weight:600;">BENCHMARKS:</span>' +
        '<span style="font-size:9px;color:#22D3EE;">🎯 ISO 45001 LTIFR&lt;1.0 · TRIFR&lt;3.0 · Compliance&gt;90%</span>' +
        '<span style="font-size:9px;color:#94A3B8;">🌍 Global Construction Avg LTIFR 1.8 · TRIFR 4.2 (ILO/HSE UK 2023)</span>' +
        (window._benchmarks && window._benchmarks.company ? '<span style="font-size:9px;color:#F59E0B;">⭐ Company targets loaded</span>' : '<span style="font-size:9px;color:#F59E0B;">⭐ Set company targets in Admin → Settings</span>') +
      '</div>' +
      '<span style="font-size:9px;color:var(--t3);">'+projects.length+' project'+(projects.length>1?'s':'')+' · ▲ = above target (needs improvement)</span>' +
    '</div>';
}



