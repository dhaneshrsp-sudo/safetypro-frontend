  var period    = document.getElementById('filter-time')?.value || '30';

  /* Build URL — project-specific OR consolidated (all projects) */
  var url = API_BASE + '/dashboard/man-hours';
  var params = [];
  if (projectId) params.push('projectId=' + projectId);
  if (period)    params.push('days=' + period);
  if (params.length) url += '?' + params.join('&');

  /* Update card header label */
  spUpdateManHoursLabel(projectId);

  spFetch(url, { headers:{ 'Authorization':'Bearer ' + token } })
  .then(function(r){ return r.ok ? r.json() : null; })
  .then(function(data){
