var _pvCurrent = null;

function pvAnimate(el, val, suffix) {
  if (!el) return;
  suffix = suffix || '';
  var start = performance.now();
  var num = parseInt(val) || 0;
  (function step(now) {
    var p = Math.min((now - start) / 900, 1);
    var e = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.round(num * e) + suffix;
    if (p < 1) requestAnimationFrame(step);
  })(performance.now());
}

function pvRenderHero(proj, kpis) {
  // Use live API data first, fall back to hardcoded PV_PROJECTS
  var liveP = _pvProjectsMap[proj];
  var p = PV_PROJECTS[proj] || (liveP ? {
    name: liveP.name,
    icon: pvGetIcon(liveP.name + ' ' + (liveP.sector||'')),
    location: liveP.location || liveP.state || '',
    contractor: 'Your Contractor',
    phase: liveP.sector || 'Active',
    phaseColor: 'var(--blue)',
    completion: 65,
    safeDays: 0,
    daysLeft: 0,
    manpower: 0,
    safeManHrs: '—',
    scoreColor: 'var(--green)',
    compliance: [
      {label:'ISO 45001',pct:80},{label:'BOCW 1996',pct:85},
      {label:'DGFASLI',pct:78},{label:'Factories Act',pct:82},{label:'IMS',pct:75}
    ]
  } : null);
  if (!p) return;

  // Icon + glow
  var icon = document.getElementById('pv-icon');
  if (icon) {
    icon.textContent = p.icon;
    icon.style.background = 'rgba(255,255,255,.06)';
    icon.style.border = '1px solid var(--border)';
  }
  var glow = document.getElementById('pv-glow');
  if (glow) glow.style.background = p.scoreColor;

  // Name + phase
  var name = document.getElementById('pv-name');
  if (name) name.textContent = p.name;
  var phase = document.getElementById('pv-phase');
  if (phase) {
    phase.textContent = p.phase;
    phase.style.background = 'rgba(255,255,255,.06)';
    phase.style.color = p.phaseColor;
    phase.style.border = '1px solid ' + p.phaseColor.replace('var(', '').replace(')', '');
    phase.style.borderColor = p.phaseColor;
  }

  // Meta
  var meta = document.getElementById('pv-meta');
  if (meta) meta.innerHTML =
    '<span>📍 ' + p.location + '</span>' +
    '<span>🏢 ' + p.contractor + '</span>';

  // Safe days
  var sd = document.getElementById('pv-safe-days');
  if (sd) pvAnimate(sd, p.safeDays, '');

  // Days left
  var dl = document.getElementById('pv-days-left');
  if (dl) {
    if (p.daysLeft === 0) { dl.textContent = 'Done'; dl.style.color = 'var(--green)'; }
    else pvAnimate(dl, p.daysLeft, '');
  }

  // HSE Score from API or fallback
  var score = kpis ? (kpis.auditScore || kpis.hseScore || 87) : 87;
  var scoreNum = document.getElementById('pv-score-num');
  if (scoreNum) pvAnimate(scoreNum, score, '%');
  var arc = document.getElementById('pv-score-arc');
  if (arc) {
    var circumference = 175.9;
    setTimeout(function() {
      arc.style.strokeDashoffset = circumference - (score / 100) * circumference;
      arc.style.stroke = score >= 80 ? 'var(--green)' : score >= 60 ? 'var(--amber)' : 'var(--red)';
    }, 200);
  }

  // Completion bar
  var bar = document.getElementById('pv-completion-bar');
  var pct = document.getElementById('pv-completion-pct');
  if (bar) setTimeout(function() { bar.style.width = p.completion + '%'; }, 300);
  if (pct) pct.textContent = p.completion + '%';
}

function pvRenderKPIs(proj, kpis) {
  var liveP = _pvProjectsMap[proj];
  var p = PV_PROJECTS[proj] || (liveP ? {manpower:0, safeManHrs:'—'} : null);
  if (!p) return;

  pvAnimate(document.getElementById('pv-k1'), kpis ? (kpis.pending || 0) : 0);
  var k1sub = document.getElementById('pv-k1-sub');
  if (k1sub) k1sub.textContent = 'Pending resolution';

  pvAnimate(document.getElementById('pv-k2'), kpis ? (kpis.escalated || 0) : 0);
  var k2sub = document.getElementById('pv-k2-sub');
  if (k2sub) k2sub.textContent = 'Need immediate action';

  pvAnimate(document.getElementById('pv-k3'), kpis ? (kpis.monthIncidents || 0) : 0);

  pvAnimate(document.getElementById('pv-k4'), p.manpower);

  var k5 = document.getElementById('pv-k5');
  if (k5) { k5.textContent = p.safeManHrs; }
}

function pvRenderIncidents(data) {
  var feed = document.getElementById('pv-incident-feed');
  var count = document.getElementById('pv-inc-count');
  if (!feed) return;

  if (!data || !data.length) {
    feed.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--t3);font-size:12px;">No incidents recorded</div>';
    if (count) count.textContent = '0 incidents';
    return;
  }

  if (count) count.textContent = data.length + ' total';

  feed.innerHTML = data.slice(0, 12).map(function(inc) {
    var sev = (inc.severity || inc.type || 'LOW').toUpperCase();
    var sevColor = sev.indexOf('HIGH') > -1 || sev.indexOf('CRITICAL') > -1 ? 'var(--red)' :
                   sev.indexOf('MED') > -1 ? 'var(--amber)' : 'var(--blue)';
    var date = inc.createdAt || inc.date || inc.reportedAt || '';
    var dateStr = date ? new Date(date).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) : '';
    var title = inc.description || inc.title || inc.type || 'Incident';
    return '<div style="display:flex;gap:10px;padding:8px 4px;border-bottom:1px solid var(--divider);align-items:flex-start;">' +
      '<div style="width:3px;flex-shrink:0;border-radius:2px;align-self:stretch;background:' + sevColor + ';margin-top:2px;"></div>' +
      '<div style="flex:1;min-width:0;">' +
        '<div style="font-size:12px;font-weight:500;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + title + '</div>' +
        '<div style="display:flex;align-items:center;gap:6px;margin-top:3px;">' +
          '<span style="font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px;background:rgba(255,255,255,.05);color:' + sevColor + ';">' + sev + '</span>' +
          (dateStr ? '<span style="font-size:10px;color:var(--t3);">' + dateStr + '</span>' : '') +
        '</div>' +
      '</div>' +
    '</div>';
  }).join('');
}

function pvRenderActions(data) {
  var tbody = document.getElementById('pv-action-tbody');
  var openEl = document.getElementById('pv-act-open');
  var overEl = document.getElementById('pv-act-over');
  var sub = document.getElementById('pv-actions-sub');
  if (!tbody) return;

  if (!data || !data.length) {
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--t3);font-size:12px;">No actions found</td></tr>';
    return;
  }

  var open = 0, over = 0;
  data.forEach(function(a) {
    var s = String(a.status || '').toLowerCase();
    if (s !== 'closed') open++;
    if (s === 'overdue') over++;
  });
  if (openEl) openEl.textContent = open + ' open';
  if (over > 0 && overEl) overEl.textContent = over + ' overdue';
  if (sub) sub.textContent = data.length + ' project actions';

  var rows = [];
  data.slice(0, 10).forEach(function(a) {
    try {
      // Normalize fields using exact Prisma schema names
      var title = String(a.title || a.description || 'Untitled');
      var statusRaw = String(a.status || 'OPEN');
      var st = statusRaw.toLowerCase();
      var stKey = (st === 'closed') ? 'done' : (st === 'overdue') ? 'over' : (st === 'in_progress') ? 'prog' : 'open';
      var pillBg = stKey==='done'?'var(--green-dim)':stKey==='over'?'var(--red-dim)':stKey==='prog'?'var(--blue-dim)':'rgba(255,255,255,.06)';
      var pillColor = stKey==='done'?'var(--green)':stKey==='over'?'var(--red)':stKey==='prog'?'var(--blue)':'var(--t2)';
      var pillText = stKey==='done'?'Closed':stKey==='over'?'Overdue':stKey==='prog'?'In Progress':'Open';
      var srcRaw = String(a.source || 'MANUAL');
      var src = srcRaw==='INCIDENT'?'Incident':srcRaw==='NCR'?'NCR':srcRaw==='AUDIT'?'Audit':srcRaw==='INVESTIGATION'?'Investigation':'Manual';
      var srcColor = srcRaw==='INCIDENT'?'var(--red)':srcRaw==='NCR'?'var(--amber)':'var(--blue)';
      var assigned = '—';
      if (a.assignedTo) { assigned = typeof a.assignedTo === 'string' ? a.assignedTo : (a.assignedTo.name || a.assignedTo.email || '—'); }
      var due = a.dueDate || '';
      var dueStr = due ? new Date(due).toLocaleDateString('en-IN', {day:'numeric', month:'short'}) : '—';
      var dueColor = stKey === 'over' ? 'var(--red)' : 'var(--t2)';
      var prog = typeof a.progressPct === 'number' ? a.progressPct : 0;
      var progColor = stKey==='over'?'var(--red)':stKey==='done'?'var(--green)':'var(--amber)';
      var initials = assigned.split(' ').map(function(w){return w[0]||'';}).join('').substring(0,2).toUpperCase()||'??';
      var avColors = ['#10B981','#3B82F6','#F59E0B','#8B5CF6','#EF4444'];
      var avColor = avColors[(assigned.charCodeAt(0)||65)%5];

      rows.push('<tr style="border-bottom:1px solid var(--divider);">' +
        '<td style="padding:8px 10px;white-space:nowrap;width:80px;"><span style="font-size:9px;font-weight:700;padding:2px 5px;border-radius:3px;background:rgba(255,255,255,.05);color:' + srcColor + ';white-space:nowrap;">' + src + '</span></td>' +
        '<td style="padding:8px 10px;max-width:200px;overflow:hidden;"><div style="font-size:12px;font-weight:500;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + title + '</div></td>' +
        '<td style="padding:8px 10px;"><div style="display:flex;align-items:center;gap:6px;"><div style="width:22px;height:22px;border-radius:50%;background:' + avColor + ';display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:#fff;flex-shrink:0;">' + initials + '</div><span style="font-size:11px;color:var(--t2);">' + assigned + '</span></div></td>' +
        '<td style="padding:8px 10px;white-space:nowrap;"><span style="font-size:11px;color:' + dueColor + ';font-weight:' + (stKey==='over'?'700':'400') + ';">' + dueStr + '</span></td>' +
        '<td style="padding:8px 10px;white-space:nowrap;"><span style="display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:600;padding:2px 7px;border-radius:100px;background:' + pillBg + ';color:' + pillColor + ';">' + pillText + '</span></td>' +
        '<td style="padding:8px 10px;"><div style="display:flex;align-items:center;gap:5px;"><div style="flex:1;height:4px;background:var(--border);border-radius:2px;overflow:hidden;"><div style="height:100%;border-radius:2px;width:' + prog + '%;background:' + progColor + ';"></div></div><span style="font-size:10px;color:var(--t3);min-width:24px;text-align:right;">' + prog + '%</span></div></td>' +
        '</tr>');
    } catch(e) {}
  });

  tbody.innerHTML = rows.length ? rows.join('') : '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--t3);">No actions to display</td></tr>';
}function pvRenderCompliance(proj) {
  var liveP = _pvProjectsMap[proj];
  var p = PV_PROJECTS[proj] || (liveP ? {
    name: liveP.name,
    compliance: [
      {label:'ISO 45001',pct:80},{label:'BOCW 1996',pct:85},
      {label:'DGFASLI',pct:78},{label:'Factories Act',pct:82},{label:'IMS',pct:75}
    ]
  } : null);
  if (!p) return;
  var grid = document.getElementById('pv-compliance-grid');
  var title = document.getElementById('pv-compliance-title');
  if (title) title.textContent = p.name;
  if (!grid) return;
  grid.innerHTML = p.compliance.map(function(c) {
    var color = c.pct >= 90 ? 'var(--green)' : c.pct >= 70 ? 'var(--amber)' : 'var(--red)';
    return '<div style="background:var(--elevated);border:1px solid var(--border);border-radius:8px;padding:12px;">' +
      '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">' +
        '<div style="font-size:11px;font-weight:600;color:var(--t2);">' + c.label + '</div>' +
