  var pms = document.getElementById('cmd-permits-sub');
  if (pm) animateNum(pm, kpis.permitsAtRisk || kpis.activePermits || 0);
  if (pms) pms.textContent = (kpis.permitsExpiringToday || 0) + ' expiring today';
  /* Incidents */
  var inc = document.getElementById('cmd-incidents');
  var incs = document.getElementById('cmd-incidents-sub');
  if (inc) animateNum(inc, kpis.openIncidents || kpis.escalated || 0);
  if (incs) incs.textContent = 'High severity: ' + (kpis.highSeverityIncidents || kpis.escalated || 0);
  /* Closed */
  var cl = document.getElementById('cmd-closed');
  var cls = document.getElementById('cmd-closed-sub');
  if (cl) animateNum(cl, kpis.closedThisWeek || kpis.safeActions || 0);
  var rate = kpis.closureRate || (kpis.safeActions ? Math.min(99, Math.round(kpis.safeActions / (kpis.safeActions + (kpis.pending||1)) * 100)) : 0);
  if (cls) cls.textContent = 'Closure rate: ' + rate + '%';
  /* HSE Score now handled by loadHSEScore() with ISO 45001 formula */
  var daf = document.getElementById('daf-count');
  if (daf) animateNum(daf, kpis.daysAccidentFree || kpis.safeActions || 47);
  var rd = document.getElementById('cmd-record-days');
  if (rd) rd.textContent = kpis.recordDays || 183;
  var as = document.getElementById('cmd-active-sites');
  if (as) as.textContent = kpis.activeSites || kpis.totalProjects || 4;
  /* Critical risk */
  var cr = document.getElementById('cmd-risk-1');
  var crm = document.getElementById('cmd-risk-1-meta');
  var crc = document.getElementById('cmd-critical-count');
  var criticalCount = kpis.criticalRisks || kpis.escalated || 0;
  if (crc) crc.textContent = criticalCount;
  if (cr) cr.textContent = criticalCount > 0 ? (kpis.topCriticalRisk || 'L3 escalation active — stop work recommended at high-risk site') : 'No critical risks detected — all sites operating normally';
  if (crm) crm.textContent = criticalCount > 0 ? (kpis.criticalOwner || 'Owner: HSE Manager') : '';
}

