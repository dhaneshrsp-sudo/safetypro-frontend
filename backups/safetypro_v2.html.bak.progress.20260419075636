/* FIX 5: Audit event emitter — fires on every mutation, non-blocking */
function spEmitAudit(action, resource, meta) {
  var token = localStorage.getItem('sp_token'); if (!token) return;
  var claims = spDecodeToken(token) || {};
  var payload = {
    action: action,
    resource: resource,
    tenantId: spGetTenantId(),
    userId: claims.sub || claims.userId || 'unknown',
    timestamp: new Date().toISOString(),
    page: 'dashboard',
    meta: meta || {}
  };
  /* Fire and forget — never block the UI for audit logging */
  spFetch(API_BASE + '/audit/events', {
    method: 'POST',
    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  }).catch(function(){}); /* silent fail — audit must never break the app */
}

/* FIX 6: SHA-256 hash of sensitive content — never log raw prompts */
function spHashContent(text) {
  if (!text || typeof text !== 'string') return Promise.resolve('[empty]');
  var encoder = new TextEncoder();
  return crypto.subtle.digest('SHA-256', encoder.encode(text))
    .then(function(buf) {
      return Array.from(new Uint8Array(buf)).map(function(b){ return b.toString(16).padStart(2,'0'); }).join('').slice(0,16) + '...';
    }).catch(function(){ return '[hash-unavailable]'; });
}

