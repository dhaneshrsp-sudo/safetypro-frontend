<script>
var API_BASE = 'https://safetypro-backend.onrender.com/api/v1';

/* ── TENANT HELPER ── */
function spGetTenantId() {
  try { var u = JSON.parse(localStorage.getItem('sp_user')||'{}'); return u.tenantId || u.organizationId || ''; } catch(e){ return ''; }
}

/* ── JWT DECODE (no verify — just read claims) ── */
function spDecodeToken(token) {
  try { return JSON.parse(atob(token.split('.')[1].replace(/-/g,'+').replace(/_/g,'/'))); } catch(e){ return null; }
}
function spDecodeHeader(token) {
  try { return JSON.parse(atob(token.split('.')[0].replace(/-/g,'+').replace(/_/g,'/'))); } catch(e){ return null; }
}
function spTokenExpired(token) {
  var p = spDecodeToken(token); if (!p) return true;
  return p.exp && (p.exp * 1000) < Date.now();
}
/* FIX 8: Reject HS256 — symmetric algorithm unsafe on public API */
function spTokenAlgSafe(token) {
  var h = spDecodeHeader(token); if (!h) return false;
  var alg = (h.alg || '').toUpperCase();
  if (alg === 'HS256' || alg === 'HS384' || alg === 'HS512') {
    console.warn('[SafetyPro] Rejected token: insecure algorithm ' + alg + '. RS256/ES256 required.');
    return false;
  }
  return true;
}
/* FIX 1: Silent refresh token — call /auth/refresh before token expires */
function spScheduleRefresh(token) {
  var p = spDecodeToken(token); if (!p || !p.exp) return;
  var msUntilExpiry = (p.exp * 1000) - Date.now();
  var refreshAt = msUntilExpiry - (3 * 60 * 1000); /* 3 min before expiry */
  if (refreshAt <= 0) return; /* already too late */
  setTimeout(function() {
    var rt = localStorage.getItem('sp_refresh_token');
    if (!rt) return; /* no refresh token — user must re-login */
    fetch(API_BASE + '/auth/refresh', {
      method: 'POST', credentials: 'include',
      headers: { 'Content-Type': 'application/json', 'X-Tenant-ID': spGetTenantId() },
      body: JSON.stringify({ refreshToken: rt })
    }).then(function(r) { return r.ok ? r.json() : null; })
    .then(function(data) {
      if (!data || !data.accessToken) { window.location.replace('safetypro_login?reason=refresh_failed'); return; }
      localStorage.setItem('sp_token', data.accessToken);
      if (data.refreshToken) localStorage.setItem('sp_refresh_token', data.refreshToken);
      spScheduleRefresh(data.accessToken); /* schedule next refresh */
    }).catch(function() { /* silent fail — session timeout will catch it */ });
  }, refreshAt);
}
/* FIX 3: Role-based session timeout durations */
function spGetSessionTimeout(role) {
  var r = (role || '').toLowerCase();
  if (r === 'admin' || r === 'operator' || r === 'platform:admin' || r === 'tenant:admin' || r === 'tenant:owner') {
    return { warn: 3.5 * 60 * 60 * 1000, expire: 4 * 60 * 60 * 1000 }; /* 4hr */
  }
  return { warn: 7.5 * 60 * 60 * 1000, expire: 8 * 60 * 60 * 1000 }; /* 8hr default */
}

/* AUTH FETCH WRAPPER — injects Tenant ID, handles 401/403 */
function spFetch(url, opts) {
  opts = opts || {};
  opts.headers = opts.headers || {};
  var tenantId = spGetTenantId();
  if (tenantId) opts.headers['X-Tenant-ID'] = tenantId;
  return fetch(url, opts).then(function(r) {
    if (r.status === 401 || r.status === 403) {
      localStorage.removeItem('sp_token');
      localStorage.removeItem('sp_user');
      localStorage.removeItem('sp_company');
      window.location.replace('safetypro_login?reason=session_expired');
      throw new Error(r.status);
    }
    return r;
  });
}

/* SESSION TIMEOUT — role-based: admin/operator=4hr, viewer/analyst=8hr */
(function(){
  var timeouts = spGetSessionTimeout('viewer'); /* default until role loads */
  var WARN_MS = timeouts.warn, EXPIRE_MS = timeouts.expire;
  var lastActivity = Date.now(), warnShown = false;
  /* Update timeouts when role is known */
  window.spApplyRoleTimeout = function(role) {
    var t = spGetSessionTimeout(role);
    WARN_MS = t.warn; EXPIRE_MS = t.expire; warnShown = false;
  };
  function resetActivity(){ lastActivity = Date.now(); warnShown = false; var w=document.getElementById('sp-session-warn'); if(w)w.style.display='none'; }
  ['click','keydown','scroll','mousemove'].forEach(function(e){ document.addEventListener(e, resetActivity, {passive:true}); });
  setInterval(function(){
    var idle = Date.now() - lastActivity;
    if (idle >= EXPIRE_MS) { localStorage.removeItem('sp_token'); localStorage.removeItem('sp_refresh_token'); window.location.replace('safetypro_login?reason=idle_timeout'); return; }
    if (idle >= WARN_MS && !warnShown) {
      warnShown = true;
      var w = document.getElementById('sp-session-warn');
      if (w) w.style.display = 'flex';
    }
  }, 30000);
})();

/* AUTH GUARD — checks token exists, algorithm safe, not expired, MFA if required */
(function(){
  var token = localStorage.getItem('sp_token');
  if (!token) { window.location.replace('safetypro_login'); return; }
  /* FIX 8: Algorithm warning only — backend currently uses HS256.
     Change to hard-block once NestJS JwtModule is updated to RS256/ES256.
     To upgrade backend: app.module.ts → JwtModule.register({ secret: undefined, privateKey, publicKey, signOptions: { algorithm: 'RS256' } }) */
  if (!spTokenAlgSafe(token)) {
    console.warn('[SafetyPro Security] Token uses weak algorithm (HS256). Upgrade backend to RS256/ES256.');
    /* DO NOT REDIRECT — warn only until backend is upgraded */
  }
  if (spTokenExpired(token)) {
    /* Try refresh token before giving up */
    var rt = localStorage.getItem('sp_refresh_token');
    if (!rt) {
      localStorage.removeItem('sp_token'); localStorage.removeItem('sp_user');
      window.location.replace('safetypro_login?reason=token_expired'); return;
    }
    /* Has refresh token — will attempt silent refresh after load */
  }
  /* FIX 4: MFA check — admin/operator must have MFA enrolled */
  var claims = spDecodeToken(token);
  if (claims) {
    var role = (claims.role || '').toLowerCase();
    var mfaRequired = (role === 'admin' || role === 'operator' || role === 'tenant:admin' || role === 'tenant:owner');
    if (mfaRequired && claims.mfa_enrolled === false) {
      window.location.replace('safetypro_login?reason=mfa_required'); return;
    }
    /* FIX 3: Apply role-based session timeout */
    if (window.spApplyRoleTimeout) spApplyRoleTimeout(role);
  }
  /* FIX 1: Schedule silent token refresh */
  spScheduleRefresh(token);
  try {
    var cached = localStorage.getItem('sp_user');
    if (cached) { var u = JSON.parse(cached); if (u && u.name) applyNavProfile(u); }
  } catch(e){}
  setTimeout(loadNavProfile, 600);
  setTimeout(loadDashboardData, 900);
  setTimeout(loadProjectOptions, 1100);
})();

