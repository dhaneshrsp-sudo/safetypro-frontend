/* ═══════════════════════════════════════════════════════════════
   SMART PORTFOLIO — paginated by screen width, sorted by risk
   Any number of projects — Critical first, pagination auto-adjusts
   ═══════════════════════════════════════════════════════════════ */

var _portfolioAllProjects = [];  /* full list — no cap */
var _portfolioPage = 0;          /* current page */

/* Page size = responsive to screen width */
function spGetPortfolioPageSize() {
  var w = window.innerWidth || 1200;
  if (w >= 1400) return 8;   /* large screens: 4×2 */
  if (w >= 1024) return 6;   /* medium: 3×2 */
  if (w >= 768)  return 4;   /* tablet: 2×2 */
  return 2;                   /* mobile: 2×1 */
}

/* Risk sort weight — Critical first, then Medium, then Safe */
function spProjectRiskWeight(p) {
  var score = p.hseScore || p.safetyScore || 50;
  if (score < 50)  return 0;  /* Critical — show first */
  if (score < 75)  return 1;  /* Medium */
  return 2;                   /* Safe — show last */
}

function renderPortfolioCards(projects) {
  var grid = document.getElementById('portfolio-grid'); if (!grid) return;

  /* Sort: Critical → Medium → Safe, then by score ascending within each group */
  _portfolioAllProjects = projects.slice().sort(function(a, b) {
    var wa = spProjectRiskWeight(a), wb = spProjectRiskWeight(b);
    if (wa !== wb) return wa - wb;
    return (a.hseScore||0) - (b.hseScore||0);
  });
  _portfolioPage = 0;
  spRenderPortfolioPage();
}

function spRenderPortfolioPage() {
  var grid = document.getElementById('portfolio-grid'); if (!grid) return;
  var projects = _portfolioAllProjects;
  var total = projects.length;
  var pageSize = spGetPortfolioPageSize();
  var totalPages = Math.ceil(total / pageSize);
  var start = _portfolioPage * pageSize;
  var page  = projects.slice(start, start + pageSize);

  var riskConfig = {
    critical: { color:'#EF4444', bg:'rgba(239,68,68,.08)', border:'rgba(239,68,68,.22)', label:'🔴 Critical', tag:'AI Flagged' },
    medium:   { color:'#F59E0B', bg:'rgba(245,158,11,.08)', border:'rgba(245,158,11,.22)', label:'🟡 Medium',   tag:'Attention'  },
    safe:     { color:'#10B981', bg:'rgba(34,197,94,.06)',  border:'rgba(34,197,94,.18)',  label:'🟢 Safe',     tag:'On Track'   }
  };

  grid.innerHTML = '';
  page.forEach(function(p) {
    var risk  = p.riskLevel || (p.hseScore < 50 ? 'critical' : p.hseScore < 75 ? 'medium' : 'safe');
    var rc    = riskConfig[risk] || riskConfig.safe;
    var score = p.hseScore || p.safetyScore || 0;
    var card  = document.createElement('div');
    card.style.cssText = 'background:'+rc.bg+';border:1px solid '+rc.border+';border-radius:12px;padding:14px;cursor:pointer;transition:transform .2s,box-shadow .2s;';
    card.setAttribute('data-proj-id', p.id);
    card.setAttribute('data-sector', (p.sector||'').toLowerCase());
    card.setAttribute('data-risk', risk);
    card.addEventListener('mouseover', function(){ this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 16px rgba(0,0,0,.3)'; });
    card.addEventListener('mouseout',  function(){ this.style.transform='none'; this.style.boxShadow='none'; });
    /* Use onclick attribute — more reliable than addEventListener across scroll contexts */
    card.onclick = function(){ spDrillDownProject(p.id, p.name); };
    card.innerHTML =
      '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">' +
        '<div style="font-family:var(--fh);font-size:12px;font-weight:800;color:var(--t1);">' + (p.name||p.id) + '</div>' +
        '<span style="font-size:9px;font-weight:700;color:'+rc.color+';background:rgba(0,0,0,.2);padding:2px 7px;border-radius:10px;">' + rc.tag + '</span>' +
      '</div>' +
      '<div style="font-size:10px;color:var(--t3);margin-bottom:8px;">📍 ' + (p.location||p.sector||'') + '</div>' +
      '<div style="display:flex;justify-content:space-between;margin-bottom:8px;">' +
        '<div style="text-align:center;">' +
          '<div style="font-family:var(--fh);font-size:18px;font-weight:800;color:'+rc.color+';">' + score + '<span style="font-size:10px;">%</span></div>' +
          '<div style="font-size:9px;color:var(--t3);">HSE Score</div>' +
        '</div>' +
        '<div style="text-align:center;">' +
          '<div style="font-family:var(--fh);font-size:18px;font-weight:800;color:#EF4444;">' + (p.incidents||0) + '</div>' +
          '<div style="font-size:9px;color:var(--t3);">Incidents</div>' +
        '</div>' +
        '<div style="text-align:center;">' +
          '<div style="font-family:var(--fh);font-size:18px;font-weight:800;color:#F59E0B;">' + (p.overdue||0) + '</div>' +
          '<div style="font-size:9px;color:var(--t3);">Overdue</div>' +
        '</div>' +
      '</div>' +
      '<div style="height:3px;background:var(--border);border-radius:2px;overflow:hidden;">' +
        '<div style="height:100%;width:'+score+'%;background:'+rc.color+';border-radius:2px;transition:width 1s;"></div>' +
      '</div>' +
      '<div style="display:flex;justify-content:space-between;margin-top:8px;">' +
        '<div style="font-size:9px;font-weight:700;color:'+rc.color+';">' + rc.label + '</div>' +
        '<div style="font-size:9px;color:#3B82F6;font-weight:700;">Investigate →</div>' +
      '</div>';
    grid.appendChild(card);
  });

  /* Update pagination controls */
  var prevBtn  = document.getElementById('portfolio-prev');
  var nextBtn  = document.getElementById('portfolio-next');
  var pageInfo = document.getElementById('portfolio-page-info');
  var sub      = document.getElementById('portfolio-sub');

  if (total <= pageSize) {
    /* No pagination needed */
    if (prevBtn) prevBtn.style.display = 'none';
    if (nextBtn) nextBtn.style.display = 'none';
    if (pageInfo) pageInfo.textContent = '';
    if (sub) sub.textContent = total + ' projects · sorted by risk · click to drill down';
  } else {
    /* Show pagination */
    if (prevBtn) { prevBtn.style.display = _portfolioPage > 0 ? 'inline-block' : 'none'; }
    if (nextBtn) { nextBtn.style.display = _portfolioPage < totalPages-1 ? 'inline-block' : 'none'; }
    if (pageInfo) pageInfo.textContent = 'Page ' + (_portfolioPage+1) + ' of ' + totalPages + ' (' + total + ' projects)';
    if (sub) sub.textContent = 'Showing ' + (start+1) + '–' + Math.min(start+_portfolioPageSize, total) + ' of ' + total + ' · sorted by risk · click to drill down';
  }

  /* Critical count badge */
  var critical = _portfolioAllProjects.filter(function(p){ return spProjectRiskWeight(p) === 0; }).length;
  if (critical > 0) {
    var title = document.querySelector('[onclick*="spTogglePortfolioMode"]')?.closest('.g-card')?.querySelector('.card-title');
    /* Update command center critical counter if present */
    var rc2 = document.getElementById('rc-critical');
    if (rc2 && critical > 0) animateNum(rc2, critical);
  }
}

function spPortfolioPage(dir) {
  var total = _portfolioAllProjects.length;
  var pageSize = spGetPortfolioPageSize();
  var totalPages = Math.ceil(total / pageSize);
  _portfolioPage = Math.max(0, Math.min(totalPages-1, _portfolioPage + dir));
  spCloseDrilldown(); /* close any open drill-down when changing page */
  spRenderPortfolioPage();
  /* Scroll to portfolio */
  document.getElementById('portfolio-grid')?.closest('.g-card')?.scrollIntoView({behavior:'smooth', block:'start'});
}

