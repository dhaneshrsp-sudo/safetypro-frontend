      '</div>' +
      '<div style="height:4px;background:var(--border);border-radius:2px;overflow:hidden;">' +
        '<div style="height:100%;border-radius:2px;background:' + color + ';width:' + c.pct + '%;transition:width 1s ease;"></div>' +
