      (u.overdue > 2 ? '<div style="font-size:9px;background:rgba(239,68,68,.08);color:#EF4444;border:1px solid rgba(239,68,68,.2);border-radius:4px;padding:2px 7px;display:inline-block;margin-top:4px;font-family:var(--fh);font-weight:600;">⚠ Needs Attention</div>' : '');

