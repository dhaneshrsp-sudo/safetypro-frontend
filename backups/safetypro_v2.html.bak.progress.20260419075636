  }
  cont.innerHTML = summary + breakdown;
}

/* Patch chart to enable click drill-down after Chart.js renders */
(function patchChartClick() {
  var tries = 0;
  var iv = setInterval(function() {
    if (++tries > 30) { clearInterval(iv); return; }
    var canvas = document.getElementById('chart');
    if (!canvas || !window.chartInstance || canvas._drillPatched) return;
    clearInterval(iv);
    canvas._drillPatched = true;
    canvas.style.cursor = 'pointer';
    canvas.addEventListener('click', function(e) {
      if (!window.chartInstance) return;
      var pts = window.chartInstance.getElementsAtEventForMode(e, 'nearest', { intersect:true }, true);
      if (!pts.length) return;
      var pt = pts[0];
      var lbl = window.chartInstance.data.labels[pt.index];
      var ds  = window.chartInstance.data.datasets[pt.datasetIndex];
      spChartDrillDown(lbl, ds.label, ds.data[pt.index]);
    });
    /* Update hint */
    var hint = document.getElementById('chart-drilldown-hint');
    if (hint) hint.textContent = '↑ Click any data point to drill down';
  }, 500);
})();

