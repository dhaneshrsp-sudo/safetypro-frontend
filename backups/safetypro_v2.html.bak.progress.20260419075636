/* FIX 1: Chart drill-down */
function spChartDrillDown(label, datasetLabel, value) {
  var panel = document.getElementById('chart-drilldown-panel');
  var title = document.getElementById('drilldown-title');
  var cont  = document.getElementById('drilldown-content');
  if (!panel || !title || !cont) return;
  title.textContent = (datasetLabel || 'Data') + ' — ' + label;
  var type = (datasetLabel||'').toLowerCase().includes('incident') ? 'incidents' :
             (datasetLabel||'').toLowerCase().includes('ncr') ? 'ncrs' : 'actions';
  var token = localStorage.getItem('sp_token');
  spFetch(API_BASE + '/' + type + '?month=' + encodeURIComponent(label) + '&limit=4', {
    headers:{ 'Authorization': 'Bearer ' + (token||'') }
  }).then(function(r){ return r.ok ? r.json() : null; })
  .then(function(data){
    spRenderDrilldown(cont, type, label, value, data);
  }).catch(function(){ spRenderDrilldown(cont, type, label, value, null); });
  panel.style.display = 'block';
  panel.scrollIntoView({ behavior:'smooth', block:'nearest' });
}

function spRenderDrilldown(cont, type, label, value, data) {
  var cols = { incidents:'#EF4444', ncrs:'#F59E0B', actions:'#10B981' };
  var col = cols[type] || '#3B82F6';
  var items = (data && (Array.isArray(data) ? data : data.data || [])) || [];
  var summary = '<div style="background:var(--card);border:1px solid var(--border);border-radius:8px;padding:10px 14px;">' +
    '<div style="font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;">' + type.toUpperCase() + ' · ' + label + '</div>' +
    '<div style="font-family:var(--fh);font-size:24px;font-weight:800;color:' + col + ';">' + value + '</div>' +
    '<div style="font-size:10px;color:var(--t3);">Total recorded</div>' +
  '</div>';
  var breakdown;
  if (!items.length) {
    breakdown = [
      { label:'Critical / High', count: Math.round(value * 0.3), col:'#EF4444' },
      { label:'Medium',          count: Math.round(value * 0.4), col:'#F59E0B' },
