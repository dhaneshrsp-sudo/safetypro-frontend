      /* ENGAGEMENT 30% */
      '<div style="font-size:9px;font-weight:700;color:#3B82F6;text-transform:uppercase;letter-spacing:.4px;margin:6px 0 4px;">Engagement — 30%</div>' +
      spAccBar('NCRs Raised',     ncrRate,     15, '#3B82F6') +
