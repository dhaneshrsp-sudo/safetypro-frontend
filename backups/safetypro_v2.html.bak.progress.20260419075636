/* Portfolio filter */
function spFilterPortfolio(filters) {
  /* Only filter if there is actually an active filter value */
  var hasFilter = (filters.sector || filters.risk);
  if (!hasFilter) {
    /* No filter — show all cards */
    document.querySelectorAll('#portfolio-grid > div').forEach(function(c){ c.style.display = ''; });
    return;
  }
  var cards = document.querySelectorAll('#portfolio-grid > div');
  if (!cards.length) return;
  cards.forEach(function(card) {
    var show = true;
    if (filters.sector && card.dataset.sector && card.dataset.sector !== filters.sector) show = false;
    if (filters.risk && card.dataset.risk && card.dataset.risk !== filters.risk) show = false;
    card.style.display = show ? '' : 'none';
  });
}

/* Global search */
var _searchTimer = null;
function spGlobalSearch(query) {
  clearTimeout(_searchTimer);
  if (!query || query.length < 2) return;
  _searchTimer = setTimeout(function() {
    var token = localStorage.getItem('sp_token'); if (!token) return;
    spFetch(API_BASE + '/search?q=' + encodeURIComponent(query) + '&limit=5', {
      headers:{ 'Authorization':'Bearer ' + token }
    }).then(function(r){ return r.ok ? r.json() : null; })
    .then(function(data){
      if (!data || !data.results) return;
      showDashToast('Found ' + data.results.length + ' results for "' + query + '"', 'blue');
    }).catch(function(){
      showDashToast('Searching: ' + query, 'blue');
    });
  }, 400);
}

