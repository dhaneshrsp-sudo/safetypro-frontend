  }
  chartInstance = new Chart(ctx, {
    type:'line', data:{ labels:chartData.labels, datasets:sets },
    options:{
      responsive:true, maintainAspectRatio:false,
      interaction:{ intersect:false, mode:'index' },
      plugins:{
        legend:{ display:sets.length > 1, position:'top', labels:{ color:'#7A9BBF', font:{ family:'Inter', size:10, weight:'600' }, boxWidth:10, padding:14 } },
        tooltip:{ backgroundColor:'#0C1824', borderColor:'#162236', borderWidth:1, titleColor:'#EBF4FF', bodyColor:'#7A9BBF', titleFont:{ family:'Inter', weight:'700', size:11 }, bodyFont:{ family:'Roboto', size:11 }, padding:10, cornerRadius:8 }
      },
