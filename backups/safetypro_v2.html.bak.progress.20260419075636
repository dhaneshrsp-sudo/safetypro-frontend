        x:{ grid:{ color:'rgba(255,255,255,0.03)' }, ticks:{ color:'#2E4A66', font:{ family:'Inter', size:9 } } },
        y:{ grid:{ color:'rgba(255,255,255,0.03)' }, ticks:{ color:'#2E4A66', font:{ family:'Inter', size:9 } }, beginAtZero:true }
