function spPopulateCompareCheckboxes() {
  var box = document.getElementById('compare-checkboxes'); if (!box) return;
  var allProjects = (_portfolioAllProjects && _portfolioAllProjects.length)
    ? _portfolioAllProjects
    : Object.values(window._ddProjectsMap || {});
  var total = allProjects.length;
  box.innerHTML = '';

  if (total === 0) return;

  if (total <= 20) {
    /* ≤ 20 projects: show all as checkboxes */
    allProjects.forEach(function(p) {
      var riskColor = p.hseScore >= 80 ? '#10B981' : p.hseScore >= 60 ? '#F59E0B' : '#EF4444';
      var cb = document.createElement('label');
      cb.style.cssText = 'display:flex;align-items:center;gap:4px;cursor:pointer;background:var(--elevated);border:1px solid var(--border);border-radius:5px;padding:3px 8px;font-size:10px;color:var(--t2);user-select:none;transition:.1s;';
      cb.innerHTML =
        '<input type="checkbox" id="cmp-cb-'+p.id+'" value="'+p.id+'" checked ' +
        'style="accent-color:var(--green);cursor:pointer;" ' +
        'onchange="spUpdateCompareBadge(this)">' +
        '<span style="color:'+riskColor+';font-weight:700;">●</span>' +
        '<span style="font-family:var(--fh);font-weight:600;">' + (p.name||p.id) + '</span>';
      box.appendChild(cb);
    });
  } else {
    /* > 20 projects: show search + multi-select dropdown */
    box.innerHTML =
      '<div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">' +
        '<input id="cmp-search" type="text" placeholder="Search projects..." ' +
        'style="background:var(--elevated);border:1px solid var(--border);border-radius:5px;color:var(--t2);font-family:var(--fh);font-size:10px;padding:3px 8px;outline:none;width:160px;" ' +
        'oninput="spFilterCompareList(this.value)">' +
        '<button onclick="spSelectAllCompare(true)" style="background:var(--elevated);border:1px solid var(--border);color:var(--green);font-family:var(--fh);font-size:9px;font-weight:700;padding:3px 8px;border-radius:5px;cursor:pointer;">All</button>' +
        '<button onclick="spSelectAllCompare(false)" style="background:var(--elevated);border:1px solid var(--border);color:var(--t3);font-family:var(--fh);font-size:9px;font-weight:700;padding:3px 8px;border-radius:5px;cursor:pointer;">None</button>' +
        '<button onclick="spSelectCriticalCompare()" style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);color:#EF4444;font-family:var(--fh);font-size:9px;font-weight:700;padding:3px 8px;border-radius:5px;cursor:pointer;">🔴 Critical only</button>' +
        '<span style="font-size:9px;color:var(--t3);" id="cmp-count">'+total+' projects</span>' +
      '</div>' +
      '<div id="cmp-list" style="display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;max-height:80px;overflow-y:auto;">' +
      allProjects.map(function(p){
        var rc = p.hseScore >= 80 ? '#10B981' : p.hseScore >= 60 ? '#F59E0B' : '#EF4444';
        return '<label style="display:flex;align-items:center;gap:3px;cursor:pointer;background:var(--elevated);border:1px solid var(--border);border-radius:4px;padding:2px 7px;font-size:9px;color:var(--t2);user-select:none;" data-risk="'+(p.hseScore<50?'critical':p.hseScore<75?'medium':'safe')+'">' +
          '<input type="checkbox" class="cmp-cb" id="cmp-cb-'+p.id+'" value="'+p.id+'" checked style="accent-color:var(--green);">' +
          '<span style="color:'+rc+';font-weight:700;font-size:8px;">●</span>' +
          '<span style="font-family:var(--fh);font-weight:600;">'+(p.name||p.id)+'</span>' +
        '</label>';
      }).join('') +
      '</div>';
  }
