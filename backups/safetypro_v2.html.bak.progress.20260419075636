<!-- WebSocket Real-Time Client -->
<script>
/* 
   SAFETYPRO AI  WebSocket Client
   Connects to backend, authenticates with JWT,
   listens for real-time events and updates UI instantly.
   
   PAGE: Dashboard
    */

/*  SOCKET.IO CDN is loaded before this script  */

var SP_SOCKET = null;
var SP_WS_URL = 'https://safetypro-backend.onrender.com';
var SP_RECONNECT_ATTEMPTS = 0;
var SP_MAX_RECONNECT = 3;
var SP_TOAST_FN = 'showDashToast';

/*  INIT: connect on page load  */
window.addEventListener('load', function() {
  setTimeout(spInitSocket, 1200); // slight delay  let auth guard run first
});

function spInitSocket() {
  var token = localStorage.getItem('sp_token');
  if (!token) return; // not logged in  skip

  /* Check socket.io is loaded */
  if (typeof io === 'undefined') {
    console.warn('[SafetyPro WS] socket.io not loaded  real-time disabled');
    return;
  }

  try {
    SP_SOCKET = io(SP_WS_URL, {
      auth: { token: token },
      transports: ['websocket', 'polling'],
      reconnection: true,
      reconnectionAttempts: SP_MAX_RECONNECT,
      reconnectionDelay: 2000,
      timeout: 10000,
    });

    spBindEvents();
  } catch(e) {
    console.warn('[SafetyPro WS] Connection failed:', e.message);
  }
}

/*  BIND ALL EVENTS  */
function spBindEvents() {
  if (!SP_SOCKET) return;

  /* Connection established */
  SP_SOCKET.on('connect', function() {
    SP_RECONNECT_ATTEMPTS = 0;
    console.log('[SafetyPro WS] Connected  real-time active');
    spUpdateConnectionStatus(true);
  });

  /* Connection lost */
  SP_SOCKET.on('disconnect', function(reason) {
    console.warn('[SafetyPro WS] Disconnected:', reason);
    spUpdateConnectionStatus(false);
  });

  /* Connection error */
  SP_SOCKET.on('connect_error', function(err) {
    SP_RECONNECT_ATTEMPTS++;
    console.warn('[SafetyPro WS] Connection error:', err.message);
    if (SP_RECONNECT_ATTEMPTS >= SP_MAX_RECONNECT) {
      console.warn('[SafetyPro WS] Max reconnects reached  falling back to HTTP polling');
      spStartFallbackPoll();
    }
  });

  /* Server confirmed connection */
  SP_SOCKET.on('connected', function(data) {
    console.log('[SafetyPro WS] Authenticated');
  });

  /*  KPIs UPDATED  */
  SP_SOCKET.on('kpis.updated', function(data) {
    /* FIX 6: Never log raw event data */ console.log('[SafetyPro WS] kpis.updated');
    spOnKpisUpdated(data);
  });

  /*  INCIDENT CREATED  */
  SP_SOCKET.on('incident.created', function(data) {
    spHashContent(JSON.stringify(data)).then(function(h){ console.log('[SafetyPro WS] incident.created hash:', h); });
    spOnIncidentCreated(data);
  });

  /*  NCR CREATED  */
  SP_SOCKET.on('ncr.created', function(data) {
    spHashContent(JSON.stringify(data)).then(function(h){ console.log('[SafetyPro WS] ncr.created hash:', h); });
    spOnNcrCreated(data);
  });

  /*  ACTION UPDATED  */
  SP_SOCKET.on('action.updated', function(data) {
    console.log('[SafetyPro WS] action.updated');
    spOnActionUpdated(data);
  });

  /*  ESCALATION TRIGGERED  */
  SP_SOCKET.on('escalation.triggered', function(data) {
    console.log('[SafetyPro WS] escalation.triggered');
    spOnEscalationTriggered(data);
  });

  /*  USER ACTIVITY  */
  SP_SOCKET.on('user.activity', function(data) {
    console.log('[SafetyPro WS] user.activity');
    spOnUserActivity(data);
  });

  /*  ERROR  */
  SP_SOCKET.on('error', function(err) {
    console.warn('[SafetyPro WS] Error:', err.message);
    if (err.message === 'Invalid token' || err.message === 'Authentication required') {
      localStorage.removeItem('sp_token');
      window.location.href = 'safetypro_login';
    }
  });
}

/*  CONNECTION STATUS INDICATOR  */
function spUpdateConnectionStatus(connected) {
  /* Update alert dot color subtly  green pulse = live */
  var dot = document.getElementById('alert-dot');
  if (!dot) return;
  if (connected) {
    dot.style.background = '#10B981';
    dot.style.display = 'block';
    setTimeout(function(){ dot.style.background = ''; dot.style.display = ''; }, 2000);
  }
}

/*  ANIMATE NUMBER HELPER  */
function spAnimateNum(el, target) {
  if (!el) return;
  if (typeof animateNum === 'function') { animateNum(el, target); return; }
  var dur = 800; var t0 = performance.now();
  var isFloat = String(target).indexOf('.') > -1;
  function step(now) {
    var p = Math.min((now - t0) / dur, 1);
    var ease = 1 - Math.pow(1 - p, 3);
    el.textContent = isFloat ? (target * ease).toFixed(1) : Math.round(target * ease);
    if (p < 1) requestAnimationFrame(step);
    else el.textContent = isFloat ? parseFloat(target).toFixed(1) : Math.round(target);
  }
  requestAnimationFrame(step);
}

/*  SHOW TOAST HELPER  */
function spToast(msg, type) {
  if (typeof showDashToast === 'function') { showDashToast(msg, type || 'green'); return; }
  if (typeof showToast === 'function') { showToast(msg, type || 'green'); return; }
}

/*  FORMAT TIME  */
function spTimeAgo(isoString) {
  var now = new Date();
  var then = new Date(isoString);
  var diff = Math.floor((now - then) / 1000);
  if (diff < 60) return 'Just now';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  return Math.floor(diff / 3600) + 'h ago';
}

/*  INITIALS FROM NAME  */
function spInitials(name) {
  if (!name) return '??';
  var parts = name.trim().split(' ');
  return parts.length > 1 
    ? (parts[0][0] + parts[parts.length-1][0]).toUpperCase()
    : name.substring(0, 2).toUpperCase();
}

/*  SEVERITY COLOR  */
function spSeverityColor(severity) {
  var map = { CRITICAL: '#EF4444', HIGH: '#F97316', MEDIUM: '#F59E0B', LOW: '#10B981' };
  return map[(severity||'').toUpperCase()] || '#3B82F6';
}

/* 
   EVENT HANDLERS  page-specific logic below
    */


function spOnKpisUpdated(data) {
  /* Refresh all KPI counters from backend */
  if (typeof loadDashboardData === 'function') {
    loadDashboardData();
  }
  /* If kpi data comes with the event, update immediately */
  var k = data.kpis || {};
  if (k.safeActions !== undefined) spAnimateNum(document.getElementById('kn1'), k.safeActions);
  if (k.pending !== undefined) spAnimateNum(document.getElementById('kn2'), k.pending);
  if (k.escalated !== undefined) {
    spAnimateNum(document.getElementById('kn3'), k.escalated);
    var dot = document.getElementById('alert-dot');
    if (dot && k.escalated > 0) dot.style.display = 'block';
  }
}

function spOnIncidentCreated(data) {
  var inc = data.incident || {};
  /* Add to Recent Activity grid */
  spAddToActivityFeed({
    initials: spInitials(inc.reportedBy),
    color: spSeverityColor(inc.severity),
    title: inc.description || 'New Incident Reported',
    badge: 'Incident',
    badgeClass: 'ab-r',
    site: inc.projectName || '',
    time: spTimeAgo(data.timestamp),
    person: inc.reportedBy || '',
  });
  /* Pulse alert bell */
  spPulseAlertBell();
  /* Toast */
  spToast('New incident: ' + (inc.description || '').substring(0, 40), 'red');
  /* Refresh KPIs */
  spOnKpisUpdated(data);
}

function spOnNcrCreated(data) {
  var ncr = data.ncr || {};
  spAddToActivityFeed({
    initials: spInitials(ncr.assignedTo),
    color: '#F59E0B',
    title: ncr.description || 'New NCR Logged',
    badge: 'NCR',
    badgeClass: 'ab-a',
    site: ncr.projectName || '',
    time: spTimeAgo(data.timestamp),
    person: ncr.assignedTo || '',
  });
  spToast('New NCR: ' + (ncr.description || '').substring(0, 40), 'amber');
  spOnKpisUpdated(data);
}

function spOnActionUpdated(data) {
  var action = data.action || {};
  spOnKpisUpdated(data);
  if (action.status === 'OVERDUE') {
    spToast('Action overdue: ' + (action.title || '').substring(0, 40), 'red');
  }
}

function spOnEscalationTriggered(data) {
  var esc = data.escalation || {};
  /* Update escalated KPI counter */
  var kn3 = document.getElementById('kn3');
  if (kn3) {
    var current = parseInt(kn3.textContent) || 0;
    spAnimateNum(kn3, current + 1);
  }
  /* Update rc-crit counter */
  var rcCrit = document.getElementById('rc-crit');
  if (rcCrit) {
    var c2 = parseInt(rcCrit.textContent) || 0;
    spAnimateNum(rcCrit, c2 + 1);
  }
  /* Add to Live Risk Panel */
  spAddToRiskPanel(esc);
  /* Pulse alert bell */
  spPulseAlertBell();
  /* Add to activity feed */
  spAddToActivityFeed({
    initials: spInitials(esc.assigneeName),
    color: '#EF4444',
    title: 'L' + esc.level + ' Escalation: ' + (esc.actionTitle || '').substring(0, 35),
    badge: 'L' + esc.level,
    badgeClass: 'ab-r',
    site: esc.projectName || '',
    time: spTimeAgo(data.timestamp),
    person: esc.assigneeName || '',
  });
  /* Toast */
  spToast('Escalation L' + esc.level + ': ' + (esc.actionTitle || '').substring(0, 35), 'red');
}

function spOnUserActivity(data) {
  var act = data.activity || {};
  /* Only add if not current user's own action (avoid duplicates) */
  try {
    var me = JSON.parse(localStorage.getItem('sp_user') || '{}');
    if (me.name === act.userName) return; /* skip own actions */
  } catch(e) {}
  spAddToActivityFeed({
    initials: spInitials(act.userName),
    color: '#3B82F6',
    title: act.description || act.action || 'Activity recorded',
    badge: act.entityType || 'Action',
    badgeClass: 'ab-b',
    site: act.projectName || '',
    time: spTimeAgo(data.timestamp),
    person: act.userName || '',
  });
}

/*  DASHBOARD HELPERS  */
function spAddToActivityFeed(item) {
  var grid = document.querySelector('.act-grid');
  if (!grid) return;
  var html = '<div class="act-item" style="animation:fadeIn .3s ease">' +
    '<div class="act-av" style="background:linear-gradient(135deg,' + item.color + ',' + item.color + 'cc)">' + item.initials + '</div>' +
    '<div class="act-body">' +
    '<div class="act-title">' + item.title + '</div>' +
    '<div class="act-meta"><span class="act-badge ' + item.badgeClass + '">' + item.badge + '</span>' +
    '<span class="act-site">' + item.site + '</span></div>' +
    '<div class="act-time">' + item.time + ' &bull; ' + item.person + '</div>' +
    '</div></div>';
  /* Prepend new item, remove last if more than 4 */
  grid.insertAdjacentHTML('afterbegin', html);
  var items = grid.querySelectorAll('.act-item');
  if (items.length > 4) items[items.length - 1].remove();
}

function spAddToRiskPanel(esc) {
  var list = document.querySelector('.risk-list');
  if (!list) return;
  var html = '<div class="risk-item crit" style="animation:fadeIn .3s ease">' +
    '<div class="risk-dot"></div>' +
    '<div class="risk-body">' +
    '<div class="risk-title">' + (esc.assigneeName || 'Unknown') + '  L' + esc.level + ' Escalation</div>' +
    '<div class="risk-meta">' + esc.daysOverdue + ' days overdue &bull; ' + (esc.projectName || '') + '</div>' +
    '</div>' +
    '<div class="risk-badge rb-r">L' + esc.level + '</div>' +
    '</div>';
  list.insertAdjacentHTML('afterbegin', html);
  var items = list.querySelectorAll('.risk-item');
  if (items.length > 5) items[items.length - 1].remove();
}

function spPulseAlertBell() {
  var dot = document.getElementById('alert-dot');
  if (!dot) return;
  dot.style.display = 'block';
  /* Flash animation */
  dot.style.transform = 'scale(1.5)';
  setTimeout(function(){ dot.style.transform = ''; }, 300);
  /* Reload alert list if open */
  var alertDd = document.getElementById('alert-dropdown');
  if (alertDd && alertDd.style.display === 'block') {
    if (typeof loadAlerts === 'function') loadAlerts();
  }
}


/*  FALLBACK: HTTP POLL every 30s if WebSocket fails  */
var spPollTimer = null;
function spStartFallbackPoll() {
  if (spPollTimer) return; // already polling
  console.log('[SafetyPro WS] Starting 30s HTTP fallback poll');
  spPollTimer = setInterval(function() {
    if (typeof loadDashboardData === 'function') loadDashboardData();
    else if (typeof loadOpsData === 'function') loadOpsData();
    else if (typeof loadControlData === 'function') loadControlData();
    else if (typeof loadReportsData === 'function') loadReportsData();
  }, 30000);
}

/*  CLEANUP on page unload  */
window.addEventListener('beforeunload', function() {
  if (SP_SOCKET) { SP_SOCKET.disconnect(); SP_SOCKET = null; }
  if (spPollTimer) { clearInterval(spPollTimer); spPollTimer = null; }
});

</script>
