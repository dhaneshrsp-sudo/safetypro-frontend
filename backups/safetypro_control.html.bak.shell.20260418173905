<!DOCTYPE html>
<html lang="en">
<head>
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SafetyPro . AI — Control</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Roboto:wght@300;400;500;600&family=Fraunces:wght@400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#0B0F14;--card:#131C26;--raised:#16212B;--sidebar:#0F1720;--border:#1E293B;--div:rgba(255,255,255,0.05);
  --green:#22C55E;--g-h:#16A34A;--g-s:rgba(34,197,94,0.12);--g-b:rgba(34,197,94,0.3);
  --amber:#F59E0B;--a-s:rgba(245,158,11,0.12);--a-b:rgba(245,158,11,0.3);
  --red:#EF4444;--r-s:rgba(239,68,68,0.12);--r-b:rgba(239,68,68,0.35);
  --blue:#3B82F6;--b-s:rgba(59,130,246,0.12);--b-b:rgba(59,130,246,0.3);
  --purple:#8B5CF6;--p-s:rgba(139,92,246,0.12);--p-b:rgba(139,92,246,0.3);
  --t1:#E6EDF3;--t2:#94A3B8;--t3:#64748B;
  --fh:'Montserrat',sans-serif;--fb:'Roboto',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{margin:0;padding:0}
body{background:var(--bg);color:var(--t1);font-family:var(--fb);font-size:13px;line-height:1.5;min-height:100vh}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
svg{flex-shrink:0}
.app{display:flex;flex-direction:column;min-height:100vh}

/* ── TOP NAV ── */
.topnav{height:52px;flex-shrink:0;background:var(--sidebar);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 0 0 0;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:8px;text-decoration:none;width:195px;flex-shrink:0;padding:0 16px 0 18px;border-right:1px solid var(--border)}
.logo-mark{width:28px;height:28px;background:var(--green);border-radius:6px;display:flex;align-items:center;justify-content:center;box-shadow:0 0 10px rgba(34,197,94,.4)}
.logo-mark svg{width:16px;height:16px;fill:#fff}
.logo-text{font-family:var(--fh);font-size:15px;font-weight:800;color:var(--t1);letter-spacing:-.3px;}
.logo-text span{color:var(--green)}
.nl{display:flex;align-items:center;gap:6px;padding:6px 13px;border-radius:7px;font-size:13px;color:var(--t2);cursor:pointer;transition:all .15s;text-decoration:none}
.nl:hover{color:var(--t1);background:rgba(255,255,255,.04)}
.nl.active{color:var(--t1);font-weight:600}
.nl svg{width:13px;height:13px;fill:currentColor}
.nl .arr{font-size:9px;opacity:.5;margin-left:2px}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:8px;padding-right:20px}
.icon-btn{width:30px;height:30px;border-radius:7px;border:1px solid var(--border);background:var(--card);display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;transition:border-color .15s}
.icon-btn:hover{border-color:var(--t3)}
.icon-btn svg{width:14px;height:14px;fill:var(--t2)}
.ndot{position:absolute;top:4px;right:4px;width:6px;height:6px;background:var(--red);border-radius:50%;border:1px solid var(--bg)}
.user-pill{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:5px 10px 5px 5px;cursor:pointer}
.ua{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#22C55E,#16A34A);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff}
.un-name{font-size:11px;font-weight:600;color:var(--t1);line-height:1.2}
.un-role{font-size:9px;color:var(--t3)}

/* ── BODY ── */
.body{display:flex;flex:1}

/* ── SIDEBAR ── */
.sidebar{width:195px;flex-shrink:0;background:var(--sidebar);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:14px 8px;min-height:calc(100vh - 52px);position:sticky;top:52px;align-self:flex-start}
.sb-item{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;color:var(--t3);cursor:pointer;transition:all .15s;font-size:13px;margin-bottom:2px;text-decoration:none}
.sb-item:hover{background:rgba(255,255,255,.04);color:var(--t2)}
.sb-item.active{background:rgba(34,197,94,.1);border-left:2px solid var(--green);color:var(--green);padding-left:8px}
.sb-item svg{width:15px;height:15px;fill:currentColor;opacity:.7}
.sb-item.active svg{opacity:1}
.sb-badge{margin-left:auto;font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px}
.sb-badge.red{background:var(--red);color:#fff}
.sb-badge.amber{background:var(--amber);color:#0B0E12}
.sidebar-foot{margin-top:auto;padding-top:10px;border-top:1px solid var(--border)}

/* ── CONTENT ── */
.content{flex:1;min-width:0;min-height:0;display:flex;flex-direction:column;}

/* ── SUB HEADER ── */
.sub-header{padding:0 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--bg);position:sticky;top:52px;z-index:50;flex-wrap:nowrap;height:52px;gap:12px;}
.sh-left{display:flex;align-items:center;gap:12px}
.sh-title{font-family:var(--fh);font-size:16px;font-weight:700}
.sh-tabs{display:flex;gap:2px;overflow-x:auto;overflow-y:hidden;flex-wrap:nowrap;scrollbar-width:none;}
.sh-tab{padding:5px 14px;border-radius:6px;font-size:12px;color:var(--t3);cursor:pointer;transition:all .15s;border:1px solid transparent;white-space:nowrap;flex-shrink:0;}
.sh-tab:hover{color:var(--t2)}
.sh-tab.active{background:var(--card);border-color:var(--border);color:var(--t1);font-weight:500}
.sh-right{display:flex;gap:8px;align-items:center}
.sel{background:var(--card);border:1px solid var(--border);color:var(--t1);padding:6px 12px;border-radius:7px;font-family:var(--fb);font-size:12px;outline:none;cursor:pointer}

/* ── MAIN AREA ── */
.main{padding:16px 20px;display:flex;flex-direction:column;gap:14px;padding-bottom:80px;overflow-y:auto;min-width:0;flex:1;min-height:0;scroll-padding-top:52px;}

/* ── STAT CARDS ── */
.ctrl-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.cs-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px 18px;position:relative;overflow:hidden;cursor:pointer;transition:all .2s}
.cs-card:hover{transform:translateY(-2px)}
.cs-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:12px 12px 0 0}
.cs-card.red{border-color:rgba(239,68,68,.3)}.cs-card.red::before{background:var(--red);box-shadow:0 0 16px rgba(239,68,68,.6)}
.cs-card.amber{border-color:rgba(245,158,11,.3)}.cs-card.amber::before{background:var(--amber);box-shadow:0 0 16px rgba(245,158,11,.6)}
.cs-card.green{border-color:rgba(34,197,94,.3)}.cs-card.green::before{background:var(--green);box-shadow:0 0 16px rgba(34,197,94,.6)}
.cs-card.blue{border-color:rgba(59,130,246,.3)}.cs-card.blue::before{background:var(--blue);box-shadow:0 0 16px rgba(59,130,246,.6)}
.cs-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.cs-icon{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center}
.cs-icon svg{width:14px;height:14px}
.cs-icon.r{background:var(--r-s);border:1px solid var(--r-b)}.cs-icon.r svg{fill:var(--red)}
.cs-icon.a{background:var(--a-s);border:1px solid var(--a-b)}.cs-icon.a svg{fill:var(--amber)}
.cs-icon.g{background:var(--g-s);border:1px solid var(--g-b)}.cs-icon.g svg{fill:var(--green)}
.cs-icon.b{background:var(--b-s);border:1px solid var(--b-b)}.cs-icon.b svg{fill:var(--blue)}
.cs-trend{font-size:10px;font-weight:600;padding:2px 6px;border-radius:4px}
.cs-trend.up{background:var(--r-s);color:var(--red)}.cs-trend.down{background:var(--g-s);color:var(--green)}.cs-trend.warn{background:var(--a-s);color:var(--amber)}
.cs-num{font-family:var(--fh);font-size:32px;font-weight:800;letter-spacing:-1px;line-height:1}
.cs-card.red .cs-num{color:var(--red)}.cs-card.amber .cs-num{color:var(--amber)}.cs-card.green .cs-num{color:var(--green)}.cs-card.blue .cs-num{color:var(--blue)}
.cs-label{font-size:11px;color:var(--t2);margin-top:4px}
.cs-sub{font-size:10px;color:var(--t3);margin-top:1px}

/* ── CARD BASE ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden}
.card-head{display:flex;align-items:center;justify-content:space-between;padding:13px 16px;border-bottom:1px solid var(--div)}
.card-title{font-family:var(--fh);font-size:13px;font-weight:700;color:var(--t1)}
.card-sub{font-size:10px;color:var(--t3);margin-top:1px}
.cbtn{font-size:10px;padding:4px 10px;border-radius:5px;border:1px solid var(--border);color:var(--t3);background:var(--raised);cursor:pointer;transition:all .15s;font-family:var(--fb)}
.cbtn:hover{color:var(--t2)}.cbtn.on{background:var(--g-s);border-color:var(--g-b);color:var(--green)}
.cbtn.red-on{background:var(--r-s);border-color:var(--r-b);color:var(--red)}

/* ── ESCALATION TABLE ── */
.esc-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,300px);gap:14px;align-items:start}

.lvl-map{padding:10px 14px;display:flex;gap:6px;align-items:center;border-bottom:1px solid var(--div);flex-wrap:wrap}
.lvl-pill{display:flex;align-items:center;gap:5px;padding:3px 10px;border-radius:100px;font-size:10px;font-weight:700;cursor:pointer;transition:all .15s;border:1px solid var(--border);color:var(--t3)}
.lvl-pill:hover{border-color:var(--t2)}
.lvl-pill.l1{border-color:var(--a-b);color:var(--amber);background:var(--a-s)}
.lvl-pill.l2{border-color:rgba(249,115,22,.3);color:#F97316;background:rgba(249,115,22,.1)}
.lvl-pill.l3{border-color:var(--r-b);color:var(--red);background:var(--r-s)}
.lvl-pill.l4{border-color:rgba(220,38,38,.4);color:#DC2626;background:rgba(220,38,38,.12)}
.lvl-pill.l5{border-color:rgba(127,29,29,.5);color:#B91C1C;background:rgba(127,29,29,.15)}
.lvl-dot{width:6px;height:6px;border-radius:50%;background:currentColor}

.esc-table-wrap{overflow-x:auto}
.etbl{width:100%;min-width:580px;border-collapse:collapse}
.etbl th{padding:8px 14px;text-align:left;font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.6px;border-bottom:1px solid var(--border);background:rgba(255,255,255,.015)}
.etbl td{padding:11px 14px;border-bottom:1px solid var(--div);vertical-align:middle}
.etbl tr:last-child td{border-bottom:none}
.etbl tr{cursor:pointer;transition:background .12s}
.etbl tr:hover td{background:rgba(255,255,255,.02)}

.person-cell{display:flex;align-items:center;gap:8px}
.av{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0}
.p-name{font-size:12px;font-weight:600;color:var(--t1)}
.p-role{font-size:10px;color:var(--t3)}

.lvl-badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px}
.lv1{background:var(--a-s);color:var(--amber);border:1px solid var(--a-b)}
.lv2{background:rgba(249,115,22,.1);color:#F97316;border:1px solid rgba(249,115,22,.3)}
.lv3{background:var(--r-s);color:var(--red);border:1px solid var(--r-b);animation:pulse-badge 2s ease-in-out infinite}
.lv4{background:rgba(220,38,38,.12);color:#DC2626;border:1px solid rgba(220,38,38,.4)}
.lv5{background:rgba(127,29,29,.15);color:#B91C1C;border:1px solid rgba(127,29,29,.5)}
@keyframes pulse-badge{0%,100%{box-shadow:0 0 0 rgba(239,68,68,0)}50%{box-shadow:0 0 8px rgba(239,68,68,.4)}}

.days-cell{display:flex;align-items:center;gap:5px;font-size:11px}
.days-cell.crit{color:var(--red);font-weight:700}
.days-cell.high{color:#F97316;font-weight:600}
.days-cell.med{color:var(--amber)}
.days-cell.low{color:var(--t2)}

.action-cell{display:flex;gap:5px}
.act-icon{width:24px;height:24px;border-radius:5px;background:var(--raised);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s}
.act-icon:hover{border-color:var(--green);background:var(--g-s)}
.act-icon svg{width:11px;height:11px;fill:var(--t3)}
.act-icon:hover svg{fill:var(--green)}

.src-tag{display:inline-flex;align-items:center;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px}
.src-i{background:var(--r-s);color:var(--red);border:1px solid var(--r-b)}
.src-n{background:var(--a-s);color:var(--amber);border:1px solid var(--a-b)}
.src-au{background:var(--p-s);color:var(--purple);border:1px solid var(--p-b)}

/* ── ESCALATION CHAIN ── */
.chain-card{display:flex;flex-direction:column;gap:0}
.chain-head{padding:12px 14px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--div)}
.chain-title{font-size:12px;font-weight:700;color:var(--t1)}
.chain-sub{font-size:10px;color:var(--t3);margin-top:1px}

.chain-steps{padding:12px 14px;display:flex;flex-direction:column;gap:0}
.chain-step{display:flex;align-items:flex-start;gap:10px;position:relative;padding-bottom:16px}
.chain-step:last-child{padding-bottom:0}
.chain-step:not(:last-child)::after{content:'';position:absolute;left:13px;top:28px;bottom:0;width:1px;background:var(--border)}
.cs-circle{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0;z-index:1}
.cs-circle.fired{background:var(--red);color:#fff;box-shadow:0 0 8px rgba(239,68,68,.5)}
.cs-circle.active{background:var(--amber);color:#0B0E12;box-shadow:0 0 8px rgba(245,158,11,.4);animation:pulse-amber 2s ease-in-out infinite}
@keyframes pulse-amber{0%,100%{box-shadow:0 0 4px rgba(245,158,11,.4)}50%{box-shadow:0 0 14px rgba(245,158,11,.6)}}
.cs-circle.pending{background:var(--raised);border:1px solid var(--border);color:var(--t3)}
.cs-circle.ceo{background:linear-gradient(135deg,#7C3AED,#6D28D9);color:#fff}
.cs-body{flex:1}
.cs-role{font-size:11px;font-weight:600;color:var(--t1)}
.cs-person{font-size:10px;color:var(--t3)}
.cs-time{font-size:9px;margin-top:2px}
.cs-time.fired{color:var(--red)}.cs-time.active{color:var(--amber)}.cs-time.pending{color:var(--t3)}

.chain-incident{margin:0 14px 12px;padding:10px 12px;background:var(--raised);border:1px solid var(--border);border-radius:8px}
.ci-title{font-size:12px;font-weight:600;color:var(--t1);margin-bottom:3px}
.ci-meta{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.ci-tag{font-size:9px;padding:2px 6px;border-radius:4px;font-weight:600}

/* ── OVERDUE TRACKER ── */
.od-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.od-filters{display:flex;gap:6px;padding:10px 14px;border-bottom:1px solid var(--div);flex-wrap:wrap}
.od-filter{padding:3px 10px;border-radius:100px;font-size:10px;border:1px solid var(--border);color:var(--t3);cursor:pointer;transition:all .15s}
.od-filter:hover{color:var(--t2)}.od-filter.on{background:var(--r-s);border-color:var(--r-b);color:var(--red)}

.od-list{display:flex;flex-direction:column;gap:0}
.od-item{display:flex;align-items:center;gap:10px;padding:11px 14px;border-bottom:1px solid var(--div);cursor:pointer;transition:background .12s;margin-bottom:4px;}
.od-item:last-child{border-bottom:none}
.od-item:hover{background:rgba(255,255,255,.02)}
.od-sev{width:4px;flex-shrink:0;border-radius:2px;align-self:stretch}
.od-body{flex:1;min-width:0}
.od-title{font-size:12px;font-weight:600;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.od-meta{display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap}
.od-right{display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0}
.od-days{font-family:var(--fh);font-size:13px;font-weight:800}
.od-days.d1{color:var(--amber)}.od-days.d3{color:#F97316}.od-days.d5{color:var(--red)}
.od-days-label{font-size:9px;color:var(--t3)}

/* ── DELAY CHART ── */
.delay-chart-wrap{padding:14px;height:180px}

/* ── ACCOUNTABILITY ── */
.acc-section{display:flex;flex-direction:column;gap:0}
.acc-item{display:flex;align-items:center;gap:10px;padding:11px 14px;border-bottom:1px solid var(--div);cursor:pointer;transition:background .12s}
.acc-item:hover{background:rgba(255,255,255,.02)}
.acc-item:last-child{border-bottom:none}
.acc-av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.acc-body{flex:1;min-width:0}
.acc-top-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:5px}
.acc-name{font-size:12px;font-weight:600;color:var(--t1)}
.acc-role{font-size:10px;color:var(--t3)}
.acc-bar-wrap{height:5px;background:var(--border);border-radius:3px;overflow:hidden;margin-bottom:3px}
.acc-bar{height:100%;border-radius:3px;transition:width .8s ease}
.acc-bar.excellent{background:var(--green);box-shadow:0 0 5px rgba(34,197,94,.4)}
.acc-bar.good{background:var(--blue)}
.acc-bar.warn{background:var(--amber)}
.acc-bar.poor{background:var(--red)}
.acc-stats{display:flex;gap:8px;align-items:center}
.acc-stat-item{font-size:10px;color:var(--t3)}
.acc-stat-item span{color:var(--t2);font-weight:600}
.acc-pct{font-size:14px;font-weight:800;min-width:42px;text-align:right;font-family:var(--fh)}
.grade-badge{font-size:9px;font-weight:400;padding:1px 5px;border-radius:3px;margin-left:4px}
.gr-a{background:var(--g-s);color:var(--green);border:1px solid var(--g-b)}
.gr-b{background:var(--b-s);color:var(--blue);border:1px solid var(--b-b)}
.gr-c{background:var(--a-s);color:var(--amber);border:1px solid var(--a-b)}
.gr-d{background:var(--r-s);color:var(--red);border:1px solid var(--r-b)}

/* ── TEAM MANAGER ── */
.team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding:14px}
.team-card{background:var(--raised);border:1px solid var(--border);border-radius:10px;padding:14px;display:flex;flex-direction:column;align-items:center;gap:8px;text-align:center;cursor:pointer;transition:all .2s}
.team-card:hover{border-color:rgba(255,255,255,.12);transform:translateY(-2px)}
.team-av-lg{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff}
.team-name{font-size:13px;font-weight:600;color:var(--t1)}
.team-role-text{font-size:10px;color:var(--t3)}
.team-stats{display:flex;gap:10px;width:100%}
.ts-item{flex:1;text-align:center;padding:5px;background:var(--card);border-radius:6px}
.ts-num{font-family:var(--fh);font-size:14px;font-weight:700}
.ts-label{font-size:8px;color:var(--t3);margin-top:1px}
.team-perf-bar{width:100%;height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.team-perf-fill{height:100%;border-radius:2px}
.role-badge{font-size:9px;font-weight:700;padding:2px 7px;border-radius:100px;border:1px solid}

/* ── RESPONSIBILITY MATRIX ── */
.matrix-wrap{padding:0 14px 14px;overflow-x:auto}
.matrix{width:100%;border-collapse:collapse}
.matrix th{padding:8px 12px;text-align:left;font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);white-space:nowrap}
.matrix td{padding:9px 12px;border-bottom:1px solid var(--div);font-size:11px;color:var(--t2);vertical-align:middle}
