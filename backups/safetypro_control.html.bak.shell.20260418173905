<script>
function scUpdate() {
  var inc = parseInt(document.getElementById('sc-inc').value);
  var ncr = parseInt(document.getElementById('sc-ncr').value);
  var train = parseInt(document.getElementById('sc-train').value);
  var off = parseInt(document.getElementById('sc-off').value);
  document.getElementById('sc-inc-val').textContent = (inc >= 0 ? '+' : '') + inc + '%';
  document.getElementById('sc-ncr-val').textContent = ncr + '%';
  document.getElementById('sc-train-val').textContent = train + '%';
  document.getElementById('sc-off-val').textContent = off;
  var baseline = 20;
  var projDelta = Math.round(baseline * inc / 100);
  var risk = inc > 30 ? 'High' : inc > 0 ? 'Medium' : 'Low';
  var riskCol = inc > 30 ? 'var(--red)' : inc > 0 ? 'var(--amber)' : 'var(--green)';
  var matNum = ((-inc * 0.015) + ((ncr - 78) * 0.01) + ((train - 83) * 0.008) + (off * 0.1));
  var matImp = (matNum >= 0 ? '+' : '') + matNum.toFixed(1);
  var matCol = matNum >= 0 ? 'var(--green)' : 'var(--amber)';
  var matArr = matNum >= 0 ? '&#8593;' : '&#8595;';
  var cost = (projDelta) * 52000;
  var costStr = (cost >= 0 ? '+' : '-') + '&#8377;' + Math.abs(Math.round(cost/1000)) + 'K';
  var costCol = cost > 0 ? 'var(--red)' : 'var(--green)';
  document.getElementById('sc-proj-inc').innerHTML = '<span style="color:' + (projDelta > 0 ? 'var(--red)' : 'var(--green)') + ';">' + (projDelta > 0 ? '+' : '') + projDelta + '</span>';
  document.getElementById('sc-esc-risk').innerHTML = '<span style="color:' + riskCol + ';">' + risk + '</span>';
  document.getElementById('sc-mat-imp').innerHTML = '<span style="color:' + matCol + ';">' + matArr + ' ' + matImp + '</span>';
  document.getElementById('sc-cost').innerHTML = '<span style="color:' + costCol + ';">' + costStr + '</span>';
}
</script>



