/* ─ HELPERS ─ */
function otStatusColor(s){ return {ON_TRACK:'#22C55E',AT_RISK:'#F59E0B',DELAYED:'#EF4444',NOT_STARTED:'#64748B'}[s]||'#64748B'; }
function otStatusBg(s){ return {ON_TRACK:'rgba(34,197,94,.1)',AT_RISK:'rgba(245,158,11,.1)',DELAYED:'rgba(239,68,68,.1)',NOT_STARTED:'rgba(100,116,139,.1)'}[s]||''; }
function otStatusLabel(s){ return {ON_TRACK:'On Track',AT_RISK:'At Risk',DELAYED:'Delayed',NOT_STARTED:'Not Started'}[s]||s; }
function otTypeIcon(t){ return {zero:'🎯',reduction:'↓',increase:'↑',maintain:'→',achieve:'✓'}[t]||'·'; }

/* ─ RENDER OBJECTIVE CARD ─ */
function otRenderCard(obj) {
  var c = otStatusColor(obj.status);
  var bg = otStatusBg(obj.status);
  var achColor = obj.achievement >= 85 ? '#22C55E' : obj.achievement >= 60 ? '#F59E0B' : '#EF4444';
  var levelBadge = obj.level === 'company' ?
    '<span style="font-size:8px;font-weight:700;background:rgba(59,130,246,.12);color:#3B82F6;padding:1px 6px;border-radius:3px;">COMPANY</span>' :
    '<span style="font-size:8px;font-weight:700;background:rgba(245,158,11,.12);color:#F59E0B;padding:1px 6px;border-radius:3px;">PROJECT — '+obj.project+'</span>';

  /* Quarterly dots */
  var qDots = [obj.q1, obj.q2, obj.q3, obj.q4].map(function(q, i) {
    if(q === null) return '<div style="width:6px;height:6px;border-radius:50%;background:var(--border);"></div>';
    var qc = q >= 85 ? '#22C55E' : q >= 60 ? '#F59E0B' : '#EF4444';
    return '<div style="width:6px;height:6px;border-radius:50%;background:'+qc+';title=Q'+(i+1)+'"></div>';
  }).join('');

  return '<div style="background:var(--elevated);border:1px solid var(--border);border-left:3px solid '+c+';border-radius:9px;padding:12px 14px;margin-bottom:9px;">' +
    '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">' +
      '<span style="font-size:11px;color:var(--t3);font-family:var(--fh);">'+obj.id+'</span>' +
      levelBadge +
      '<span style="font-size:9px;font-weight:700;background:'+bg+';color:'+c+';padding:2px 7px;border-radius:4px;">'+otStatusLabel(obj.status)+'</span>' +
      '<span style="margin-left:auto;font-size:9px;color:var(--t3);">'+obj.clause+'</span>' +
    '</div>' +
    '<div style="font-size:12px;font-weight:700;color:var(--t1);margin-bottom:8px;">'+otTypeIcon(obj.type)+' '+obj.title+'</div>' +
    '<div style="display:flex;align-items:center;gap:16px;">' +
      '<div style="flex:1;">' +
        '<div style="display:flex;justify-content:space-between;font-size:9px;color:var(--t3);margin-bottom:3px;">' +
          '<span>Target: <b style="color:var(--t1);">'+obj.target+'</b></span>' +
          '<span>Actual: <b style="color:'+achColor+';">'+obj.actual+'</b></span>' +
          '<span>Achievement: <b style="color:'+achColor+';">'+obj.achievement+'%</b></span>' +
        '</div>' +
        '<div style="height:6px;background:var(--border);border-radius:3px;overflow:hidden;">' +
          '<div style="height:100%;width:'+Math.min(obj.achievement,100)+'%;background:'+achColor+';border-radius:3px;transition:width .3s;"></div>' +
        '</div>' +
      '</div>' +
      '<div style="text-align:right;min-width:80px;">' +
        '<div style="font-size:9px;color:var(--t3);margin-bottom:3px;">Q milestones</div>' +
        '<div style="display:flex;gap:3px;justify-content:flex-end;">'+qDots+'</div>' +
      '</div>' +
    '</div>' +
    '<div style="display:flex;align-items:center;gap:10px;margin-top:8px;padding-top:7px;border-top:1px solid var(--div);font-size:9px;color:var(--t3);">' +
      '<span>Owner: <b style="color:var(--t2);">'+obj.owner+'</b></span>' +
      '<span>KPI: '+obj.kpi+'</span>' +
      '<span>Weight: <b style="color:var(--t2);">'+obj.weight+'%</b></span>' +
      '<span>Evidence: '+obj.evidence+' files</span>' +
      '<div style="margin-left:auto;display:flex;gap:5px;">' +
        '<button onclick="otOpenUpdate(this.dataset.oid)" data-oid="'+obj.id+'" style="background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.25);color:#3B82F6;font-size:9px;font-weight:700;padding:2px 8px;border-radius:4px;cursor:pointer;font-family:var(--fh);">Update</button>' +
        '<button onclick="otAttachEvidence(this.dataset.oid)" data-oid="'+obj.id+'" style="background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.25);color:#22C55E;font-size:9px;font-weight:700;padding:2px 8px;border-radius:4px;cursor:pointer;font-family:var(--fh);">+ Evidence</button>' +
      '</div>' +
    '</div>' +
  '</div>';
}

/* ─ MAIN RENDER ─ */
window.otRender = function() {
  var period = document.getElementById('ot-period-sel') ? document.getElementById('ot-period-sel').value : 'fy26';

  var showCo = _otLevel === 'co' || _otLevel === 'all';
  var showPr = _otLevel === 'pr' || _otLevel === 'all';

  var coSection = document.getElementById('ot-section-co');
  var prSection = document.getElementById('ot-section-pr');
  if(coSection) coSection.style.display = showCo ? 'block' : 'none';
  if(prSection) prSection.style.display = showPr ? 'block' : 'none';

  /* Render company objectives */
  var coList = document.getElementById('ot-list-co');
  if(coList) {
    coList.innerHTML = '';
    _otCompanyObjectives.filter(function(o){ return o.period === period || period === 'fy26'; })
      .forEach(function(o){ coList.innerHTML += otRenderCard(o); });
  }

  /* Render project objectives */
  var prList = document.getElementById('ot-list-pr');
  if(prList) {
    prList.innerHTML = '';
    _otProjectObjectives.filter(function(o){ return o.period === period || period === 'fy26'; })
      .forEach(function(o){ prList.innerHTML += otRenderCard(o); });
  }

  /* Quarterly tracker */
  var qEl = document.getElementById('ot-quarters');
  if(qEl && !qEl.children.length) {
    var quarters = [{q:'Q1',p:'Jan–Mar 2026',done:true,score:88},{q:'Q2',p:'Apr–Jun 2026',done:true,score:90},{q:'Q3',p:'Jul–Sep 2026',done:false,score:null},{q:'Q4',p:'Oct–Dec 2026',done:false,score:null}];
    quarters.forEach(function(qt){
      var c = qt.done ? '#22C55E' : 'var(--t3)';
      var icon = qt.done ? '✓' : '○';
      qEl.innerHTML += '<div style="display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--div);">' +
        '<div style="font-size:14px;font-weight:800;color:'+c+';min-width:28px;">'+icon+'</div>' +
        '<div style="flex:1;"><div style="font-size:11px;font-weight:700;color:'+(qt.done?'var(--t1)':'var(--t3)')+';">'+qt.q+'</div><div style="font-size:9px;color:var(--t3);">'+qt.p+'</div></div>' +
        (qt.score ? '<div style="font-size:12px;font-weight:700;color:#22C55E;">'+qt.score+'%</div>' : '<div style="font-size:10px;color:var(--t3);">Upcoming</div>') +
      '</div>';
    });
  }

  /* Period summary */
  var ps = document.getElementById('ot-period-summary');
  if(ps && !ps.children.length) {
    [{l:'Period',v:'FY 2025-26'},{l:'Set Date',v:'01 Apr 2025'},{l:'Review Frequency',v:'Quarterly'},{l:'Company Objectives',v:'6'},{l:'Project Objectives',v:'6'},{l:'Next Review',v:'30 Jun 2026'}].forEach(function(r){
      ps.innerHTML += '<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--div);font-size:10px;"><span style="color:var(--t3);">'+r.l+'</span><span style="font-weight:700;color:var(--t1);">'+r.v+'</span></div>';
    });
  }
};

/* ─ LEVEL TOGGLE ─ */
window.otSetLevel = function(level) {
  _otLevel = level;
  ['co','pr','all'].forEach(function(l){
    var btn = document.getElementById('ot-level-'+l);
    if(!btn) return;
    if(l === level) {
      btn.style.background = 'var(--green)'; btn.style.color = '#0B0E12'; btn.style.border = 'none';
    } else {
      btn.style.background = 'var(--raised)'; btn.style.color = 'var(--t2)'; btn.style.border = '1px solid var(--border)';
    }
  });
  otRender();
};

/* ─ MODAL ─ */
window.otOpenSetModal = function() {
  var m = document.getElementById('ot-set-modal');
  if(m) m.style.display = 'flex';
};
window.otCloseModal = function() {
  var m = document.getElementById('ot-set-modal');
  if(m) m.style.display = 'none';
};
window.otSaveObjective = function() {
  var title = (document.getElementById('ot-new-title')||{}).value || '';
  var level = (document.getElementById('ot-new-level')||{}).value || 'company';
  if(!title) { alert('Please enter an objective title'); return; }
  otCloseModal();
  if(typeof showToast === 'function') showToast('Objective saved: '+title, 'green');
};
window.otOpenUpdate = function(id) {
  if(typeof showToast === 'function') showToast('Opening update form for '+id, 'blue');
};
window.otAttachEvidence = function(id) {
  if(typeof showToast === 'function') showToast('Evidence attachment opened for '+id, 'green');
};

/* ─ INIT ─ */
document.addEventListener('DOMContentLoaded', function() {
  var objPanel = document.getElementById('tab-objectives');
  if(objPanel && objPanel.style.display !== 'none') otRender();
});

