/* ── SINGLE switchTab for Control ── */
function ctrlSwitchTab(el, tabId) {
  document.querySelectorAll('.sh-tab').forEach(function(t){t.classList.remove('active');});
  if(el) el.classList.add('active');
  ['escalations','overdue','accountability','team','scenario','livefeed','analytics','objectives'].forEach(function(id){
    var p = document.getElementById('tab-'+id);
    if(p) p.style.display = id===tabId ? 'block' : 'none';
  });
  if(tabId==='escalations')   ctrlRenderEscalations();
  if(tabId==='overdue')       ctrlRenderOverdue();
  if(tabId==='accountability') ctrlRenderAcc();
  if(tabId==='livefeed')      ctrlRenderFeed();
  if(tabId==='analytics')     ctrlRenderAnalytics();
  /* scroll active tab into view */
  setTimeout(function(){
    var sc=document.getElementById('ctrl-tabs-scroll');
    var a=sc&&sc.querySelector('.sh-tab.active');
    if(sc&&a) sc.scrollTo({left:a.offsetLeft-sc.clientWidth/2+a.offsetWidth/2,behavior:'smooth'});
  },50);
}
