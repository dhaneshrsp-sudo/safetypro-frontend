function positionDropdown(dropdown, trigger) {
  if (!dropdown || !trigger) return;
  var tr = trigger.getBoundingClientRect(); var vw = window.innerWidth;
  var dw = Math.min(dropdown.offsetWidth || 260, vw - 16);
  var right = vw - tr.right; if (right < 8) right = 8;
  dropdown.style.right = right + 'px'; dropdown.style.left = 'auto';
  dropdown.style.top = (tr.bottom + 6) + 'px';
  if (vw <= 480) dropdown.style.width = (vw - 12) + 'px';
  else if (vw <= 768) dropdown.style.width = Math.min(dw, vw - 16) + 'px';
}
