<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0B0F14;--card:#131C26;--border:#1E293B;--green:#22C55E;--blue:#3B82F6;--t1:#E6EDF3;--t2:#94A3B8;--t3:#64748B;--fh:'Montserrat',sans-serif;--fb:'Roboto',sans-serif;}
body{background:var(--bg);color:var(--t1);font-family:var(--fb);line-height:1.8;}
.topbar{background:#0F1720;border-bottom:1px solid var(--border);padding:0 24px;height:52px;display:flex;align-items:center;justify-content:space-between;}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.logo-shield{width:28px;height:28px;background:linear-gradient(135deg,#22C55E,#16A34A);border-radius:7px;display:flex;align-items:center;justify-content:center;}
.logo-shield svg{width:16px;height:16px;fill:#fff;}
.logo-text{font-family:var(--fh);font-size:14px;font-weight:800;color:var(--t1);}
.logo-text span{color:var(--green);}
.nav-links{display:flex;gap:20px;}
.nav-links a{font-size:11px;color:var(--t3);text-decoration:none;font-family:var(--fh);font-weight:600;}
.nav-links a:hover{color:var(--t1);}
.hero{background:linear-gradient(180deg,rgba(34,197,94,.04),transparent);border-bottom:1px solid var(--border);padding:48px 24px 36px;text-align:center;}
.hero-badge{display:inline-block;font-size:10px;font-weight:700;padding:4px 12px;border-radius:100px;background:rgba(34,197,94,.1);color:var(--green);border:1px solid rgba(34,197,94,.3);font-family:var(--fh);margin-bottom:16px;}
.hero h1{font-family:var(--fh);font-size:28px;font-weight:800;color:var(--t1);margin-bottom:8px;}
.hero-sub{font-size:13px;color:var(--t3);max-width:500px;margin:0 auto;}
.content{max-width:800px;margin:0 auto;padding:40px 24px;}
.section{margin-bottom:36px;}
.section h2{font-family:var(--fh);font-size:15px;font-weight:700;color:var(--t1);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.section h3{font-family:var(--fh);font-size:13px;font-weight:600;color:var(--t2);margin:16px 0 8px;}
.section p{font-size:13px;color:var(--t2);margin-bottom:10px;}
.section ul{font-size:13px;color:var(--t2);padding-left:20px;margin-bottom:10px;}
.section ul li{margin-bottom:6px;}
.highlight{background:rgba(34,197,94,.05);border:1px solid rgba(34,197,94,.15);border-radius:8px;padding:14px 16px;margin:16px 0;font-size:13px;color:var(--t2);}
.highlight strong{color:var(--green);}
.footer-legal{background:#0F1720;border-top:1px solid var(--border);padding:24px;text-align:center;margin-top:40px;}
.footer-legal a{color:var(--t3);text-decoration:none;font-size:11px;margin:0 10px;font-family:var(--fh);}
.footer-legal a:hover{color:var(--t1);}
.footer-copy{font-size:11px;color:var(--t3);margin-top:8px;}

/* SafetyPro scrollbar v2 */
.body { overflow: hidden !important; }
.content { overflow-y: auto !important; scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
.content::-webkit-scrollbar { width: 4px; }
.content::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
</style>
<style>/* sp-height-fix */
html,body{height:100%!important;overflow:hidden!important;}
.body{height:calc(100vh - 52px)!important;overflow:hidden!important;}
</style>
