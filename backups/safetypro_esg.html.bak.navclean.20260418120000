var EAIA_DATA = [];

var SSPD_SC = ['1 = Localised within work area','2 = Within site boundary','3 = Site boundary & adjacent area','4 = Nearby community / village','5 = Regional / waterbody affected'];
var SSPD_SV = ['1 = Negligible, no visible effect','2 = Minor, fully recoverable','3 = Moderate, recoverable over time','4 = Major, difficult to recover','5 = Catastrophic / irreversible'];
var SSPD_PR = ['1 = Rare — less than 5% probability','2 = Unlikely — 5 to 25%','3 = Possible — 25 to 50%','4 = Likely — 50 to 75%','5 = Almost certain — above 75%'];
var SSPD_DU = ['1 = Momentary — less than 1 hour','2 = Short-term — less than 1 day','3 = Medium — 1 day to 1 month','4 = Long-term — 1 to 12 months','5 = Permanent — more than 1 year'];
var SSPD_DE = ['1 = Always detected / easily controlled','2 = Usually detected','3 = Sometimes detected','4 = Rarely detected','5 = Not detectable'];

function eaiaScore(r){ return r.sc * r.sv * r.pr * r.du * r.de; }
function eaiaResScore(r){ var rs=r.rsc||r.sc,rv=r.rsv||r.sv,rp=r.rpr||r.pr,rd=r.rdu||r.du,re2=r.rde||r.de; return rs*rv*rp*rd*re2; }
function eaiaSig(s){ return s>=36; }

function eaiaLoad(){
  try{ var d=localStorage.getItem('sp_eaia_v3'); EAIA_DATA=d?JSON.parse(d):EAIA_DEFAULT.map(function(x){return Object.assign({},x);}); }
  catch(e){ EAIA_DATA=EAIA_DEFAULT.map(function(x){return Object.assign({},x);}); }
}
function eaiaSave(){ try{ localStorage.setItem('sp_eaia_v3',JSON.stringify(EAIA_DATA)); }catch(e){} }
function eaiaGetVal(id){ return (document.getElementById(id)||{}).value||''; }
function eaiaSetVal(id,v){ var el=document.getElementById(id); if(el&&v) el.value=v; }

function eaiaSaveMeta(){
  var m={
    org:eaiaGetVal('eaia-org'), project:eaiaGetVal('eaia-project'),
    dept:eaiaGetVal('eaia-dept'), docno:eaiaGetVal('eaia-docno'),
    rev:eaiaGetVal('eaia-rev'), date:eaiaGetVal('eaia-date'),
    prep:eaiaGetVal('eaia-prep'), reviewBy:eaiaGetVal('eaia-review-by'),
    appr:eaiaGetVal('eaia-appr')
  };
  try{ localStorage.setItem('sp_eaia_meta',JSON.stringify(m)); }catch(e){}
  eaiaRefreshHeader(m);
}

function eaiaRefreshHeader(m){
  function set(id,v,fallback){ var el=document.getElementById(id); if(el) el.textContent=v||fallback||'—'; }
  set('hdr-org', m.org);
  set('hdr-project', m.project);
  set('hdr-dept', m.dept);
  var orgPfx = m.org ? m.org.replace(/\s+/g,'').substring(0,8).toUpperCase() : '[Org]';
  set('hdr-docno', m.docno || (orgPfx+'-HSE-EIA-01'));
  set('hdr-rev', m.rev, 'Rev 00');
  set('hdr-date', m.date ? new Date(m.date).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '—');
  var sigs = [m.prep&&('Prep: '+m.prep), m.reviewBy&&('Rev: '+m.reviewBy), m.appr&&('Appr: '+m.appr)].filter(Boolean).join(' | ');
  set('hdr-signatories', sigs);
}

function eaiaLoadMeta(){
  try{
    var m=JSON.parse(localStorage.getItem('sp_eaia_meta')||'{}');
    eaiaSetVal('eaia-org',m.org); eaiaSetVal('eaia-project',m.project);
    eaiaSetVal('eaia-dept',m.dept); eaiaSetVal('eaia-docno',m.docno);
    eaiaSetVal('eaia-rev',m.rev); eaiaSetVal('eaia-date',m.date);
    eaiaSetVal('eaia-prep',m.prep); eaiaSetVal('eaia-review-by',m.reviewBy);
    eaiaSetVal('eaia-appr',m.appr);
    eaiaRefreshHeader(m);
  }catch(e){}
}

function eaiaOpenEditHeader(){
  eaiaLoadMeta();
  var m=document.getElementById('eaia-hdr-modal');
  if(m) m.style.display='flex';
}

function eaiaSaveHeader(){
  eaiaSaveMeta();
  var m=document.getElementById('eaia-hdr-modal');
  if(m) m.style.display='none';
  if(typeof acToast==='function') acToast('Header saved');
}

function eaiaPopulateActivityFilter(){
  var sel=document.getElementById('eaia-act-f');
  if(!sel) return;
  var current=sel.value;
  sel.innerHTML='<option value="ALL">All Activities</option>';
  var seen={};
  EAIA_DATA.forEach(function(r){
    if(!seen[r.activity]){
      seen[r.activity]=1;
      var o=document.createElement('option');
      o.value=r.activity; o.textContent=r.activity;
      sel.appendChild(o);
    }
  });
  if(current) sel.value=current;
}

function eaiaRender(){
  eaiaLoad();
  eaiaPopulateActivityFilter();
  var filter=(document.getElementById('eaia-filter')||{}).value||'ALL';
  var condF=(document.getElementById('eaia-cond-f')||{}).value||'ALL';
  var actF=(document.getElementById('eaia-act-f')||{}).value||'ALL';
  var tbody=document.getElementById('eaia-tbody');
  if(!tbody) return;

  var totSig=0,totNS=0,totRes=0,totOcp=0,totLc=0;
  EAIA_DATA.forEach(function(r){
    var s=eaiaScore(r), rs=eaiaResScore(r);
    if(eaiaSig(s)) totSig++; else totNS++;
    if(eaiaSig(rs)) totRes++;
    if(r.ocp) totOcp++;
    if(r.lc==='Y'||r.ipc==='Y'||r.bc==='Y'||r.rcp==='Y') totLc++;
  });
  function set(id,v){var el=document.getElementById(id);if(el)el.textContent=v;}
  set('eaia-c-total',EAIA_DATA.length);
  set('eaia-c-sig',totSig); set('eaia-c-ns',totNS);
  set('eaia-c-res',totRes); set('eaia-c-ocp',totOcp); set('eaia-c-lc',totLc);

  var filtered=EAIA_DATA.filter(function(r,i){
    var s=eaiaScore(r);
    if(filter==='SIG'&&!eaiaSig(s)) return false;
    if(filter==='NS'&&eaiaSig(s)) return false;
    if(condF!=='ALL'&&r.cond!==condF) return false;
    if(actF!=='ALL'&&r.activity!==actF) return false;
    return true;
  });

  tbody.innerHTML=filtered.map(function(r){
    var realIdx=EAIA_DATA.indexOf(r);
    var score=eaiaScore(r), rscore=eaiaResScore(r);
    var sig=eaiaSig(score), rSig=eaiaSig(rscore);
    var rowBg=sig?'background:rgba(239,68,68,.04);border-left:2px solid #EF4444;':'border-left:2px solid transparent;';
    var condColor=r.cond==='E'?'#F87171':r.cond==='A'?'#F59E0B':'#22C55E';
    function yn(v){return v==='Y'?'<span style="color:#22C55E;font-weight:700;">Y</span>':'<span style="color:var(--t4);">N</span>';}
    var scoreColor=sig?'#EF4444':'#22C55E';
    var rScoreColor=rSig?'#F59E0B':'#22C55E';
    var badge=sig
      ?'<span style="background:rgba(239,68,68,.12);border:0.5px solid rgba(239,68,68,.3);color:#F87171;padding:1px 5px;border-radius:3px;font-size:8px;font-weight:700;">S</span>'
      :'<span style="background:rgba(34,197,94,.1);border:0.5px solid rgba(34,197,94,.25);color:#22C55E;padding:1px 5px;border-radius:3px;font-size:8px;font-weight:700;">NS</span>';
    var rBadge=rSig
      ?'<span style="background:rgba(245,158,11,.12);border:0.5px solid rgba(245,158,11,.3);color:#F59E0B;padding:1px 5px;border-radius:3px;font-size:8px;font-weight:700;">S</span>'
      :'<span style="background:rgba(34,197,94,.1);border:0.5px solid rgba(34,197,94,.25);color:#22C55E;padding:1px 5px;border-radius:3px;font-size:8px;font-weight:700;">NS</span>';

    return '<div style="display:grid;grid-template-columns:30px 130px 120px 130px 50px 30px 30px 30px 30px 34px 34px 34px 34px 34px 56px 50px 130px 80px 130px 120px 56px 50px 100px;border-bottom:0.5px solid var(--border);align-items:center;'+rowBg+'">'
      +'<div style="padding:5px 4px;color:var(--t3);font-weight:600;font-size:9px;">'+(realIdx+1)+'</div>'
