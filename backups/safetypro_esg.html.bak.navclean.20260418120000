      +'onchange="WHY_DATA['+i+'].a=this.value;updateRootCause()">'+w.a+'</textarea>'
      +'</div></div>';
  }).join('');
  updateRootCause();
}
function addWhyLevel() {
  WHY_DATA.push({q:'Why? (Level '+(WHY_DATA.length+1)+')', a:''});
