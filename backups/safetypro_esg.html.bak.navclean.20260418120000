function eaiaOpenEdit(idx){
  var r=EAIA_DATA[idx];
  var mb=document.getElementById('eaia-m-body');
  var mt=document.getElementById('eaia-m-title');
  if(!mb||!mt) return;
  mt.textContent=r.activity;

  function scoreBox(sc,sv,pr,du,de,isRes){
    var s=sc*sv*pr*du*de;
    var sig=eaiaSig(s);
    var color=isRes?(sig?'#F59E0B':'#22C55E'):(sig?'#EF4444':'#22C55E');
    var bg=isRes?(sig?'rgba(245,158,11,.08)':'rgba(34,197,94,.07)'):(sig?'rgba(239,68,68,.08)':'rgba(34,197,94,.07)');
    return '<div style="background:'+bg+';border-radius:6px;padding:8px;text-align:center;margin-top:8px;">'
      +'<div style="font-size:9px;color:var(--t3);margin-bottom:2px;">Score = Sc &times; Sv &times; Pr &times; Du &times; De</div>'
      +'<div id="'+(isRes?'ev-rscore':'ev-score')+'" style="font-size:30px;font-weight:700;color:'+color+';">'+s+'</div>'
      +'<div id="'+(isRes?'ev-rlabel':'ev-label')+'" style="font-size:10px;font-weight:700;color:'+color+';">'+(sig?(isRes?'Still Significant':'SIGNIFICANT'):(isRes?'Residual Non-Significant':'Non-Significant'))+'</div>'
      +'</div>';
  }

  function srow(param,val,max,descs,isRes){
    var prefix=isRes?'r':'';
    var id='ev-'+prefix+param;
    var color=val>=4?'#EF4444':val>=3?'#F59E0B':'#22C55E';
    var desc=descs[val-1]||'';
    var d=document.createElement('div');
    d.style.cssText='display:flex;align-items:center;gap:6px;margin-bottom:6px;';
    var lbl=document.createElement('span');
    lbl.style.cssText='width:80px;font-size:9px;color:var(--t2);flex-shrink:0;';
    lbl.textContent=(isRes?'Residual ':'')+{sc:'Scale',sv:'Severity',pr:'Probability',du:'Duration',de:'Detection'}[param];
    var inp=document.createElement('input');
    inp.type='range'; inp.min=1; inp.max=max; inp.value=val; inp.step=1; inp.style.cssText='flex:1;';
    inp.setAttribute('data-idx',idx); inp.setAttribute('data-param',(isRes?'r':'')+param); inp.setAttribute('data-res',isRes?'1':'0');
    inp.oninput=function(){ eaiaModalSlider(this); };
    var vsp=document.createElement('span');
    vsp.id=id; vsp.style.cssText='width:20px;text-align:center;font-weight:700;font-size:11px;color:'+color+';';
    vsp.textContent=val;
    var dsp=document.createElement('span');
    dsp.style.cssText='flex:2;font-size:9px;color:var(--t3);';
    dsp.id=id+'-desc'; dsp.textContent=desc;
    d.appendChild(lbl); d.appendChild(inp); d.appendChild(vsp); d.appendChild(dsp);
    return d;
  }

  mb.innerHTML='';

  // Aspect/Impact info
  var info=document.createElement('div');
  info.style.cssText='background:var(--raised);border-radius:7px;padding:9px 12px;margin-bottom:10px;display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:10px;';
  info.innerHTML='<div><div style="font-size:8px;color:var(--t3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:2px;">Aspect</div><div style="color:var(--t1);">'+r.aspect+'</div></div>'
    +'<div><div style="font-size:8px;color:var(--t3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:2px;">Impact</div><div style="color:var(--t1);">'+r.impact+'</div></div>'
    +'<div style="display:flex;gap:8px;font-size:9px;margin-top:2px;">'
    +'<span style="color:var(--t3);">Cond:</span><strong style="color:'+(r.cond==='E'?'#F87171':r.cond==='A'?'#F59E0B':'#22C55E')+';">'+r.cond+'</strong>'
    +'<span style="color:var(--t3);margin-left:8px;">Impact Criteria:</span>'
    +(r.lc==='Y'?'<span style="background:rgba(59,130,246,.1);color:#60A5FA;padding:1px 5px;border-radius:3px;font-size:8px;font-weight:700;">LC</span>':'')+
    (r.ipc==='Y'?'<span style="background:rgba(139,92,246,.1);color:#A78BFA;padding:1px 5px;border-radius:3px;font-size:8px;font-weight:700;">IPC</span>':'')+
    (r.bc==='Y'?'<span style="background:rgba(245,158,11,.1);color:#F59E0B;padding:1px 5px;border-radius:3px;font-size:8px;font-weight:700;">BC</span>':'')+
    (r.rcp==='Y'?'<span style="background:rgba(34,197,94,.1);color:#22C55E;padding:1px 5px;border-radius:3px;font-size:8px;font-weight:700;">RCP</span>':'')
    +'</div><div></div>';
  mb.appendChild(info);

  // Two columns: initial | residual
  var grid=document.createElement('div');
  grid.style.cssText='display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;';

  var initDiv=document.createElement('div');
  initDiv.style.cssText='background:var(--raised);border-radius:8px;padding:10px;';
  initDiv.innerHTML='<div style="font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">Initial Score (before controls)</div>';
  [['sc',r.sc,5,SSPD_SC],['sv',r.sv,5,SSPD_SV],['pr',r.pr,5,SSPD_PR],['du',r.du,5,SSPD_DU],['de',r.de,5,SSPD_DE]].forEach(function(p){
    initDiv.appendChild(srow(p[0],p[1],p[2],p[3],false));
  });
  initDiv.innerHTML+=scoreBox(r.sc,r.sv,r.pr,r.du,r.de,false);
  grid.appendChild(initDiv);

  var resDiv=document.createElement('div');
  resDiv.style.cssText='background:rgba(139,92,246,.06);border:0.5px solid rgba(139,92,246,.2);border-radius:8px;padding:10px;';
  resDiv.innerHTML='<div style="font-size:9px;color:#A78BFA;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">Residual Score (after controls)</div>';
  [['sc',r.rsc||r.sc],['sv',r.rsv||r.sv],['pr',r.rpr||r.pr],['du',r.rdu||r.du],['de',r.rde||r.de]].forEach(function(p,i){
    var descs=[SSPD_SC,SSPD_SV,SSPD_PR,SSPD_DU,SSPD_DE][i];
    resDiv.appendChild(srow(p[0],p[1],5,descs,true));
  });
  resDiv.innerHTML+=scoreBox(r.rsc||r.sc,r.rsv||r.sv,r.rpr||r.pr,r.rdu||r.du,r.rde||r.de,true);
  grid.appendChild(resDiv);
  mb.appendChild(grid);

  // Control fields
  var fields=document.createElement('div');
  fields.style.cssText='display:flex;flex-direction:column;gap:8px;';
  function frow(label,fid,val){
    var d=document.createElement('div');
    d.innerHTML='<label style="font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.4px;display:block;margin-bottom:3px;">'+label+'</label>'
      +'<input id="'+fid+'" value="'+val.replace(/"/g,'&quot;')+'" style="width:100%;padding:7px 9px;background:var(--raised);border:1px solid var(--border);border-radius:6px;color:var(--t1);font-size:11px;" onchange="eaiaFieldChange('+idx+',\''+fid+'\',this.value)"/>';
    return d;
  }
  fields.appendChild(frow('Existing Control',     'ef-ctrl1',  r.ctrl1));
  fields.appendChild(frow('Gap (if any)',          'ef-gap',    r.gap));
  fields.appendChild(frow('Control Measure (OCP)', 'ef-ctrl2',  r.ctrl2));
  fields.appendChild(frow('Competent Authority',   'ef-auth',   r.auth));
  var ocpRow=document.createElement('label');
  ocpRow.style.cssText='display:flex;align-items:center;gap:8px;font-size:11px;color:var(--t2);cursor:pointer;';
  ocpRow.innerHTML='<input type="checkbox"'+(r.ocp?' checked':'')+' onchange="EAIA_DATA['+idx+'].ocp=this.checked;eaiaSave();eaiaRender();"> OCP Required';
  fields.appendChild(ocpRow);
  mb.appendChild(fields);

  document.getElementById('eaia-modal').style.display='flex';
}

function eaiaModalSlider(inp){
  var idx=parseInt(inp.getAttribute('data-idx'));
  var param=inp.getAttribute('data-param');
  var val=parseInt(inp.value);
  EAIA_DATA[idx][param]=val;
  var el=document.getElementById('ev-'+param);
  if(el) el.textContent=val;
  // update desc
  var descMap={sc:SSPD_SC,sv:SSPD_SV,pr:SSPD_PR,du:SSPD_DU,de:SSPD_DE,
               rsc:SSPD_SC,rsv:SSPD_SV,rpr:SSPD_PR,rdu:SSPD_DU,rde:SSPD_DE};
  var descs=descMap[param];
  var dEl=document.getElementById('ev-'+param+'-desc');
  if(dEl&&descs) dEl.textContent=descs[val-1]||'';
  // recalc scores
  var r=EAIA_DATA[idx];
  var s=eaiaScore(r), rs=eaiaResScore(r);
  var sigC=eaiaSig(s)?'#EF4444':'#22C55E';
  var resC=eaiaSig(rs)?'#F59E0B':'#22C55E';
  function upd(id,val,color){var e=document.getElementById(id);if(e){e.textContent=val;e.style.color=color;}}
  upd('ev-score',s,sigC);
  upd('ev-label',eaiaSig(s)?'SIGNIFICANT':'Non-Significant',sigC);
  upd('ev-rscore',rs,resC);
  upd('ev-rlabel',eaiaSig(rs)?'Still Significant':'Residual Non-Significant',resC);
  eaiaSave(); eaiaRender();
}

function eaiaFieldChange(idx,fid,val){
  var map={'ef-ctrl1':'ctrl1','ef-gap':'gap','ef-ctrl2':'ctrl2','ef-auth':'auth'};
  if(map[fid]) EAIA_DATA[idx][map[fid]]=val;
  eaiaSave();
}

function eaiaDeleteRow(idx){
  if(!confirm('Remove this entry?')) return;
  EAIA_DATA.splice(idx,1); eaiaSave(); eaiaRender();
}

function eaiaOpenAdd(){ document.getElementById('eaia-add-modal').style.display='flex'; }


function eaiaAddScoreUpdate(){
  var sc=Math.min(5,Math.max(1,parseInt((document.getElementById('add-sc')||{}).value)||2));
  var sv=Math.min(5,Math.max(1,parseInt((document.getElementById('add-sv')||{}).value)||2));
  var pr=Math.min(5,Math.max(1,parseInt((document.getElementById('add-pr')||{}).value)||2));
  var du=Math.min(5,Math.max(1,parseInt((document.getElementById('add-du')||{}).value)||2));
  var de=Math.min(5,Math.max(1,parseInt((document.getElementById('add-de')||{}).value)||2));
  var score=sc*sv*pr*du*de;
  var sig=score>=36;
  var sp=document.getElementById('add-score-preview');
  var sl=document.getElementById('add-sig-preview');
  if(sp){sp.textContent=score;sp.style.color=sig?'#EF4444':'#22C55E';}
  if(sl){sl.textContent=sig?'SIGNIFICANT':'Non-Significant';sl.style.color=sig?'#EF4444':'#22C55E';}
}
function eaiaPopulateAddActDropdown(){
  var sel=document.getElementById('add-act-sel'); if(!sel) return;
  var seen={};
  sel.innerHTML='<option value="">— Select existing activity —</option>';
  EAIA_DATA.forEach(function(r){
    if(!seen[r.activity]){seen[r.activity]=1;
      var o=document.createElement('option');o.value=r.activity;o.textContent=r.activity;sel.appendChild(o);
    }
  });
}
function eaiaOpenAdd(){ eaiaLoad(); eaiaPopulateAddActDropdown(); eaiaAddScoreUpdate(); var m=document.getElementById('eaia-add-modal'); if(m) m.style.display='flex'; }
function eaiaDoAdd(){
  var sel=(document.getElementById('add-act-sel')||{}).value||'';
  var newAct=((document.getElementById('add-act-new')||{}).value||'').trim();
  var act=newAct||sel;
  var asp=((document.getElementById('add-asp')||{}).value||'').trim();
  if(!act||!asp){alert('Activity and Aspect are required');return;}
  var sc=Math.min(5,Math.max(1,parseInt((document.getElementById('add-sc')||{}).value)||2));
  var sv=Math.min(5,Math.max(1,parseInt((document.getElementById('add-sv')||{}).value)||2));
  var pr=Math.min(5,Math.max(1,parseInt((document.getElementById('add-pr')||{}).value)||2));
  var du=Math.min(5,Math.max(1,parseInt((document.getElementById('add-du')||{}).value)||2));
  var de=Math.min(5,Math.max(1,parseInt((document.getElementById('add-de')||{}).value)||2));
  var maxId=EAIA_DATA.reduce(function(m,r){return Math.max(m,r.id);},0);
  EAIA_DATA.push({
    id:maxId+1, activity:act, aspect:asp,
    impact:((document.getElementById('add-imp')||{}).value||'').trim(),
    cond:(document.getElementById('add-cond')||{}).value||'N',
    lc:(document.getElementById('add-lc')||{}).value||'N',
    ipc:(document.getElementById('add-ipc')||{}).value||'N',
    bc:(document.getElementById('add-bc')||{}).value||'N',
    rcp:(document.getElementById('add-rcp')||{}).value||'N',
    sc:sc,sv:sv,pr:pr,du:du,de:de,
    ctrl1:((document.getElementById('add-ctrl1')||{}).value||'').trim(),
    gap:((document.getElementById('add-gap')||{}).value||'').trim(),
    ctrl2:((document.getElementById('add-ctrl2')||{}).value||'').trim(),
    auth:((document.getElementById('add-auth')||{}).value||'Site In-charge / Site Supervisor').trim(),
    rsc:sc,rsv:sv,rpr:pr,rdu:du,rde:de,
    ocp:document.getElementById('add-ocp')?document.getElementById('add-ocp').checked:false
  });
  eaiaSave();
  document.getElementById('eaia-add-modal').style.display='none';
  ['add-act-sel','add-act-new','add-asp','add-imp','add-ctrl1','add-gap','add-ctrl2','add-auth'].forEach(function(id){var el=document.getElementById(id);if(el)el.value='';});
  ['add-sc','add-sv','add-pr','add-du','add-de'].forEach(function(id){var el=document.getElementById(id);if(el)el.value=2;});
  var ocp=document.getElementById('add-ocp');if(ocp)ocp.checked=false;
  eaiaAddScoreUpdate();
  eaiaRender();
  if(typeof acToast==='function') acToast('Entry added successfully');
}

