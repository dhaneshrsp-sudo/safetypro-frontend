function eaiaMatrixRender(){
  eaiaLoad();
  var container = document.getElementById('eaia-matrix-content');
  if(!container) return;

  // Get unique activities
  var acts = [];
  var seen = {};
  EAIA_DATA.forEach(function(r){ if(!seen[r.activity]){seen[r.activity]=1;acts.push(r.activity);} });

  // Score bands
  var bands = [{label:'Low (1–15)',min:0,max:15,color:'#166534',bg:'rgba(34,197,94,.15)',border:'rgba(34,197,94,.3)'},
               {label:'Moderate (16–35)',min:16,max:35,color:'#92400E',bg:'rgba(245,158,11,.15)',border:'rgba(245,158,11,.3)'},
               {label:'Significant (≥36)',min:36,max:999,color:'#991B1B',bg:'rgba(239,68,68,.15)',border:'rgba(239,68,68,.3)'}];

  // Build grid
  var colW = 28;
  var actW = 210;
  var totalW = actW + bands.length * (colW * 5) + 10;

  var html = '<table style="border-collapse:collapse;font-size:9px;min-width:'+totalW+'px;">';
  // Header
  html += '<thead><tr>';
  html += '<th style="padding:6px 10px;background:var(--raised);color:var(--t3);font-size:8px;text-transform:uppercase;letter-spacing:.4px;text-align:left;border-bottom:0.5px solid var(--border);width:'+actW+'px;">Activity</th>';
  html += '<th style="padding:6px 8px;background:rgba(34,197,94,.08);color:#22C55E;font-size:8px;text-transform:uppercase;letter-spacing:.4px;text-align:center;border-bottom:0.5px solid var(--border);" colspan="2">Low (1–15)</th>';
  html += '<th style="padding:6px 8px;background:rgba(245,158,11,.08);color:#F59E0B;font-size:8px;text-transform:uppercase;letter-spacing:.4px;text-align:center;border-bottom:0.5px solid var(--border);" colspan="2">Moderate (16–35)</th>';
  html += '<th style="padding:6px 8px;background:rgba(239,68,68,.08);color:#F87171;font-size:8px;text-transform:uppercase;letter-spacing:.4px;text-align:center;border-bottom:0.5px solid var(--border);" colspan="3">Significant (≥36)</th>';
  html += '<th style="padding:6px 8px;background:var(--raised);color:var(--t3);font-size:8px;text-transform:uppercase;letter-spacing:.4px;text-align:center;border-bottom:0.5px solid var(--border);" colspan="2">Residual</th>';
  html += '</tr>';
  html += '<tr>';
  html += '<th style="padding:4px 10px;background:var(--raised);color:var(--t3);font-size:7.5px;border-bottom:0.5px solid var(--border);text-align:left;">Construction Activity</th>';
  ['N','A','N','A','N','A','E','Init.S','Res.S'].forEach(function(label,i){
    var bgs = ['rgba(34,197,94,.05)','rgba(34,197,94,.05)','rgba(245,158,11,.05)','rgba(245,158,11,.05)','rgba(239,68,68,.05)','rgba(239,68,68,.05)','rgba(239,68,68,.05)','rgba(99,102,241,.05)','rgba(99,102,241,.05)'];
    html += '<th style="padding:4px 6px;background:'+bgs[i]+';color:var(--t3);font-size:7px;text-transform:uppercase;border-bottom:0.5px solid var(--border);text-align:center;min-width:48px;">'+label+'</th>';
  });
  html += '</tr></thead><tbody>';

  // Rows
  acts.forEach(function(act, ai){
    var rows = EAIA_DATA.filter(function(r){return r.activity===act;});
    var bg = ai%2===0?'transparent':'rgba(255,255,255,.01)';

    // Count by band × condition
    function count(minS, maxS, cond, useResidual){
      return rows.filter(function(r){
        var s = useResidual ? (r.rsc||r.sc)*(r.rsv||r.sv)*(r.rpr||r.pr)*(r.rdu||r.du)*(r.rde||r.de) : r.sc*r.sv*r.pr*r.du*r.de;
        return s>=minS && s<=maxS && (cond==='ALL'||r.cond===cond);
      }).length;
    }

    function cell(n, bgColor){
      if(n===0) return '<td style="padding:5px 6px;text-align:center;background:'+bg+';border-bottom:0.5px solid rgba(255,255,255,.03);color:var(--t4);">—</td>';
      return '<td style="padding:5px 6px;text-align:center;background:'+bgColor+';border-bottom:0.5px solid rgba(255,255,255,.03);font-weight:700;color:inherit;">'+n+'</td>';
    }

    var totalSig = rows.filter(function(r){return r.sc*r.sv*r.pr*r.du*r.de>=36;}).length;
    var totalResSig = rows.filter(function(r){return (r.rsc||r.sc)*(r.rsv||r.sv)*(r.rpr||r.pr)*(r.rdu||r.du)*(r.rde||r.de)>=36;}).length;

    html += '<tr style="background:'+bg+';">';
    html += '<td style="padding:5px 10px;color:var(--t2);font-size:9px;border-bottom:0.5px solid rgba(255,255,255,.03);">'+act+'</td>';
    // Low N, Low A
    html += cell(count(0,15,'N',false), 'rgba(34,197,94,.08)');
    html += cell(count(0,15,'A',false), 'rgba(34,197,94,.06)');
    // Mod N, Mod A
    html += cell(count(16,35,'N',false), 'rgba(245,158,11,.1)');
    html += cell(count(16,35,'A',false), 'rgba(245,158,11,.07)');
    // Sig N, A, E
    html += cell(count(36,999,'N',false), 'rgba(239,68,68,.12)');
    html += cell(count(36,999,'A',false), 'rgba(239,68,68,.1)');
    html += cell(count(36,999,'E',false), 'rgba(239,68,68,.15)');
    // Residual sig
    html += cell(totalSig, totalSig>0?'rgba(239,68,68,.1)':bg);
    html += cell(totalResSig, totalResSig>0?'rgba(245,158,11,.1)':bg);
    html += '</tr>';
  });

  html += '</tbody></table>';
  container.innerHTML = html;
}

function eaiaAnalysisRender(){
  eaiaLoad();

  // ── Stats ──
  var statsEl = document.getElementById('eaia-analysis-stats');
  var total = EAIA_DATA.length;
  var sig = EAIA_DATA.filter(function(r){return r.sc*r.sv*r.pr*r.du*r.de>=36;}).length;
  var ns = total - sig;
  var resStillSig = EAIA_DATA.filter(function(r){return (r.rsc||r.sc)*(r.rsv||r.sv)*(r.rpr||r.pr)*(r.rdu||r.du)*(r.rde||r.de)>=36;}).length;
  var gapCount = EAIA_DATA.filter(function(r){return r.gap&&r.gap.trim()&&r.gap!=='----';}).length;

  if(statsEl) statsEl.innerHTML = [
    ['96 Total','Total aspects in register','var(--t1)'],
    [sig+' Significant','Score &ge; 36','#EF4444'],
    [resStillSig+' Residual Sig.','After controls applied','#F59E0B'],
    [gapCount+' Control Gaps','Gaps identified','#A78BFA']
  ].map(function(d){
    return '<div class="card" style="padding:10px;text-align:center;">'
      +'<div style="font-size:22px;font-weight:700;color:'+d[2]+';">'+d[0]+'</div>'
      +'<div style="font-size:9px;color:var(--t3);margin-top:2px;">'+d[1]+'</div>'
    +'</div>';
  }).join('');

  // ── Chart helper — horizontal bar ──
  function barChart(el, data, maxVal){
    if(!el) return;
    el.innerHTML = data.map(function(d){
      var pct = maxVal>0 ? Math.round(d.val/maxVal*100) : 0;
      return '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">'
        +'<div style="width:140px;font-size:9px;color:var(--t2);flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="'+d.label+'">'+d.label+'</div>'
        +'<div style="flex:1;background:rgba(255,255,255,.05);border-radius:3px;height:14px;overflow:hidden;">'
          +'<div style="height:14px;width:'+pct+'%;background:'+d.color+';border-radius:3px;transition:width .3s;min-width:'+(d.val>0?'4px':'0')+'"></div>'
        +'</div>'
        +'<div style="width:24px;font-size:9px;font-weight:600;color:'+d.color+';">'+d.val+'</div>'
      +'</div>';
    }).join('');
  }

  // Chart 1: Sig aspects by activity
  var actSig = {};
  EAIA_DATA.forEach(function(r){
    if(r.sc*r.sv*r.pr*r.du*r.de>=36){
      actSig[r.activity] = (actSig[r.activity]||0)+1;
    }
  });
  var actData = Object.keys(actSig).sort(function(a,b){return actSig[b]-actSig[a];}).map(function(k){
    return {label:k, val:actSig[k], color:'#EF4444'};
  });
  var maxAct = actData.length>0?actData[0].val:1;
  barChart(document.getElementById('eaia-chart-activity'), actData, maxAct);

  // Chart 2: By condition
  var conds = {N:0,A:0,E:0};
  EAIA_DATA.forEach(function(r){conds[r.cond]=(conds[r.cond]||0)+1;});
  barChart(document.getElementById('eaia-chart-cond'), [
    {label:'Normal (N)',val:conds.N||0,color:'#22C55E'},
    {label:'Abnormal (A)',val:conds.A||0,color:'#F59E0B'},
    {label:'Emergency (E)',val:conds.E||0,color:'#EF4444'}
  ], total);

  // Chart 3: Score distribution
  var bands = [{label:'Score 1–15 (Low)',min:0,max:15,color:'#22C55E'},
               {label:'Score 16–35 (Moderate)',min:16,max:35,color:'#F59E0B'},
               {label:'Score 36–48 (Significant)',min:36,max:48,color:'#EF4444'},
               {label:'Score >48 (High Sig.)',min:49,max:999,color:'#DC2626'}];
  var scoreData = bands.map(function(b){
    return {label:b.label, val:EAIA_DATA.filter(function(r){var s=r.sc*r.sv*r.pr*r.du*r.de;return s>=b.min&&s<=b.max;}).length, color:b.color};
  });
  barChart(document.getElementById('eaia-chart-score'), scoreData, total);

  // Chart 4: Legal criteria
  var lcCounts = {LC:0,IPC:0,BC:0,RCP:0};
  EAIA_DATA.forEach(function(r){
    if(r.lc==='Y') lcCounts.LC++;
    if(r.ipc==='Y') lcCounts.IPC++;
    if(r.bc==='Y') lcCounts.BC++;
    if(r.rcp==='Y') lcCounts.RCP++;
  });
  var legalMax = Math.max(lcCounts.LC,lcCounts.IPC,lcCounts.BC,lcCounts.RCP,1);
  barChart(document.getElementById('eaia-chart-legal'), [
    {label:'LC — Legal Compliance',val:lcCounts.LC,color:'#60A5FA'},
    {label:'IPC — Interested Party Concern',val:lcCounts.IPC,color:'#A78BFA'},
    {label:'BC — Binding Commitment',val:lcCounts.BC,color:'#F59E0B'},
    {label:'RCP — Reg. Compliance Potential',val:lcCounts.RCP,color:'#22C55E'}
  ], legalMax);
}

function eaiaOCPRender(){
  eaiaLoad();
  var filter = (document.getElementById('ocp-filter')||{}).value||'ALL';
  var tbody = document.getElementById('eaia-ocp-tbody');
  if(!tbody) return;

  var sigRows = EAIA_DATA.filter(function(r){return r.sc*r.sv*r.pr*r.du*r.de>=36;});
  var gapRows = sigRows.filter(function(r){return r.gap&&r.gap.trim()&&r.gap!=='----';});

  var el1=document.getElementById('ocp-sig-count'); if(el1) el1.textContent=sigRows.length+' Significant';
  var el2=document.getElementById('ocp-gap-count'); if(el2) el2.textContent=gapRows.length+' with Gaps';

  var filtered = sigRows.filter(function(r){
    var hasGap = r.gap&&r.gap.trim()&&r.gap!=='----';
    var hasCtrl = r.ctrl2&&r.ctrl2.trim()&&r.ctrl2!=='----';
    if(filter==='GAP') return hasGap;
    if(filter==='OCP') return r.ocp;
    if(filter==='COMPLETE') return hasCtrl && !hasGap;
    return true;
  });

  tbody.innerHTML = filtered.map(function(r,i){
    var score = r.sc*r.sv*r.pr*r.du*r.de;
    var resScore = (r.rsc||r.sc)*(r.rsv||r.sv)*(r.rpr||r.pr)*(r.rdu||r.du)*(r.rde||r.de);
    var hasGap = r.gap&&r.gap.trim()&&r.gap!=='----';
    var condColor = r.cond==='E'?'#F87171':r.cond==='A'?'#F59E0B':'#22C55E';
    var rowBg = hasGap?'background:rgba(245,158,11,.04);border-left:2px solid #F59E0B;':'border-left:2px solid #EF4444;';
    return '<div style="display:grid;grid-template-columns:28px 140px 140px 50px 50px 50px 1fr 1fr 1fr 110px;border-bottom:0.5px solid var(--border);align-items:start;'+rowBg+'">'
      +'<div style="padding:7px 4px;color:var(--t3);font-size:9px;">'+(i+1)+'</div>'
      +'<div style="padding:7px 6px;font-size:9px;font-weight:500;color:var(--t1);line-height:1.3;">'+r.activity+'</div>'
      +'<div style="padding:7px 6px;font-size:9px;color:var(--t2);line-height:1.3;">'+r.aspect+'<br><span style="font-size:8px;color:var(--t3);">'+r.impact+'</span></div>'
      +'<div style="padding:7px 4px;text-align:center;font-size:14px;font-weight:700;color:#EF4444;">'+score+'</div>'
      +'<div style="padding:7px 4px;text-align:center;font-size:12px;font-weight:700;color:'+(resScore>=36?'#F59E0B':'#22C55E')+';">'+resScore+'</div>'
      +'<div style="padding:7px 4px;text-align:center;">'+(r.ocp?'<span style="background:rgba(239,68,68,.1);border:0.5px solid rgba(239,68,68,.25);color:#F87171;padding:2px 6px;border-radius:3px;font-size:8px;font-weight:700;">OCP</span>':'<span style="color:var(--t4);font-size:9px;">—</span>')+'</div>'
      +'<div style="padding:7px 6px;font-size:9px;color:var(--t2);line-height:1.4;">'+r.ctrl1+'</div>'
      +'<div style="padding:7px 6px;font-size:9px;color:'+(hasGap?'#F59E0B':'var(--t4)')+';line-height:1.4;font-weight:'+(hasGap?'600':'400')+';">'+(hasGap?r.gap:'—')+'</div>'
      +'<div style="padding:7px 6px;font-size:9px;color:var(--t2);line-height:1.4;">'+r.ctrl2+'</div>'
      +'<div style="padding:7px 6px;font-size:9px;color:var(--t3);line-height:1.4;">'+r.auth+'</div>'
    +'</div>';
  }).join('')||'<div style="padding:20px;text-align:center;color:var(--t3);font-size:11px;">No entries match the filter</div>';
}

