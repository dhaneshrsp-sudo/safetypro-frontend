<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SafetyPro AI — AI-native HSE intelligence, built by HSE professionals</title>
<meta name="description" content="The AI-native HSE platform for construction and high-risk industries. Paperless, predictive, biometric-ready. Setup in 1 day, not 1 year."/>
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta property="og:title" content="SafetyPro AI — AI-native HSE intelligence"/>
<meta property="og:description" content="Real-time HSE intelligence, redefined by HSE professionals."/>
<meta property="og:type" content="website"/>
<meta name="twitter:card" content="summary_large_image"/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cpath d='M16 2L4 7v9c0 7 5.3 12.7 12 14 6.7-1.3 12-7 12-14V7L16 2z' fill='%2322c55e'/%3E%3C/svg%3E">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
:root{--bg:#04060E;--bg-2:#06090F;--surface:#0A101E;--surface-2:#0D1422;--surface-3:#101827;--border:rgba(255,255,255,.08);--border-2:rgba(255,255,255,.14);--text:#fff;--text-2:rgba(255,255,255,.65);--text-3:rgba(255,255,255,.42);--green:#22c55e;--green-2:#86efac;--gold:#E4C87A;--gold-2:#C9A84C;--purple:#8b5cf6;--blue:#60a5fa;--danger:#ef4444;--warn:#f59e0b;--max:1280px}
body{background:var(--bg);color:var(--text);font-family:'Inter',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;font-size:15px;line-height:1.6;overflow-x:hidden;font-weight:400;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4{font-family:'Montserrat',sans-serif;font-weight:500;letter-spacing:-.025em;line-height:1.1}
h1{font-size:clamp(36px,6vw,64px);letter-spacing:-.035em}
h2{font-size:clamp(26px,3.6vw,40px)}
h3{font-size:clamp(17px,2vw,20px)}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}
.mono{font-family:'JetBrains Mono',monospace}
.container{max-width:var(--max);margin:0 auto;padding:0 32px}
.italic{font-style:italic;font-family:'Montserrat',sans-serif}
.grad-green{background:linear-gradient(135deg,#22c55e,#86efac);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.grad-gold{background:linear-gradient(135deg,#E4C87A,#F5D98F);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.grid-bg{background-image:linear-gradient(rgba(255,255,255,.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.015) 1px,transparent 1px);background-size:48px 48px}
.fade-in{opacity:0;transform:translateY(20px);transition:opacity .7s ease,transform .7s ease}
.fade-in.vis{opacity:1;transform:translateY(0)}

/* NAV */
.nav{position:sticky;top:0;z-index:100;background:rgba(4,6,14,.78);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);border-bottom:1px solid var(--border)}
.nav-inner{max-width:var(--max);margin:0 auto;padding:14px 32px;display:flex;align-items:center;justify-content:space-between;gap:24px}
.logo{display:flex;align-items:center;gap:10px;font-weight:500;font-size:15px}
.logo svg{width:30px;height:30px}
.logo .ai{background:linear-gradient(135deg,#22c55e,#86efac);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-weight:600}
.nav-links{display:flex;gap:26px;font-size:13.5px;color:var(--text-2)}
.nav-links a{transition:color .2s}
.nav-links a:hover{color:var(--text)}
.nav-links .biometric{display:inline-flex;align-items:center;gap:6px;color:var(--text)}
.nav-links .biometric .dot{width:5px;height:5px;background:var(--gold-2);border-radius:50%;box-shadow:0 0 10px var(--gold-2);animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(.85)}}
.nav-cta{display:flex;gap:10px;align-items:center}
.nav-cta .signin{font-size:13.5px;color:var(--text-2);transition:color .2s}
.nav-cta .signin:hover{color:var(--text)}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:9px 16px;border-radius:8px;font-weight:500;font-size:13px;cursor:pointer;transition:all .25s;border:none;font-family:inherit;white-space:nowrap}
.btn-primary{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;box-shadow:0 10px 28px -8px rgba(34,197,94,.55),inset 0 1px 0 rgba(255,255,255,.2)}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 14px 32px -6px rgba(34,197,94,.7),inset 0 1px 0 rgba(255,255,255,.2)}
.btn-ghost{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:#fff}
.btn-ghost:hover{background:rgba(255,255,255,.1)}
.btn-outline{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.15);color:#fff}
.btn-outline:hover{background:rgba(255,255,255,.08)}
.btn-lg{padding:12px 20px;font-size:13.5px;border-radius:10px}
.menu-toggle{display:none;background:none;border:none;color:#fff;cursor:pointer;width:32px;height:32px;font-size:20px}

/* HERO */
.hero{position:relative;padding:64px 0 40px;overflow:hidden}
.hero::before{content:"";position:absolute;top:40px;right:-140px;width:720px;height:620px;background:radial-gradient(circle,rgba(34,197,94,.3) 0%,rgba(34,197,94,.08) 30%,transparent 70%);filter:blur(60px);z-index:0;pointer-events:none}
.hero::after{content:"";position:absolute;top:200px;right:120px;width:460px;height:360px;background:radial-gradient(circle,rgba(201,168,76,.22) 0%,rgba(201,168,76,.06) 40%,transparent 70%);filter:blur(70px);z-index:0;pointer-events:none}
.hero-bg-purple{position:absolute;top:-80px;left:-60px;width:380px;height:380px;background:radial-gradient(circle,rgba(139,92,246,.18) 0%,transparent 70%);filter:blur(50px);z-index:0;pointer-events:none}
.hero-inner{position:relative;z-index:2;display:grid;grid-template-columns:5fr 6.5fr;gap:48px;align-items:center}
.hero-copy .badge{display:inline-flex;align-items:center;gap:7px;padding:5px 11px;background:linear-gradient(135deg,rgba(201,168,76,.14),rgba(201,168,76,.04));color:var(--gold);font-size:11px;letter-spacing:.7px;text-transform:uppercase;font-weight:500;border-radius:100px;margin-bottom:22px;border:1px solid rgba(201,168,76,.22)}
.badge .dot{width:5px;height:5px;background:var(--gold);border-radius:50%;box-shadow:0 0 10px var(--gold-2);animation:pulse 2s ease-in-out infinite}
.hero-copy h1{margin-bottom:18px;color:#fff}
.hero-copy .sub{font-size:16.5px;color:var(--text-2);line-height:1.55;margin-bottom:26px;max-width:480px}
.hero-ctas{display:flex;gap:10px;margin-bottom:22px;flex-wrap:wrap}
.trust-line{display:flex;gap:18px;flex-wrap:wrap;font-size:12px;color:var(--text-3)}
.trust-line span{display:flex;align-items:center;gap:6px}
.trust-line span::before{content:"";width:4px;height:4px;background:var(--green);border-radius:50%}

/* Hero dashboard — BIGGER, DENSER, REALISTIC */
.hero-visual{position:relative;perspective:2000px}
.dash-glow{position:absolute;bottom:-40px;left:20px;right:20px;height:60px;background:radial-gradient(ellipse at center,rgba(34,197,94,.55),transparent 70%);filter:blur(30px);pointer-events:none}
.dash{transform:rotateY(-8deg) rotateX(4deg);background:var(--surface);border:1px solid rgba(255,255,255,.08);border-radius:12px;overflow:hidden;box-shadow:0 40px 90px -24px rgba(0,0,0,.85),0 0 0 1px rgba(255,255,255,.04);transform-style:preserve-3d}
.dash-chrome{padding:9px 14px;border-bottom:1px solid rgba(255,255,255,.05);background:linear-gradient(180deg,#0E1628,#0A101E);display:flex;align-items:center;gap:10px}
.dash-chrome .dots{display:flex;gap:5px}
.dash-chrome .dots span{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.14)}
.dash-chrome .url{flex:1;max-width:240px;padding:3px 10px;background:rgba(255,255,255,.04);border-radius:4px;font-size:10px;color:var(--text-3);margin-left:8px;font-family:'JetBrains Mono',monospace}
.dash-chrome .live{margin-left:auto;display:flex;align-items:center;gap:5px;font-size:10px;color:var(--green);font-weight:500}
.dash-chrome .live::before{content:"";width:6px;height:6px;background:var(--green);border-radius:50%;box-shadow:0 0 8px var(--green);animation:pulse 1.5s infinite}
.dash-topnav{padding:10px 14px;border-bottom:1px solid rgba(255,255,255,.05);background:rgba(255,255,255,.015);display:flex;align-items:center;gap:16px;font-size:11px;color:var(--text-2)}
.dash-topnav .nav-it{padding:3px 8px;border-radius:4px;display:flex;align-items:center;gap:5px}
.dash-topnav .nav-it.ac{background:rgba(34,197,94,.12);color:var(--green);font-weight:500}
.dash-body{display:grid;grid-template-columns:60px 1fr;min-height:320px}
.dash-sb{padding:10px 6px;border-right:1px solid rgba(255,255,255,.04);background:linear-gradient(180deg,#080E1C,#060B18)}
.dash-sb .item{padding:5px 4px;margin-bottom:5px;display:flex;align-items:center;gap:5px}
.dash-sb .item .ic{width:13px;height:13px;border-radius:3px;background:rgba(255,255,255,.1);flex-shrink:0}
.dash-sb .active{background:linear-gradient(90deg,rgba(34,197,94,.15),transparent);border-left:2px solid var(--green);margin-left:-6px;padding-left:8px}
.dash-sb .active .ic{background:var(--green)}
.dash-sb .more-label{padding:4px;margin:8px 0 4px;border-top:1px dashed rgba(255,255,255,.08);color:rgba(255,255,255,.3);font-size:8px;letter-spacing:.6px;font-weight:500;text-align:center}
.dash-content{padding:14px}
.dash-row{display:grid;gap:8px;margin-bottom:8px}
.dash-row.r5{grid-template-columns:1.2fr 1fr 1fr 1fr 1fr}
.dash-row.r2-6{grid-template-columns:2fr 3fr}
.kpi{padding:10px 11px;background:linear-gradient(135deg,var(--surface-2),#091020);border:1px solid rgba(255,255,255,.05);border-radius:7px;position:relative;overflow:hidden}
.kpi.hl-green{border-color:rgba(34,197,94,.22)}
.kpi.hl-green::before{content:"";position:absolute;top:0;right:0;width:50px;height:50px;background:radial-gradient(circle at top right,rgba(34,197,94,.2),transparent 70%)}
.kpi.hl-gold{border-color:rgba(201,168,76,.22)}
.kpi.hl-gold::before{content:"";position:absolute;top:0;right:0;width:50px;height:50px;background:radial-gradient(circle at top right,rgba(201,168,76,.18),transparent 70%)}
.kpi-l{font-size:8.5px;color:var(--text-3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;font-weight:500}
.kpi-v{font-size:20px;font-weight:300;line-height:1;letter-spacing:-.03em}
.kpi-d{font-size:9px;color:var(--text-3);margin-top:3px;display:flex;align-items:center;gap:3px}
.kpi-d .up{color:var(--green-2)}
.panel{background:var(--surface-2);border:1px solid rgba(255,255,255,.05);border-radius:7px;padding:10px 12px}
.panel h5{font-size:9.5px;color:var(--text-3);text-transform:uppercase;letter-spacing:.5px;font-weight:500;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center}
.panel h5 .up{color:var(--green-2);font-weight:500;text-transform:none;letter-spacing:normal}
.activity-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:10px}
.activity-row:last-child{border:0}
.av{width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8.5px;font-weight:600;flex-shrink:0}
.av.g{background:rgba(34,197,94,.2);color:#86efac}
.av.b{background:rgba(96,165,250,.2);color:#60a5fa}
.av.a{background:rgba(245,158,11,.2);color:#fcd34d}
.av.p{background:rgba(139,92,246,.2);color:#c4b5fd}
.activity-row .name{color:var(--text);font-weight:500}
.activity-row .meta{color:var(--text-3);font-size:9px;margin-left:auto}
.activity-row .st{padding:1px 6px;font-size:8.5px;border-radius:3px;font-weight:500}
.st.ok{background:rgba(34,197,94,.15);color:var(--green-2)}
.st.pend{background:rgba(245,158,11,.15);color:#fcd34d}

/* STATS BAND */
.stats{position:relative;z-index:3;border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:rgba(255,255,255,.012);margin-top:32px}
.stats-inner{max-width:var(--max);margin:0 auto;padding:26px 32px;display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
.stat .val{font-size:28px;font-weight:300;color:#fff;margin-bottom:4px;letter-spacing:-.03em}
.stat .val small{font-size:16px;color:var(--text-3)}
.stat .label{font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.8px;font-weight:500}

/* Section base */
section{padding:64px 0;position:relative}
.sec-head{text-align:center;margin-bottom:40px;max-width:700px;margin-left:auto;margin-right:auto}
.sec-eyebrow{display:inline-block;padding:4px 11px;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--text-2);font-size:10.5px;text-transform:uppercase;letter-spacing:.8px;font-weight:500;border-radius:100px;margin-bottom:14px}
.sec-head h2{margin-bottom:12px;color:#fff}
.sec-head p{color:var(--text-2);font-size:15.5px;line-height:1.6}

/* PROBLEM */
.prob-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.prob-card{padding:24px 22px;background:var(--surface);border:1px solid var(--border);border-radius:12px;transition:all .3s}
.prob-card:hover{border-color:var(--border-2);transform:translateY(-2px);background:var(--surface-2)}
.prob-icon{width:40px;height:40px;border-radius:9px;display:flex;align-items:center;justify-content:center;margin-bottom:16px}
.prob-icon.red{background:rgba(239,68,68,.12);color:#fca5a5}
.prob-icon.amber{background:rgba(245,158,11,.12);color:#fcd34d}
.prob-icon.blue{background:rgba(59,130,246,.12);color:#93c5fd}
.prob-card h3{color:#fff;margin-bottom:8px;font-size:17px}
.prob-card p{color:var(--text-2);font-size:13.5px;line-height:1.6}

/* PRODUCT TOUR */
.tour{background:linear-gradient(180deg,transparent,rgba(34,197,94,.012),transparent)}
.tour-tabs{display:flex;gap:6px;justify-content:center;margin-bottom:28px;flex-wrap:wrap}
.tour-tab{padding:7px 14px;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--text-2);font-size:12.5px;border-radius:100px;cursor:pointer;transition:all .2s;font-family:inherit;font-weight:500}
.tour-tab:hover{border-color:var(--border-2);color:var(--text)}
.tour-tab.active{background:#fff;color:#04060E;border-color:#fff}
.tour-view{position:relative;padding:28px;background:linear-gradient(180deg,var(--surface-2),var(--surface));border:1px solid var(--border);border-radius:18px;overflow:hidden}
.tour-view::before{content:"";position:absolute;top:-60px;right:-60px;width:400px;height:400px;background:radial-gradient(circle,rgba(34,197,94,.1),transparent 70%);filter:blur(50px)}
.tour-content{position:relative;z-index:2;display:grid;grid-template-columns:1fr 1.4fr;gap:32px;align-items:center}
.tour-left h3{color:#fff;margin-bottom:12px;font-size:22px}
.tour-left p{color:var(--text-2);font-size:14.5px;line-height:1.6;margin-bottom:18px}
.tour-left ul{list-style:none;display:flex;flex-direction:column;gap:9px}
.tour-left li{color:var(--text-2);font-size:13.5px;display:flex;gap:10px;align-items:flex-start}
.tour-left li::before{content:"";min-width:6px;height:6px;margin-top:7px;background:var(--green);border-radius:50%;box-shadow:0 0 6px rgba(34,197,94,.5)}
.tour-mock{background:var(--bg-2);border:1px solid var(--border);border-radius:10px;padding:14px;overflow:hidden;position:relative;min-height:300px}

/* AI section */
.ai-sec{background:linear-gradient(180deg,transparent,rgba(139,92,246,.015),transparent)}
.ai-layout{display:grid;grid-template-columns:1fr 1fr;gap:28px;align-items:stretch}
.ai-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
.ai-card{padding:22px;background:var(--surface);border:1px solid var(--border);border-radius:12px;position:relative;overflow:hidden;transition:all .3s}
.ai-card::before{content:"";position:absolute;top:-40px;right:-40px;width:140px;height:140px;background:radial-gradient(circle,rgba(34,197,94,.1),transparent 70%);filter:blur(30px);opacity:0;transition:opacity .3s}
.ai-card:hover{border-color:rgba(34,197,94,.25);transform:translateY(-2px)}
.ai-card:hover::before{opacity:1}
.ai-eyebrow{font-size:10.5px;color:var(--green);text-transform:uppercase;letter-spacing:.8px;font-weight:600;margin-bottom:10px;display:flex;align-items:center;gap:8px}
.ai-eyebrow::before{content:"";width:14px;height:1px;background:var(--green)}
.ai-card h3{color:#fff;margin-bottom:8px;font-size:17px}
.ai-card p{color:var(--text-2);font-size:13px;line-height:1.55}
.ai-live{padding:24px;background:linear-gradient(180deg,var(--surface-2),var(--surface));border:1px solid var(--border);border-radius:14px;position:relative;overflow:hidden;display:flex;flex-direction:column}
.ai-live::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at top right,rgba(139,92,246,.12),transparent 60%);pointer-events:none}
.ai-live-head{position:relative;z-index:2;display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;padding-bottom:12px;border-bottom:1px solid var(--border)}
.ai-live-head .t{font-size:12px;color:var(--text-3);text-transform:uppercase;letter-spacing:.6px;font-weight:500;display:flex;align-items:center;gap:7px}
.ai-live-head .t::before{content:"";width:6px;height:6px;background:var(--purple);border-radius:50%;box-shadow:0 0 8px var(--purple);animation:pulse 1.8s infinite}
.ai-live-head .time{font-size:10px;color:var(--text-3);font-family:'JetBrains Mono',monospace}
.ai-pred{position:relative;z-index:2;padding:12px;background:rgba(139,92,246,.05);border:1px solid rgba(139,92,246,.15);border-radius:8px;margin-bottom:10px}
.ai-pred-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.ai-pred-head .ttl{font-size:13px;font-weight:500;color:#fff}
.ai-pred-conf{display:flex;align-items:center;gap:5px;font-size:10px;color:#c4b5fd;font-family:'JetBrains Mono',monospace}
.ai-pred p{font-size:12px;color:var(--text-2);line-height:1.55;margin-bottom:8px}
.ai-pred-meta{display:flex;gap:12px;font-size:10px;color:var(--text-3)}
.ai-pred-meta span{display:flex;align-items:center;gap:4px}
.ai-pred-meta .dot-d{width:4px;height:4px;background:var(--danger);border-radius:50%}
.ai-pred-meta .dot-a{width:4px;height:4px;background:var(--warn);border-radius:50%}

/* STANDARDS ROW - new trust section */
.standards{padding:36px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:rgba(255,255,255,.012)}
.standards-inner{max-width:var(--max);margin:0 auto;padding:0 32px;display:flex;align-items:center;gap:32px;flex-wrap:wrap;justify-content:center}
.standards-label{font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.8px;font-weight:500}
.standards-badges{display:flex;gap:20px;flex-wrap:wrap;align-items:center}
.std-badge{padding:6px 14px;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:100px;font-size:12px;color:var(--text-2);font-weight:500;transition:all .3s}
.std-badge:hover{border-color:var(--border-2);color:var(--text);background:rgba(255,255,255,.06)}

/* REGIONS */
.regions{background:linear-gradient(180deg,transparent,rgba(34,197,94,.012),transparent)}
.regions-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.region-card{padding:18px;background:var(--surface);border:1px solid var(--border);border-radius:10px;transition:all .3s}
.region-card:hover{border-color:var(--border-2);transform:translateY(-2px);background:var(--surface-2)}
.region-head{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.region-head img{width:24px;height:17px;border-radius:3px;border:1px solid rgba(255,255,255,.1);object-fit:cover}
.region-head .name{font-size:13.5px;font-weight:500;color:#fff}
.region-regs{font-size:11.5px;color:var(--text-2);line-height:1.6}

/* COMPLIANCE */
.comp-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;max-width:1000px;margin:0 auto}
.comp-badge{padding:13px 10px;background:var(--surface);border:1px solid var(--border);border-radius:10px;text-align:center;font-size:12.5px;font-weight:500;color:#fff;transition:all .3s}
.comp-badge:hover{border-color:var(--border-2);background:var(--surface-2);transform:translateY(-2px)}
