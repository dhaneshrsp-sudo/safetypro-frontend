/* ─── CORE TAB SWITCHER ─── */
window.rptTab = function(el, tabId) {
  /* 1. Update active tab style */
  var scroll = document.getElementById('rpt-tabs-scroll');
  if(scroll) scroll.querySelectorAll('.sh-tab').forEach(function(t){t.classList.remove('active');});
  if(el) el.classList.add('active');

  /* 2. Hide all tab panels */
  var allIds = ['stats','monthly','annual','ncrsummary','inspection','contractor','training',
                'investigation','benchmark','objectives','roi','maturity','regulatory','scheduled',
                'appraisal','trophy','calendar'];
  allIds.forEach(function(id){
    var p = document.getElementById('tab-'+id);
    if(p) p.style.display = id===tabId ? 'block' : 'none';
  });

  /* 3. Render new tab content */
  var renders = {annual:rptRenderAnnual,ncrsummary:rptRenderNCR,inspection:rptRenderInspection,contractor:rptRenderContractor,training:rptRenderTraining,investigation:rptRenderInvestigation,regulatory:rptRenderRegulatory,scheduled:rptRenderScheduled,objectives:rptRenderObjectives};
  if(renders[tabId]) renders[tabId]();

  /* 4. Auto-scroll active tab into view */
  if(scroll && el) {
    var tabLeft = el.offsetLeft;
    var tabWidth = el.offsetWidth;
    var scrollCenter = tabLeft - (scroll.clientWidth/2) + (tabWidth/2);
    scroll.scrollTo({left: Math.max(0, scrollCenter), behavior:'smooth'});
  }

  /* 5. Scroll page to top */
  var main = document.querySelector('.main');
  if(main) main.scrollTop = 0;
};

/* Keep backward compat with old switchTab calls */
window.switchTab = window.rptTab;

