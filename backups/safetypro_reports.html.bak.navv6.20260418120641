<script>
var API_BASE = 'https://safetypro-backend-production.up.railway.app/api/v1';

/* AUTH GUARD */
(function(){
  var token = localStorage.getItem('sp_token');
  if (!token) { window.location.replace('safetypro_login'); return; }
  try { var u = JSON.parse(localStorage.getItem('sp_user')||'{}'); if (u && u.name) applyNavProfile(u); } catch(e){}
  setTimeout(loadNavProfile, 600);
  setTimeout(loadReportsData, 900);
})();

/* API FETCH */
function apiFetch(path, opts) {
  var token = localStorage.getItem('sp_token');
  var options = opts || {};
  options.headers = options.headers || {};
  options.headers['Authorization'] = 'Bearer ' + token;
  if (options.body && !options.headers['Content-Type']) options.headers['Content-Type'] = 'application/json';
  return fetch(API_BASE + path, options);
}

/* LOAD REPORTS DATA */
function loadReportsData() {
  apiFetch('/dashboard/kpis')
  .then(function(r) { if (!r.ok) throw new Error(); return r.json(); })
  .then(function(d) {
    var map = { 'sn1': d.totalIncidents, 'sn2': d.openNCRs, 'sn3': d.auditScore, 'sn4': d.safeActions };
    Object.keys(map).forEach(function(id) {
      var el = document.getElementById(id);
      if (el && map[id] !== undefined) animateNum(el, map[id]);
    });
    var dot = document.getElementById('alert-dot');
    if (dot && d.escalated > 0) dot.style.display = 'block';
  })
  .catch(function(){});
}

/* ANIMATE NUMBER */
function animateNum(el, target) {
  if (!el) return;
  var dur = 1000; var t0 = performance.now();
  function step(now) {
    var p = Math.min((now-t0)/dur,1); var ease = 1-Math.pow(1-p,3);
    el.textContent = Math.round(target * ease);
    if (p < 1) requestAnimationFrame(step); else el.textContent = Math.round(target);
  }
  requestAnimationFrame(step);
}

/* TAB SWITCHING */
function switchTab(el, tabId) {
  document.querySelectorAll('.sh-tab').forEach(function(t){ t.classList.remove('active'); });
  el.classList.add('active');
  var main=document.querySelector('.main');
  if(main){Array.from(main.children).forEach(function(p){if(p.classList.contains('tab-panel')){p.style.display='none';p.classList.remove('active');}});}
  var nestedTabs=['objectives','roi','maturity','calendar'];
  if(nestedTabs.indexOf(tabId)>-1){
    var tr=document.getElementById('tab-trophy');if(tr)tr.style.display='block';
    var tc=document.querySelector('#tab-trophy > .card');if(tc)tc.style.display='none';
    ['tab-objectives','tab-roi','tab-maturity','tab-calendar'].forEach(function(id){var p=document.getElementById(id);if(p)p.style.display='none';});
  }
  if(tabId==='trophy'){var tc2=document.querySelector('#tab-trophy > .card');if(tc2)tc2.style.display='';}
  var target=document.getElementById('tab-'+tabId);
  if(target){target.style.display='block';target.classList.add('active');}
  var activeTab=document.querySelector('.sh-tab.active');
  var shTabs=document.querySelector('.sh-tabs');
  if(activeTab&&shTabs){shTabs.scrollTo({left:activeTab.offsetLeft-(shTabs.offsetWidth/2)+(activeTab.offsetWidth/2),behavior:'smooth'});}
  if(tabId==='objectives')initObjCharts();
  if(tabId==='stats')initStatsCharts();
  if(tabId==='benchmark')initBenchChart();
  if(tabId==='appraisal'){renderApr();renderLb();}
  if(tabId==='trophy')renderLb();
}

/* FILTER OBJECTIVES */
function filterObjectives(status) {
  document.querySelectorAll('.obj-card').forEach(function(card) {
    if (status === 'all' || card.getAttribute('data-status') === status) {
      card.style.display = 'block';
    } else {
      card.style.display = 'none';
    }
  });
}

/* EVIDENCE UPLOAD */
function handleEvidenceUpload(input, objId) {
  if (!input.files || !input.files.length) return;
  var grid = document.getElementById('new-evidence');
  if (!grid) return;
  Array.from(input.files).forEach(function(file) {
    var icon = file.type.indexOf('image') > -1 ? '&#128247;' : file.name.indexOf('.pdf') > -1 ? '&#128196;' : '&#128202;';
    var div = document.createElement('div');
    div.style.cssText = 'display:flex;align-items:center;gap:8px;padding:9px 10px;background:var(--raised);border:1px solid rgba(34,197,94,.2);border-radius:8px;';
    div.innerHTML = '<span style="font-size:18px">' + icon + '</span><div><div style="font-size:10px;font-weight:600;color:var(--t1);font-family:var(--fh);">' + (file.name.length > 20 ? file.name.substring(0,20)+'...' : file.name) + '</div><div style="font-size:9px;color:var(--t3)">Just uploaded</div></div>';
    grid.appendChild(div);
  });
  showObjToast(input.files.length + ' file(s) attached', 'green');
}

/* OBJECTIVES CHARTS */
var objChartsBuilt = false;
function initObjCharts() {
  if (objChartsBuilt) return;
  objChartsBuilt = true;
  var trendCtx = document.getElementById('objTrendChart');
  var targetCtx = document.getElementById('objTargetChart');
  if (trendCtx) {
    try {
      new Chart(trendCtx, {
