<!DOCTYPE html>
<html lang="en">
<head>
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SafetyPro AI — Reports</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Roboto:wght@300;400;500;600&family=Fraunces:wght@400;500&display=swap" rel="stylesheet"/>

<style>
:root{
  --bg:#0B0F14;--card:#131C26;--raised:#16212B;--sidebar:#0F1720;--border:#1E293B;--div:rgba(255,255,255,0.05);
  --green:#22C55E;--g-h:#16A34A;--g-s:rgba(34,197,94,0.12);--g-b:rgba(34,197,94,0.3);
  --amber:#F59E0B;--a-s:rgba(245,158,11,0.12);--a-b:rgba(245,158,11,0.3);
  --red:#EF4444;--r-s:rgba(239,68,68,0.12);--r-b:rgba(239,68,68,0.35);
  --blue:#3B82F6;--b-s:rgba(59,130,246,0.12);--b-b:rgba(59,130,246,0.3);
  --purple:#8B5CF6;--p-s:rgba(139,92,246,0.12);--p-b:rgba(139,92,246,0.3);
  --t1:#E6EDF3;--t2:#94A3B8;--t3:#64748B;
  --fh:'Montserrat',sans-serif;--fb:'Roboto',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{margin:0;padding:0}
body{background:var(--bg);color:var(--t1);font-family:var(--fb);font-size:13px;line-height:1.5;min-height:100vh}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
svg{flex-shrink:0}
.app{display:flex;flex-direction:column;min-height:100vh}

/* NAV */
.topnav{height:52px;flex-shrink:0;background:var(--sidebar);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 0 0 0;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:8px;text-decoration:none;width:195px;flex-shrink:0;padding:0 16px 0 18px;border-right:1px solid var(--border)}
.logo-shield-REPLACED{width:28px;height:28px;background:var(--green);border-radius:6px;display:flex;align-items:center;justify-content:center;box-shadow:0 0 10px rgba(34,197,94,.4)}
.logo-mark svg{width:16px;height:16px;fill:#fff}
.logo-text{font-family:var(--fh);font-size:15px;font-weight:800;color:var(--t1);letter-spacing:-.3px;}
.logo-text span{color:var(--green)}
.nl{display:flex;align-items:center;gap:6px;padding:6px 13px;border-radius:7px;font-size:13px;color:var(--t2);cursor:pointer;transition:all .15s;text-decoration:none}
.nl:hover{color:var(--t1);background:rgba(255,255,255,.04)}
.nl.active{color:var(--t1);font-weight:600}
.nl svg{width:13px;height:13px;fill:currentColor}
.nl .arr{font-size:9px;opacity:.5;margin-left:2px}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:8px;padding-right:20px}
.icon-btn{width:30px;height:30px;border-radius:7px;border:1px solid var(--border);background:var(--card);display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative}
.icon-btn svg{width:14px;height:14px;fill:var(--t2)}
.ndot{position:absolute;top:4px;right:4px;width:6px;height:6px;background:var(--red);border-radius:50%;border:1px solid var(--bg)}
.user-pill{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:5px 10px 5px 5px;cursor:pointer}
.ua{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#22C55E,#16A34A);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff}
.un-name{font-size:11px;font-weight:600;color:var(--t1);line-height:1.2}
.un-role{font-size:9px;color:var(--t3)}

/* BODY */
.body{display:flex;flex:1}
.sidebar{width:195px;flex-shrink:0;background:var(--sidebar);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:14px 8px;min-height:calc(100vh - 52px);position:sticky;top:52px;align-self:flex-start}
.sb-item{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;color:var(--t3);cursor:pointer;transition:all .15s;font-size:13px;margin-bottom:2px;text-decoration:none}
.sb-item:hover{background:rgba(255,255,255,.04);color:var(--t2)}
.sb-item.active{background:rgba(34,197,94,.1);border-left:2px solid var(--green);color:var(--green);padding-left:8px}
.sb-item svg{width:15px;height:15px;fill:currentColor;opacity:.7}
.sb-item.active svg{opacity:1}
.sb-badge{margin-left:auto;font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px}
.sb-badge.red{background:var(--red);color:#fff}
.sb-badge.amber{background:var(--amber);color:#0B0E12}
.sidebar-foot{margin-top:auto;padding-top:10px;border-top:1px solid var(--border)}

/* CONTENT */
.content{flex:1;min-width:0;min-height:0;display:flex;flex-direction:column;}
.sub-header{padding:0 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--bg);position:sticky;top:0;z-index:50;height:52px;flex-shrink:0;flex-wrap:nowrap;gap:12px;}
.sh-left{display:flex;align-items:center;gap:12px;flex:1;min-width:0;overflow:hidden}
.sh-title{font-family:var(--fh);font-size:16px;font-weight:700}
.sh-tabs{display:flex;gap:2px;overflow-x:auto;overflow-y:hidden;flex-wrap:nowrap;scrollbar-width:none;flex:1;min-width:0;}
.sh-tab{padding:5px 14px;border-radius:6px;font-size:12px;color:var(--t3);cursor:pointer;transition:all .15s;border:1px solid transparent;white-space:nowrap;flex-shrink:0;}
.sh-tab:hover{color:var(--t2)}
.sh-tab.active{background:var(--card);border-color:var(--border);color:var(--t1);font-weight:500}
.sh-right{display:flex;gap:8px;align-items:center}
.sel{background:var(--card);border:1px solid var(--border);color:var(--t1);padding:6px 12px;border-radius:7px;font-family:var(--fb);font-size:12px;outline:none;cursor:pointer}
.btn-export{display:flex;align-items:center;gap:6px;background:var(--green);color:#0B0E12;border:none;padding:7px 14px;border-radius:7px;font-family:var(--fb);font-size:12px;font-weight:600;cursor:pointer;transition:all .2s}
.btn-export:hover{background:var(--g-h)}
.btn-export svg{width:12px;height:12px;fill:#0B0E12}

/* MAIN */
.main{padding:16px 20px;display:flex;flex-direction:column;gap:14px;padding-bottom:80px;overflow-y:auto;min-width:0;flex:1;min-height:0;scroll-padding-top:52px;}

/* TAB PANELS */
.tab-panel{display:none}.tab-panel.active{display:flex;flex-direction:column;gap:14px}

/* CARD */
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden}
.card-head{display:flex;align-items:center;justify-content:space-between;padding:13px 16px;border-bottom:1px solid var(--div)}
.card-title{font-family:var(--fh);font-size:13px;font-weight:700;color:var(--t1)}
.card-sub{font-size:10px;color:var(--t3);margin-top:1px}
.cbtn{font-size:10px;padding:4px 10px;border-radius:5px;border:1px solid var(--border);color:var(--t3);background:var(--raised);cursor:pointer;transition:all .15s;font-family:var(--fb)}
.cbtn:hover{color:var(--t2)}.cbtn.on{background:var(--g-s);border-color:var(--g-b);color:var(--green)}

/* ── STATS TAB ── */
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.sr-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px 18px;position:relative;overflow:hidden;transition:all .2s;cursor:default}
.sr-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:12px 12px 0 0}
.sr-card.g{border-color:rgba(34,197,94,.3)}.sr-card.g::before{background:var(--green);box-shadow:0 0 14px rgba(34,197,94,.5)}
.sr-card.a{border-color:rgba(245,158,11,.3)}.sr-card.a::before{background:var(--amber);box-shadow:0 0 14px rgba(245,158,11,.5)}
.sr-card.r{border-color:rgba(239,68,68,.3)}.sr-card.r::before{background:var(--red);box-shadow:0 0 14px rgba(239,68,68,.5)}
.sr-card.b{border-color:rgba(59,130,246,.3)}.sr-card.b::before{background:var(--blue);box-shadow:0 0 14px rgba(59,130,246,.5)}
.sr-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.sr-icon{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center}
.sr-icon svg{width:14px;height:14px}
.sr-icon.g{background:var(--g-s);border:1px solid var(--g-b)}.sr-icon.g svg{fill:var(--green)}
.sr-icon.a{background:var(--a-s);border:1px solid var(--a-b)}.sr-icon.a svg{fill:var(--amber)}
.sr-icon.r{background:var(--r-s);border:1px solid var(--r-b)}.sr-icon.r svg{fill:var(--red)}
.sr-icon.b{background:var(--b-s);border:1px solid var(--b-b)}.sr-icon.b svg{fill:var(--blue)}
.sr-change{font-size:10px;font-weight:600;padding:2px 6px;border-radius:4px}
.sr-change.up{background:var(--g-s);color:var(--green)}.sr-change.dn{background:var(--r-s);color:var(--red)}.sr-change.nt{background:var(--a-s);color:var(--amber)}
.sr-num{font-family:var(--fh);font-size:32px;font-weight:800;letter-spacing:-1px;line-height:1}
.sr-card.g .sr-num{color:var(--green)}.sr-card.a .sr-num{color:var(--amber)}.sr-card.r .sr-num{color:var(--red)}.sr-card.b .sr-num{color:var(--blue)}
.sr-label{font-size:11px;color:var(--t2);margin-top:4px}
.sr-sub{font-size:10px;color:var(--t3);margin-top:1px}

.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.chart-h200{padding:14px;height:220px}
.chart-h160{padding:14px;height:180px}

/* ── MONTHLY TAB ── */
.monthly-grid{display:grid;grid-template-columns:1fr minmax(260px,320px);gap:14px}
.report-list{padding:0 14px 14px;display:flex;flex-direction:column;gap:8px}
.report-item{display:flex;align-items:center;gap:12px;padding:12px 14px;background:var(--raised);border:1px solid var(--border);border-radius:10px;cursor:pointer;transition:all .2s}
.report-item:hover{border-color:rgba(255,255,255,.1);transform:translateX(3px)}
.ri-icon{width:40px;height:48px;background:linear-gradient(145deg,#1A2D42,#131C26);border:1px solid var(--border);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0}
.ri-icon .pdf-top{width:100%;background:var(--red);height:12px;border-radius:5px 5px 0 0;display:flex;align-items:center;justify-content:center;font-size:7px;font-weight:800;color:#fff}
.ri-icon .pdf-lines{padding:4px;display:flex;flex-direction:column;gap:2px;width:100%}
.ri-icon .pdf-line{height:2px;background:var(--border);border-radius:1px}
.ri-body{flex:1;min-width:0}
.ri-title{font-size:13px;font-weight:600;color:var(--t1)}
.ri-meta{display:flex;gap:8px;align-items:center;margin-top:3px;flex-wrap:wrap}
.ri-tag{font-size:9px;font-weight:600;padding:2px 6px;border-radius:4px}
.ri-size{font-size:10px;color:var(--t3)}
.ri-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px}
.ri-date{font-size:10px;color:var(--t3)}
.dl-btn{display:flex;align-items:center;gap:5px;font-size:11px;font-weight:600;padding:5px 10px;border-radius:6px;background:var(--g-s);border:1px solid var(--g-b);color:var(--green);cursor:pointer;transition:all .15s}
.dl-btn:hover{background:rgba(34,197,94,.2)}
.dl-btn svg{width:11px;height:11px;fill:var(--green)}

.report-preview{display:flex;flex-direction:column;gap:12px}
.preview-card{background:var(--raised);border:1px solid var(--border);border-radius:10px;padding:14px}
.preview-header{font-size:12px;font-weight:700;color:var(--t1);margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--div)}
.preview-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--div)}
.preview-row:last-child{border-bottom:none}
.pr-label{font-size:11px;color:var(--t3)}
.pr-val{font-size:11px;font-weight:600;color:var(--t1)}
.pr-val.green{color:var(--green)}.pr-val.red{color:var(--red)}.pr-val.amber{color:var(--amber)}
.gen-btn{width:100%;padding:10px;border-radius:8px;background:var(--green);color:#0B0E12;border:none;font-family:var(--fh);font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;transition:all .2s}
.gen-btn:hover{background:var(--g-h);transform:translateY(-1px)}
.gen-btn svg{width:14px;height:14px;fill:#0B0E12}

/* ── BENCHMARK TAB ── */
.bench-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.bench-score{display:flex;flex-direction:column;align-items:center;padding:24px;gap:8px}
.score-ring{position:relative;width:140px;height:140px}
.score-ring canvas{position:absolute;top:0;left:0}
.score-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.score-num{font-family:var(--fh);font-size:36px;font-weight:800}
.score-label{font-size:10px;color:var(--t3)}
.bench-metrics{padding:14px;display:flex;flex-direction:column;gap:8px}
.bm-item{display:flex;align-items:center;gap:10px}
.bm-label{font-size:11px;color:var(--t2);width:120px;flex-shrink:0}
.bm-bar-wrap{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.bm-bar{height:100%;border-radius:3px;transition:width 1s ease}
.bm-val{font-size:11px;font-weight:700;width:36px;text-align:right;flex-shrink:0}
.bm-ind{font-size:9px;color:var(--t3);width:40px;text-align:right;flex-shrink:0}

.compare-table{padding:0 14px 14px}
.ctbl{width:100%;border-collapse:collapse}
.ctbl th{padding:8px 12px;text-align:left;font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);background:rgba(255,255,255,.015)}
.ctbl td{padding:10px 12px;border-bottom:1px solid var(--div);font-size:12px;color:var(--t2);vertical-align:middle}
.ctbl tr:last-child td{border-bottom:none}
.ctbl tr:hover td{background:rgba(255,255,255,.018)}
.vs-cell{display:flex;align-items:center;gap:6px}
.vs-you{font-weight:700;color:var(--t1)}
.vs-arrow{font-size:12px}
.vs-ind{color:var(--t3)}
.vs-badge{font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px}
.vb-better{background:var(--g-s);color:var(--green);border:1px solid var(--g-b)}
.vb-worse{background:var(--r-s);color:var(--red);border:1px solid var(--r-b)}
.vb-same{background:var(--a-s);color:var(--amber);border:1px solid var(--a-b)}

/* ── APPRAISAL TAB ── */
.apr-grid{display:grid;grid-template-columns:1fr minmax(220px,280px);gap:14px}
.apr-filters{display:flex;gap:6px;padding:10px 14px;border-bottom:1px solid var(--div);flex-wrap:wrap}
.af{padding:3px 10px;border-radius:100px;font-size:10px;border:1px solid var(--border);color:var(--t3);cursor:pointer;transition:all .15s}
.af:hover{color:var(--t2)}.af.on{background:var(--g-s);border-color:var(--g-b);color:var(--green)}
.apr-table{width:100%;border-collapse:collapse}
.apr-table th{padding:8px 14px;text-align:left;font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);background:rgba(255,255,255,.015)}
.apr-table td{padding:11px 14px;border-bottom:1px solid var(--div);vertical-align:middle}
.apr-table tr:last-child td{border-bottom:none}
.apr-table tr:hover td{background:rgba(255,255,255,.02);cursor:pointer}
.score-bar-wrap{width:80px;height:5px;background:var(--border);border-radius:3px;overflow:hidden;display:inline-block}
.score-bar{height:100%;border-radius:3px}
.grade-pill{font-size:10px;font-weight:800;padding:3px 8px;border-radius:100px}
.gp-ex{background:var(--g-s);color:var(--green);border:1px solid var(--g-b)}
.gp-go{background:var(--b-s);color:var(--blue);border:1px solid var(--b-b)}
.gp-av{background:var(--a-s);color:var(--amber);border:1px solid var(--a-b)}
.gp-po{background:var(--r-s);color:var(--red);border:1px solid var(--r-b)}

.score-breakdown{padding:14px;display:flex;flex-direction:column;gap:10px}
.sb-title{font-size:12px;font-weight:700;color:var(--t1);margin-bottom:4px}
.sb-item{display:flex;flex-direction:row;gap:4px}
.sb-row{display:flex;justify-content:space-between;align-items:center}
.sb-label{font-size:11px;color:var(--t2)}
.sb-val{font-size:11px;font-weight:700}
.sb-bar-wrap{height:4px;background:var(--border);border-radius:2px;overflow:hidden}
.sb-bar{height:100%;border-radius:2px}

/* ── TROPHY TAB ── */
.trophy-header{padding:24px 20px;text-align:center;background:linear-gradient(180deg,rgba(34,197,94,.06) 0%,transparent 100%);border-bottom:1px solid var(--div)}
.trophy-title{font-family:var(--fh);font-size:22px;font-weight:800;color:var(--t1);margin-bottom:4px}
.trophy-sub{font-size:12px;color:var(--t3)}
.trophy-reset{font-size:11px;color:var(--amber);margin-top:6px}

.podium{display:flex;align-items:flex-end;justify-content:center;gap:16px;padding:24px 20px 0}
.pod-item{display:flex;flex-direction:column;align-items:center;gap:8px}
.pod-avatar{border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;position:relative}
.pod-crown{position:absolute;top:-14px;left:50%;transform:translateX(-50%);font-size:18px}
.pod-name{font-size:12px;font-weight:700;color:var(--t1);text-align:center}
.pod-role{font-size:10px;color:var(--t3);text-align:center}
.pod-score{font-family:var(--fh);font-size:18px;font-weight:800;text-align:center}
.pod-block{display:flex;align-items:center;justify-content:center;border-radius:8px 8px 0 0;width:90px}
.pod-rank{font-family:var(--fh);font-size:22px;font-weight:800;color:rgba(255,255,255,.5)}

.lb-full{padding:14px;display:flex;flex-direction:column;gap:6px}
.lb-row{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--raised);border:1px solid var(--border);border-radius:8px;cursor:pointer;transition:all .15s}
.lb-row:hover{border-color:rgba(255,255,255,.1);transform:translateX(3px)}
.lb-rank-num{font-family:var(--fh);font-size:14px;font-weight:800;width:20px;text-align:center}
.lb-av{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0}
.lb-inf{flex:1;min-width:0}
.lb-name{font-size:12px;font-weight:600;color:var(--t1)}
.lb-proj{font-size:10px;color:var(--t3)}
.lb-bar-wrap{width:80px;height:4px;background:var(--border);border-radius:2px;overflow:hidden}
.lb-bar{height:100%;border-radius:2px;background:var(--green)}
.lb-score-val{font-family:var(--fh);font-size:14px;font-weight:800;color:var(--green);min-width:32px;text-align:right}
.lb-change{font-size:10px;font-weight:600;padding:1px 5px;border-radius:3px}
.lbc-up{background:var(--g-s);color:var(--green)}.lbc-dn{background:var(--r-s);color:var(--red)}.lbc-eq{background:var(--a-s);color:var(--amber)}

.trophy-cards{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;padding:14px}
.tc{background:var(--raised);border:1px solid var(--border);border-radius:10px;padding:14px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:6px;transition:all .2s}
.tc:hover{border-color:rgba(255,255,255,.12);transform:translateY(-2px)}
.tc-trophy{font-size:28px}
.tc-title{font-size:11px;font-weight:700;color:var(--t1)}
.tc-name{font-size:13px;font-weight:800;color:var(--t1);font-family:var(--fh)}
.tc-score{font-family:var(--fh);font-size:22px;font-weight:800;color:var(--green)}
.tc-label{font-size:9px;color:var(--t3)}

/* ── MORE DROPDOWN ── */
.more-wrap{position:relative;user-select:none}
.more-menu{
  display:none;position:absolute;top:calc(100% + 6px);left:0;
  background:#131C26;border:1px solid #1E293B;border-radius:10px;
  min-width:210px;z-index:200;padding:6px;
  box-shadow:0 12px 32px rgba(0,0,0,.5);
}
.more-wrap.open .more-menu{display:flex;flex-direction:column;gap:1px}
