<script>
(function(){
  var el = document.getElementById("fbar-scroll");
  if(!el) return;
  // Mouse wheel
  el.addEventListener("wheel", function(e){
    e.preventDefault();
    el.scrollLeft += e.deltaY || e.deltaX;
  }, {passive:false});
  // Mouse drag
  var down=false, sx=0, sl=0;
  el.addEventListener("mousedown", function(e){ down=true; sx=e.clientX; sl=el.scrollLeft; el.style.cursor="grabbing"; });
  document.addEventListener("mouseup", function(){ down=false; el.style.cursor=""; });
  document.addEventListener("mousemove", function(e){ if(!down) return; el.scrollLeft = sl-(e.clientX-sx); });
  // Touch
  var tx=0,tl=0;
  el.addEventListener("touchstart",function(e){tx=e.touches[0].clientX;tl=el.scrollLeft;},{passive:true});
  el.addEventListener("touchmove",function(e){el.scrollLeft=tl-(e.touches[0].clientX-tx);},{passive:true});
})();
</script>
