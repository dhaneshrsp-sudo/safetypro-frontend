<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SafetyPro AI — HSE intelligence, built by HSE professionals</title>
<meta name="description" content="The AI-native HSE platform for construction and high-risk industries. Thoughtful, transparent, deployed in a day."/>
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta property="og:title" content="SafetyPro AI"/>
<meta property="og:description" content="HSE intelligence, built by HSE professionals."/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,400..600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cpath d='M16 2L4 7v9c0 7 5.3 12.7 12 14 6.7-1.3 12-7 12-14V7L16 2z' fill='%23C6583E'/%3E%3C/svg%3E">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
:root{
  --cream:#F5F2EB;
  --cream-2:#EEE9DD;
  --cream-3:#E6DFD0;
  --ink:#1F1B17;
  --ink-2:#4A4239;
  --ink-3:#7A7168;
  --accent:#C6583E;
  --accent-2:#A84A35;
  --sage:#7A8B6D;
  --gold:#B8935C;
  --border:rgba(31,27,23,.1);
  --border-2:rgba(31,27,23,.2);
  --surface-dark:#1F1B17;
  --max:1200px;
}
body{background:var(--cream);color:var(--ink);font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;font-size:17px;line-height:1.6;overflow-x:hidden;font-weight:400;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4{font-family:'Fraunces',Georgia,serif;font-weight:400;letter-spacing:-.02em;line-height:1.1;color:var(--ink)}
h1{font-size:clamp(40px,6.5vw,76px);letter-spacing:-.035em;font-weight:400}
h2{font-size:clamp(30px,4.5vw,52px);font-weight:400}
h3{font-size:clamp(20px,2.4vw,26px);font-weight:500}
.serif{font-family:'Fraunces',Georgia,serif}
.italic{font-style:italic}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}
.container{max-width:var(--max);margin:0 auto;padding:0 32px}
.container-narrow{max-width:820px;margin:0 auto;padding:0 32px}
.fade-in{opacity:0;transform:translateY(16px);transition:opacity .8s ease,transform .8s ease}
.fade-in.vis{opacity:1;transform:translateY(0)}

/* NAV */
.nav{position:sticky;top:0;z-index:100;background:rgba(245,242,235,.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-inner{max-width:var(--max);margin:0 auto;padding:20px 32px;display:flex;align-items:center;justify-content:space-between;gap:24px}
.logo{display:flex;align-items:center;gap:10px;font-family:'Fraunces',serif;font-weight:500;font-size:20px;letter-spacing:-.01em;color:var(--ink)}
.logo svg{width:28px;height:28px}
.logo em{color:var(--accent);font-style:normal;font-weight:500}
.nav-links{display:flex;gap:32px;font-size:15px;color:var(--ink-2)}
.nav-links a{transition:color .2s;padding:4px 0;border-bottom:1px solid transparent}
.nav-links a:hover{color:var(--ink)}
.nav-links .biometric{color:var(--ink)}
.nav-cta{display:flex;gap:14px;align-items:center}
.nav-cta .signin{font-size:15px;color:var(--ink-2);transition:color .2s}
.nav-cta .signin:hover{color:var(--ink)}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;padding:11px 22px;border-radius:4px;font-weight:500;font-size:15px;cursor:pointer;transition:all .25s;border:none;font-family:inherit;white-space:nowrap;letter-spacing:.01em}
.btn-primary{background:var(--accent);color:var(--cream);border:1px solid var(--accent)}
.btn-primary:hover{background:var(--accent-2);border-color:var(--accent-2)}
.btn-ghost{background:transparent;border:1px solid var(--border-2);color:var(--ink)}
.btn-ghost:hover{background:var(--cream-2);border-color:var(--ink-2)}
.btn-dark{background:var(--ink);color:var(--cream);border:1px solid var(--ink)}
.btn-dark:hover{background:var(--ink-2);border-color:var(--ink-2)}
.menu-toggle{display:none;background:none;border:none;color:var(--ink);cursor:pointer;width:32px;height:32px;font-size:20px}

/* HERO */
.hero{padding:100px 0 72px;position:relative}
.hero-inner{display:grid;grid-template-columns:1fr;gap:40px;max-width:980px;margin:0 auto}
.hero .eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:13px;color:var(--ink-2);margin-bottom:32px;letter-spacing:.02em}
.hero .eyebrow::before{content:"";width:28px;height:1px;background:var(--accent)}
.hero h1{margin-bottom:28px;color:var(--ink);max-width:920px}
.hero h1 em{color:var(--accent);font-style:italic;font-weight:500}
.hero .sub{font-size:22px;color:var(--ink-2);line-height:1.5;margin-bottom:40px;max-width:720px;font-weight:300;letter-spacing:-.005em}
.hero-ctas{display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap}
.trust-line{display:flex;gap:24px;flex-wrap:wrap;font-size:14px;color:var(--ink-3)}
.trust-line span{display:flex;align-items:center;gap:8px}
.trust-line span::before{content:"—";color:var(--ink-3)}

/* DASHBOARD STAGE — quiet integrated preview */
.dash-stage{padding:48px 0 100px;position:relative}
.dash-stage-inner{max-width:1100px;margin:0 auto;padding:0 32px}
.dash-label{text-align:center;font-size:13px;color:var(--ink-3);letter-spacing:.15em;text-transform:uppercase;margin-bottom:24px;font-weight:500}
.dash-frame{background:var(--surface-dark);border-radius:12px;overflow:hidden;box-shadow:0 40px 80px -30px rgba(31,27,23,.25),0 0 0 1px rgba(31,27,23,.08)}
.dash-chrome{padding:11px 16px;border-bottom:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.02);display:flex;align-items:center;gap:10px}
.dash-chrome .dots{display:flex;gap:6px}
.dash-chrome .dots span{width:9px;height:9px;border-radius:50%;background:rgba(255,255,255,.18)}
.dash-chrome .url{flex:1;max-width:280px;padding:4px 12px;background:rgba(255,255,255,.04);border-radius:4px;font-size:11px;color:rgba(255,255,255,.5);margin-left:10px;font-family:'Inter',monospace}
.dash-chrome .live{margin-left:auto;display:flex;align-items:center;gap:6px;font-size:11px;color:#8FBC80;font-weight:500}
.dash-chrome .live::before{content:"";width:6px;height:6px;background:#8FBC80;border-radius:50%;box-shadow:0 0 8px #8FBC80;animation:pulse 1.8s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.dash-topnav{padding:12px 16px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;gap:20px;font-size:13px;color:rgba(255,255,255,.7)}
.dash-topnav .it{padding:4px 10px;border-radius:4px}
.dash-topnav .it.ac{background:rgba(198,88,62,.14);color:#E8A090;font-weight:500}
.dash-topnav .user{margin-left:auto;font-size:12px;color:var(--gold);font-weight:500}
.dash-body{display:grid;grid-template-columns:72px 1fr;min-height:360px}
.dash-sb{padding:14px 10px;border-right:1px solid rgba(255,255,255,.06);background:rgba(0,0,0,.18)}
.dash-sb .it{padding:6px 8px;margin-bottom:6px;display:flex;align-items:center;gap:6px}
.dash-sb .it .ic{width:14px;height:14px;border-radius:3px;background:rgba(255,255,255,.12)}
.dash-sb .it.ac{background:rgba(198,88,62,.12);border-left:2px solid var(--accent);margin-left:-8px;padding-left:10px}
.dash-sb .it.ac .ic{background:var(--accent)}
.dash-sb .more{padding:6px;margin:10px 0 6px;border-top:1px dashed rgba(255,255,255,.1);font-size:9px;color:rgba(255,255,255,.3);text-align:center;letter-spacing:.15em;font-weight:500}
.dash-content{padding:18px}
.dash-row{display:grid;gap:10px;margin-bottom:10px}
.dash-row.r5{grid-template-columns:1.3fr 1fr 1fr 1fr 1fr}
.dash-row.r2-6{grid-template-columns:2fr 3fr}
.kpi{padding:13px 14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:8px;position:relative;overflow:hidden}
.kpi.accent{border-color:rgba(198,88,62,.3);background:rgba(198,88,62,.05)}
.kpi.gold{border-color:rgba(184,147,92,.3);background:rgba(184,147,92,.05)}
.kpi-l{font-size:10px;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px;font-weight:500}
.kpi-v{font-family:'Fraunces',serif;font-size:28px;font-weight:400;line-height:1;color:#fff;letter-spacing:-.02em}
.kpi-v.accent-c{color:#E8A090}
.kpi-v.gold-c{color:#D9BA86}
.kpi-v.sage-c{color:#8FBC80}
.kpi-d{font-size:10px;color:rgba(255,255,255,.5);margin-top:6px}
.panel{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:8px;padding:13px 15px}
.panel h5{font-size:11px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.12em;font-weight:500;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center}
.panel h5 .meta{color:#8FBC80;font-weight:500;text-transform:none;letter-spacing:normal}
.act{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:11px}
.act:last-child{border:0}
.av{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600;flex-shrink:0;font-family:'Inter',sans-serif}
.av.a{background:rgba(198,88,62,.22);color:#E8A090}
.av.b{background:rgba(122,139,109,.22);color:#9DB38A}
.av.c{background:rgba(184,147,92,.22);color:#D9BA86}
.av.d{background:rgba(139,101,180,.22);color:#B49AD0}
.act .nm{color:#fff;font-weight:500;font-size:12px}
.act .mt{color:rgba(255,255,255,.4);font-size:10px}
.st{padding:2px 8px;font-size:10px;border-radius:3px;font-weight:500;margin-left:auto}
.st.ok{background:rgba(143,188,128,.18);color:#9DB38A}
.st.pd{background:rgba(184,147,92,.18);color:#D9BA86}

/* Section base */
section{padding:96px 0;position:relative}
.sec-head{text-align:center;margin-bottom:64px;max-width:760px;margin-left:auto;margin-right:auto}
.sec-head.left{text-align:left;margin-left:0}
.sec-eyebrow{display:inline-block;font-size:12px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.18em;font-weight:500;margin-bottom:20px}
.sec-head h2{margin-bottom:20px;color:var(--ink)}
.sec-head h2 em{color:var(--accent);font-style:italic;font-weight:400}
.sec-head p{color:var(--ink-2);font-size:19px;line-height:1.6;font-weight:300}

/* PROBLEM */
.problem{background:var(--cream-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.prob-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.prob-card{padding:8px 0}
.prob-num{font-family:'Fraunces',serif;font-size:46px;font-weight:400;color:var(--accent);line-height:1;margin-bottom:20px;letter-spacing:-.02em}
.prob-card h3{color:var(--ink);margin-bottom:12px;font-size:22px}
.prob-card p{color:var(--ink-2);font-size:16px;line-height:1.65}

/* PRODUCT TOUR */
.tour-tabs{display:flex;gap:0;justify-content:center;margin-bottom:40px;flex-wrap:wrap;border-bottom:1px solid var(--border)}
.tour-tab{padding:14px 20px;background:none;border:none;color:var(--ink-3);font-size:15px;cursor:pointer;transition:all .2s;font-family:inherit;font-weight:500;position:relative;letter-spacing:-.005em}
.tour-tab:hover{color:var(--ink)}
.tour-tab.active{color:var(--ink)}
.tour-tab.active::after{content:"";position:absolute;bottom:-1px;left:20px;right:20px;height:2px;background:var(--accent)}
.tour-view{padding:48px 0}
.tour-content{display:grid;grid-template-columns:1fr 1.3fr;gap:56px;align-items:center}
.tour-left h3{color:var(--ink);margin-bottom:18px;font-size:30px;letter-spacing:-.02em}
.tour-left p{color:var(--ink-2);font-size:17px;line-height:1.65;margin-bottom:24px;font-weight:400}
.tour-left ul{list-style:none;display:flex;flex-direction:column;gap:12px}
.tour-left li{color:var(--ink-2);font-size:15.5px;display:flex;gap:14px;align-items:flex-start;line-height:1.55}
.tour-left li::before{content:"";min-width:5px;height:5px;margin-top:9px;background:var(--accent);border-radius:50%}
.tour-mock{background:var(--surface-dark);border:1px solid var(--border);border-radius:10px;padding:16px;overflow:hidden;position:relative;min-height:320px;box-shadow:0 20px 50px -20px rgba(31,27,23,.15)}

/* AI SECTION */
.ai-sec{background:var(--cream)}
.ai-layout{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
.ai-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
.ai-card{padding:28px 26px;background:var(--cream-2);border:1px solid var(--border);border-radius:8px;transition:all .3s}
.ai-card:hover{border-color:var(--border-2);transform:translateY(-2px)}
.ai-eyebrow{font-family:'Fraunces',serif;font-size:13px;color:var(--accent);text-transform:uppercase;letter-spacing:.18em;font-weight:500;margin-bottom:14px}
.ai-card h3{color:var(--ink);margin-bottom:10px;font-size:20px;letter-spacing:-.01em}
.ai-card p{color:var(--ink-2);font-size:14.5px;line-height:1.6}
.ai-live{padding:32px;background:var(--surface-dark);border-radius:10px;color:var(--cream);box-shadow:0 20px 50px -20px rgba(31,27,23,.2)}
.ai-live-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,.08)}
.ai-live-head .t{font-size:11px;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.18em;font-weight:500;display:flex;align-items:center;gap:9px}
.ai-live-head .t::before{content:"";width:7px;height:7px;background:#E8A090;border-radius:50%;box-shadow:0 0 10px #E8A090;animation:pulse 1.8s infinite}
.ai-live-head .time{font-size:11px;color:rgba(255,255,255,.4);font-family:'Inter',monospace}
.ai-pred{padding:16px;background:rgba(255,255,255,.04);border-radius:6px;margin-bottom:12px}
.ai-pred-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.ai-pred-head .ttl{font-family:'Fraunces',serif;font-size:16px;color:#fff;letter-spacing:-.01em}
.ai-pred-conf{font-size:11px;color:#E8A090;font-family:'Inter',monospace;letter-spacing:.05em}
.ai-pred p{font-size:13px;color:rgba(255,255,255,.65);line-height:1.6;margin-bottom:10px}
.ai-pred-meta{display:flex;gap:16px;font-size:11px;color:rgba(255,255,255,.5);flex-wrap:wrap}

/* STANDARDS */
.standards{padding:56px 0;background:var(--cream-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.standards-inner{max-width:var(--max);margin:0 auto;padding:0 32px;text-align:center}
.standards-label{font-size:12px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.18em;font-weight:500;margin-bottom:28px;display:block}
.standards-badges{display:flex;gap:40px;flex-wrap:wrap;align-items:center;justify-content:center}
.std-badge{font-family:'Fraunces',serif;font-size:18px;color:var(--ink-2);font-weight:400;letter-spacing:-.01em}

/* REGIONS */
.regions{background:var(--cream)}
.regions-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.region-card{padding:22px 0;border-top:1px solid var(--border)}
.region-head{display:flex;align-items:center;gap:12px;margin-bottom:10px}
.region-head img{width:24px;height:17px;border-radius:2px;object-fit:cover}
.region-head .name{font-family:'Fraunces',serif;font-size:18px;color:var(--ink);font-weight:500;letter-spacing:-.01em}
.region-regs{font-size:13.5px;color:var(--ink-2);line-height:1.6}

/* PRICING */
.pricing{background:var(--cream-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:1100px;margin:0 auto}
.price-card{padding:36px 30px;background:var(--cream);border:1px solid var(--border);border-radius:8px;position:relative;transition:all .3s;display:flex;flex-direction:column}
.price-card:hover{border-color:var(--border-2)}
.price-card.featured{border:1px solid var(--accent);background:var(--cream)}
.price-card.featured::before{content:"Limited slots";position:absolute;top:-12px;left:30px;padding:4px 12px;background:var(--accent);color:var(--cream);font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:500;border-radius:3px}
.price-name{font-size:13px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.15em;font-weight:500;margin-bottom:12px}
.price-name.featured{color:var(--accent)}
.price-title{font-family:'Fraunces',serif;font-size:28px;font-weight:500;color:var(--ink);margin-bottom:10px;letter-spacing:-.02em}
.price-desc{color:var(--ink-2);font-size:15px;line-height:1.6;margin-bottom:28px}
.price-feats{list-style:none;margin-bottom:28px;flex:1}
.price-feats li{padding:11px 0;font-size:14.5px;color:var(--ink-2);display:flex;gap:12px;border-bottom:1px solid var(--border);line-height:1.5}
.price-feats li::before{content:"—";color:var(--accent);font-weight:500}
.price-feats li:last-child{border-bottom:none}
.price-cta{display:block;text-align:center;padding:13px;border-radius:4px;font-size:14.5px;font-weight:500;transition:all .2s;font-family:inherit}
.cta-ghost{background:transparent;border:1px solid var(--border-2);color:var(--ink)}
.cta-ghost:hover{background:var(--cream-2);border-color:var(--ink-2)}
.cta-accent{background:var(--accent);color:var(--cream);border:1px solid var(--accent)}
.cta-accent:hover{background:var(--accent-2)}

/* FAQ */
.faq-wrap{max-width:800px;margin:0 auto}
.faq-item{border-bottom:1px solid var(--border);transition:all .2s}
.faq-q{padding:26px 0;cursor:pointer;display:flex;align-items:center;justify-content:space-between;font-family:'Fraunces',serif;font-size:21px;font-weight:500;color:var(--ink);user-select:none;width:100%;background:none;border:none;text-align:left;letter-spacing:-.01em;line-height:1.3}
.faq-icon{width:24px;height:24px;display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--ink-3);transition:transform .3s;flex-shrink:0;font-family:'Inter',sans-serif;font-weight:300}
.faq-item.open .faq-icon{transform:rotate(45deg);color:var(--accent)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s,padding .3s}
.faq-item.open .faq-a{max-height:400px;padding:0 0 28px}
.faq-a p{color:var(--ink-2);font-size:16px;line-height:1.7;max-width:680px}

/* FINAL CTA */
.final-cta{text-align:center;padding:120px 0;background:var(--cream-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.final-inner{max-width:720px;margin:0 auto;padding:0 32px}
.final-cta h2{color:var(--ink);margin-bottom:22px}
.final-cta h2 em{color:var(--accent);font-style:italic}
.final-cta p{color:var(--ink-2);font-size:19px;line-height:1.6;margin-bottom:36px;font-weight:300}
.final-ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}

/* FOOTER */
.footer{padding:72px 0 32px;background:var(--cream)}
.footer-grid{display:grid;grid-template-columns:2.4fr 1fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px}
.footer-brand{padding-right:24px}
.footer-logo{display:flex;align-items:center;gap:10px;margin-bottom:20px;font-family:'Fraunces',serif;font-weight:500;font-size:20px;color:var(--ink);letter-spacing:-.01em}
.footer-logo svg{width:28px;height:28px}
.footer-logo em{color:var(--accent);font-style:normal}
.footer-brand p{color:var(--ink-2);font-size:14.5px;line-height:1.65;margin-bottom:20px;max-width:340px}
.founder-box{padding:16px 18px;border:1px solid var(--border);border-radius:6px}
.founder-label{font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.15em;font-weight:500;margin-bottom:6px}
.founder-name{font-family:'Fraunces',serif;font-size:17px;color:var(--ink);font-weight:500;margin-bottom:4px;letter-spacing:-.01em}
.founder-creds{font-size:13px;color:var(--ink-2);line-height:1.5}
.footer-col h4{font-family:'Inter',sans-serif;font-size:12px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.15em;font-weight:600;margin-bottom:18px}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:11px}
