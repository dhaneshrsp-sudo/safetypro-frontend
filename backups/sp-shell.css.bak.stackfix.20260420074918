/* -------- KPI / FILTER / TABLE HEADER LABELS (UPPERCASE SMALL CAPS) -------- */
html body .kpi-label,
html body .filter-label,
html body .field-label,
html body .form-label,
html body label,
html body th,
html body .table-header,
html body .filter-group label,
