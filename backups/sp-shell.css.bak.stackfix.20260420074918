/* ===============================================================
   SAFETYPRO UNIFIED TYPOGRAPHY SYSTEM (Linear-style 13px)
   Single source of truth for fonts across all 13 pages.
   High specificity (html body) beats page-inline styles.
   =============================================================== */

:root {
  /* Font families */
  --sp-font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --sp-font-display: 'Fraunces', Georgia, serif;
  --sp-font-mono: 'JetBrains Mono', ui-monospace, Consolas, monospace;
  
  /* Size scale - 5 sizes only, disciplined */
  --sp-text-xs:  11px;  /* labels, badges, table headers, filter labels */
  --sp-text-sm:  12px;  /* footer, timestamps, meta */
  --sp-text-md:  13px;  /* BODY DEFAULT: tables, forms, sidebar, tabs */
  --sp-text-lg:  15px;  /* card titles, section headers */
  --sp-text-xl:  18px;  /* page titles */
  --sp-text-kpi: 28px;  /* KPI hero numbers */
  
  /* Weights - only 3 */
  --sp-fw-regular:  400;
  --sp-fw-medium:   500;
  --sp-fw-semibold: 600;
  
  /* Line heights */
  --sp-lh-tight:  1.3;
  --sp-lh-normal: 1.5;
  --sp-ls-caps:   0.05em;
}

/* -------- GLOBAL BODY DEFAULT -------- */
html body, html body p, html body div, html body span, html body li, html body a {
  font-family: var(--sp-font-sans) !important;
}
html body {
  font-size: var(--sp-text-md) !important;
  font-weight: var(--sp-fw-regular) !important;
  line-height: var(--sp-lh-normal) !important;
  color: inherit;
}

/* -------- LOGO (keep Fraunces serif) -------- */
html body .logo, html body .brand, html body a.logo {
  font-family: var(--sp-font-display) !important;
}

/* -------- PAGE TITLE -------- */
html body h1,
html body .page-title,
html body .main-title,
html body .sub-header h1,
html body .sub-header h2:first-child {
  font-size: var(--sp-text-xl) !important;
  font-weight: var(--sp-fw-semibold) !important;
  line-height: var(--sp-lh-tight) !important;
  font-family: var(--sp-font-sans) !important;
  letter-spacing: -0.01em !important;
}

/* -------- SECTION HEADERS -------- */
html body h2,
html body .section-title,
html body h3 {
  font-size: var(--sp-text-lg) !important;
  font-weight: var(--sp-fw-semibold) !important;
  line-height: var(--sp-lh-tight) !important;
