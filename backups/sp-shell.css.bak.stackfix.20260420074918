/* ===============================================================
   METHODOLOGY MODAL STYLES — sp-methodology.js
   Professional dark modal matching Linear/Stripe/Vercel aesthetic
   =============================================================== */

/* Overlay */
.sp-meth-overlay {
  position: fixed;
  inset: 0;
  background: rgba(9, 14, 22, 0.85);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  animation: sp-meth-fade-in 0.2s ease-out;
}

@keyframes sp-meth-fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* Modal container */
.sp-meth-modal {
  background: var(--card, #0D1520);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  width: min(900px, 100%);
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(16,185,129,0.1);
  animation: sp-meth-slide-up 0.25s ease-out;
  font-family: 'Inter', -apple-system, sans-serif;
}

@keyframes sp-meth-slide-up {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* Header */
.sp-meth-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 24px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  background: radial-gradient(ellipse 400px 200px at top left, rgba(16,185,129,0.12), transparent 70%);
}

.sp-meth-title {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}

.sp-meth-icon {
  font-size: 24px;
  line-height: 1;
  padding-top: 2px;
}

.sp-meth-title h2 {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
  color: #F9FAFB;
  letter-spacing: -0.01em;
}

.sp-meth-subtitle {
  margin: 4px 0 0;
  font-size: 12px;
  color: #9CA3AF;
  font-weight: 400;
}

.sp-meth-close {
  background: transparent;
  border: none;
  color: #9CA3AF;
  font-size: 18px;
  cursor: pointer;
  padding: 4px 10px;
  border-radius: 6px;
  line-height: 1;
  transition: all 0.15s;
}

.sp-meth-close:hover {
  background: rgba(255,255,255,0.05);
  color: #F9FAFB;
}

/* Body (scrollable) */
.sp-meth-body {
  overflow-y: auto;
  padding: 20px 24px;
  flex: 1;
}

.sp-meth-body::-webkit-scrollbar {
  width: 6px;
}

.sp-meth-body::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.1);
  border-radius: 3px;
}

/* Sections */
.sp-meth-section {
  margin-bottom: 24px;
}

.sp-meth-section:last-child {
  margin-bottom: 0;
}

.sp-meth-section h3 {
  font-size: 12px;
  font-weight: 600;
  color: #10B981;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin: 0 0 10px;
}

.sp-meth-section p {
  margin: 0;
  font-size: 13px;
  color: #D1D5DB;
  line-height: 1.6;
