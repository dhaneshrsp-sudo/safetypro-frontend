/* ===============================================================
   SAFETYPRO UNIFIED COLOR PALETTE — 6-Token System
   Design tokens only. Nothing overridden yet.
   Use these variables going forward for new components.
   =============================================================== */

:root {
  /* ===== 6 CORE BRAND/SEMANTIC TOKENS ===== */
  --sp-brand:     #C6583E;  /* Terracotta - primary action, active states, tab underlines */
  --sp-success:   #10B981;  /* Muted emerald - KPIs on-target, completed, passing */
  --sp-danger:    #EF4444;  /* Clean red - critical risks, overdue, incidents, Fix Now */
  --sp-warning:   #F59E0B;  /* Modern amber - pending, warnings, near-miss */
  --sp-info:      #3B82F6;  /* Modern blue - informational, counts, links */
  --sp-accent:    #8B5CF6;  /* Violet - AI features, HRM, reports differentiator */

  /* ===== TEXT HIERARCHY (3 neutral grays) ===== */
  --sp-text-strong: #F3F4F6;  /* Headlines, KPI numbers, primary text */
  --sp-text-body:   #9CA3AF;  /* Body text, labels, descriptions */
  --sp-text-muted:  #6B7280;  /* Captions, metadata, timestamps */

  /* ===== SEMANTIC TINTS (12% opacity) for card borders, chips, subtle backgrounds ===== */
  --sp-brand-tint:   rgba(198, 88, 62, 0.12);
  --sp-success-tint: rgba(16, 185, 129, 0.12);
  --sp-danger-tint:  rgba(239, 68, 68, 0.12);
  --sp-warning-tint: rgba(245, 158, 11, 0.12);
  --sp-info-tint:    rgba(59, 130, 246, 0.12);
  --sp-accent-tint:  rgba(139, 92, 246, 0.12);

  /* ===== STANDARD CHART PALETTE (fixed order for every chart) ===== */
  --sp-chart-1: var(--sp-success);  /* emerald (positive / primary data) */
  --sp-chart-2: var(--sp-warning);  /* amber (secondary / comparison) */
  --sp-chart-3: var(--sp-info);     /* blue (tertiary) */
  --sp-chart-4: var(--sp-accent);   /* violet (quaternary) */
  --sp-chart-5: var(--sp-danger);   /* red (alerts / negative) */

  /* ===== SURFACE LAYERS ===== */
  --sp-surface-0: #0b0f14;   /* App background (deepest) */
  --sp-surface-1: #141922;   /* Card background */
  --sp-surface-2: #1C2230;   /* Card hover / active rows */
  --sp-surface-3: #252B3B;   /* Elevated elements (dropdowns, modals) */

  /* ===== BORDERS ===== */
  --sp-border-subtle: rgba(255, 255, 255, 0.06);  /* Most card borders */
  --sp-border-medium: rgba(255, 255, 255, 0.10);  /* Active states */
  --sp-border-strong: rgba(255, 255, 255, 0.16);  /* Focused inputs */
}
/* ===============================================================
   SAFETYPRO — APPLY COLOR TOKENS (Option A: Gentle Refinement)
