  font-weight: var(--sp-fw-semibold) !important;
  font-family: var(--sp-font-sans) !important;
  letter-spacing: var(--sp-ls-caps) !important;
  text-transform: uppercase !important;
}

/* -------- FOOTER -------- */
html body footer,
html body .sp-footer,
html body .page-footer {
  font-size: var(--sp-text-sm) !important;
  font-weight: var(--sp-fw-regular) !important;
  font-family: var(--sp-font-sans) !important;
  line-height: var(--sp-lh-normal) !important;
  letter-spacing: 0 !important;
  text-transform: none !important;
}

/* -------- META TEXT (timestamps, subtitles, captions) -------- */
html body .meta,
html body .caption,
html body .subtitle,
html body .text-muted,
html body small {
  font-size: var(--sp-text-sm) !important;
