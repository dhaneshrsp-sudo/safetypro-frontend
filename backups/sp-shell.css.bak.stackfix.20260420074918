/* ==================================================================
   PLAN C FINAL: Row 1 lives inside .sub-header now
   Adjust child selectors: Row1=first, tabs=nth(2), filters=nth(3)
   ================================================================== */

/* Override previous Plan C CSS (tab row is now 2nd child, not 1st) */
.sub-header > .sp-page-identity {
  /* Row 1 inherits base .sp-page-identity styling from framework CSS */
