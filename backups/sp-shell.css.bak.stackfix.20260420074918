  font-weight: var(--sp-fw-regular) !important;
  font-family: var(--sp-font-sans) !important;
  line-height: var(--sp-lh-normal) !important;
  text-transform: none !important;
}

/* -------- INPUTS, SELECTS, TEXTAREAS (override Arial leak) -------- */
html body input,
html body select,
html body textarea,
html body .input,
html body .select,
html body .form-control {
  font-size: var(--sp-text-md) !important;
  font-weight: var(--sp-fw-regular) !important;
  font-family: var(--sp-font-sans) !important;
  line-height: var(--sp-lh-normal) !important;
