}

/* -------- CARD TITLES (override Montserrat) -------- */
html body .card h3,
html body .card-title,
html body .card-header h3,
html body .kpi-title,
html body .card .title,
html body .widget-title {
  font-size: var(--sp-text-md) !important;
  font-weight: var(--sp-fw-semibold) !important;
  font-family: var(--sp-font-sans) !important;
  line-height: var(--sp-lh-tight) !important;
}

/* -------- KPI HERO NUMBERS -------- */
html body .kpi-value,
html body .kpi-number,
html body .big-number,
html body .metric-value,
html body .stat-value {
  font-size: var(--sp-text-kpi) !important;
  font-weight: 700 !important;
  line-height: 1.1 !important;
  font-family: var(--sp-font-sans) !important;
  letter-spacing: -0.02em !important;
