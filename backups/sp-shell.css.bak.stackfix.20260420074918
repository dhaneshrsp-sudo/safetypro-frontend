/* === TYPOGRAPHY: Force Fraunces serif for brand headings, Inter for body === */
@import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap');

body, .topnav, .sb, .content, .panel, .card, .kpi, .modal, .dropdown {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
}

/* Big numbers, brand text use Fraunces serif */
.logo-text, .brand-name, .kpi-v, .htn-num, .hhse-num, .tm-k-v,
.score-num, .num-big, h1.brand, .stat-num, .metric-v {
    font-family: 'Fraunces', Georgia, serif !important;
    font-weight: 600 !important;
    letter-spacing: -0.01em !important;
}

/* === WORDMARK: Force identical SafetyPro . AI across all logos === */
.logo, .brand, .htn-logo, a.logo {
    font-family: 'Fraunces', Georgia, serif !important;
    font-weight: 600 !important;
    font-size: 17px !important;
    letter-spacing: -0.01em !important;
    text-decoration: none !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
    color: inherit !important;
}

.logo-text, .brand-name {
    font-family: 'Fraunces', Georgia, serif !important;
    font-weight: 600 !important;
    font-size: 17px !important;
    letter-spacing: -0.01em !important;
}

/* The terracotta dot inside wordmarks — force everywhere */
.logo span[style*="C6583E"],
.brand span[style*="C6583E"],
.logo-text span[style*="C6583E"],
.brand-name span[style*="C6583E"] {
    color: #C6583E !important;
    font-weight: 700 !important;
    margin: 0 4px !important;
    font-style: normal !important;
    display: inline !important;
}

/* === TOPNAV: Force same height, background, border across all pages === */
.topnav {
    height: 56px !important;
    background: rgba(10, 16, 30, 0.95) !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06) !important;
    backdrop-filter: blur(12px) !important;
    display: flex !important;
    align-items: center !important;
    padding: 0 20px !important;
    gap: 16px !important;
}

/* Topnav nav links — same font, color, transition */
.topnav a, .topnav .nl, .nl {
    font-size: 14px !important;
    font-weight: 500 !important;
    color: #9aa5b1 !important;
    padding: 8px 14px !important;
    text-decoration: none !important;
    border-radius: 6px !important;
    transition: color 0.15s !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 6px !important;
}

.topnav a:hover, .nl:hover {
    color: #fff !important;
}

/* Active topnav button — terracotta underline only */
.topnav a.active, .nl.active {
    color: #fff !important;
    background: transparent !important;
    border-radius: 0 !important;
    border-bottom: 2px solid #C6583E !important;
    padding-bottom: 6px !important;
}

/* Kill any pseudo-elements that might draw green underlines */
.topnav a.active::before, .topnav a.active::after,
.nl.active::before, .nl.active::after {
    display: none !important;
    content: none !important;
    background: transparent !important;
}

/* === SIDEBAR: Force same width, background === */
.sb, .sidebar {
    width: 220px !important;
    background: rgba(10, 16, 30, 0.5) !important;
    border-right: 1px solid rgba(255, 255, 255, 0.05) !important;
    padding: 14px 0 !important;
}

.sb-sec {
