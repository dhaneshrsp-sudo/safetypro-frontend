html body [style*="background: #22C55E"],
html body [style*="background:#22C55E"],
html body [style*="background-color: #22C55E"],
html body [style*="background-color:#22C55E"] {
  background-color: var(--sp-success) !important;
}

/* ==== 2. TONE DOWN ALL KPI BIG NUMBERS ==== */
/* KPI numbers should be white with ONLY a small colored accent/trend, not full neon */
html body .kpi-card [style*="color"],
html body .card [style*="font-size: 2"] [style*="color"],
html body [style*="font-size: 28"] {
